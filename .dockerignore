**/__pycache__
**/*.py[cod]
**/.pytest_cache
.venv
venv
*.egg-info
.mypy_cache
.ruff_cache
.cursor
terminals

# Локальные модели монтируются томом; в контекст сборки не нужны
models/

# Документация и CI в образе не обязательны
docs/
.github/
