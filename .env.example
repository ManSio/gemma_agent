TURN_QUALITY_AUDIT_PATH=data/runtime/quality_audit.jsonl

# =============================================================================
# Google News RSS + дайджест в Telegram
# Подробные комментарии (каждая переменная, true/false, примеры):
#   config/env_catalog/20_news_digest.env.fragment
# Применить на сервер: python scripts/apply_env_catalog.py /opt/gemma_agent/.env
# =============================================================================
# BRAIN_NEWS_DIRECT_FROM_SEARCH — формат ответа на «новости».
#   false — LLM: 3–4 предложения на пункт (что внутри новости).
#   true — только заголовки из RSS без LLM (быстро, но сухо).

# BRAIN_NEWS_DIRECT_FROM_SEARCH — формат ответа на «новости».
#   false — LLM: 3–4 предложения на пункт (что внутри новости).
#   true — только заголовки из RSS без LLM (быстро, но сухо).

BRAIN_NEWS_DIRECT_FROM_SEARCH=false

# --- Brain owns turn (реформа 2026-05): один brain на ход, direct только по ALLOW_* ---
# BRAIN_OWN_TURN_ENABLED=true — отключить plan bypass (news/weather/geo/«да»→поиск) по умолчанию.
# BRAIN_OWN_TURN_ALLOW_NEWS=false — новости через brain + UniversalSearch, не RSS в plan().
# BRAIN_OWN_TURN_ALLOW_WEATHER=false — погода через brain/tools.
# BRAIN_OWN_TURN_ALLOW_GEO_NEARBY=false — «рядом» через brain.
# BRAIN_OWN_TURN_ALLOW_AFFIRMATIVE_SEARCH=false — «да» после поиска — brain, не plan shortcut.
# NEWS_DIGEST_SEARCH_ONLY=true — дайджест только из UniversalSearch/SearX; Google News RSS выключен.
NEWS_DIGEST_SEARCH_ONLY=true
# NEWS_DIGEST_MIN_ITEMS=2 — минимум пунктов для дайджеста (2 + relaxed quality при тонком SearX).
# NEWS_DIGEST_MAX_SEARCH_QUERIES=5 — лимит refine-запросов за один ход (таймаут Telegram).
# NEWS_SEARCH_SEARX_NEWS_CATEGORY=false — categories=general для news (news category часто SEO-хабы).
NEWS_DIGEST_MIN_ITEMS=2
NEWS_DIGEST_MAX_SEARCH_QUERIES=5
NEWS_SEARCH_SEARX_NEWS_CATEGORY=false
# NEWS_RSS_FALLBACK_ENABLED=false — Google News RSS только если NEWS_DIGEST_SEARCH_ONLY=false и ALLOW_NEWS=true.
# NEWS_RESPECT_USER_SEARCH_OVER_RSS=true — фразы «не через rss», «из интернета» и т.п.: не news_direct и
#   не Google News RSS в pipeline-hint (ход в brain + UniversalSearch). false — старое поведение.
NEWS_RESPECT_USER_SEARCH_OVER_RSS=true
BRAIN_OWN_TURN_ENABLED=true
BRAIN_OWN_TURN_ALLOW_NEWS=false
BRAIN_OWN_TURN_ALLOW_WEATHER=false
BRAIN_OWN_TURN_ALLOW_GEO_NEARBY=false
BRAIN_OWN_TURN_ALLOW_AFFIRMATIVE_SEARCH=false
NEWS_RSS_FALLBACK_ENABLED=false
# NEWS_PIPELINE_RSS_ON_SEARCH_FAIL=false — не подмешивать Google News RSS, если поиск пуст (при SEARCH_ONLY игнор).
NEWS_PIPELINE_RSS_ON_SEARCH_FAIL=false
# BRAIN_WEATHER_API_ENABLED — Open-Meteo/wttr внутри brain (short-circuit + hint), не planner bypass.
BRAIN_WEATHER_API_ENABLED=true
# BRAIN_NEWS_ITEM_REPLY_ENABLED=true — пункт дайджеста «4» в pipeline (не plan bypass).
BRAIN_NEWS_ITEM_REPLY_ENABLED=true
# BRAIN_WEATHER_SHORT_CIRCUIT_REQUIRES_ANCHOR=true — «погода» без LLM только при сохранённых lat/lon (pin или прошлый успешный прогноз).
BRAIN_WEATHER_SHORT_CIRCUIT_REQUIRES_ANCHOR=true
# BRAIN_WEATHER_PIPELINE_PREFETCH=false — не подмешивать сводку погоды в external_hint до LLM (фаза 5).
BRAIN_WEATHER_PIPELINE_PREFETCH=false
# BRAIN_PIPELINE_NEWS_SHORT_CIRCUIT=false — ответ по новостям до LLM в pipeline (фаза 5; нужен ALLOW_NEWS=true).
BRAIN_PIPELINE_NEWS_SHORT_CIRCUIT=false
# BRAIN_PIPELINE_NEWS_ITEM_SHORT_CIRCUIT=false — пункт дайджеста до LLM в pipeline.
BRAIN_PIPELINE_NEWS_ITEM_SHORT_CIRCUIT=false
# WEATHER_ANCHOR_ON_FACT_COMMIT=true — после сохранения city в /me — геокод → weather_anchor.
WEATHER_ANCHOR_ON_FACT_COMMIT=true

# ROUTE_SEMANTIC_AUDIT_ENABLED — лог расхождения classifier vs final_profile в turns (не override).
# ROUTE_SEMANTIC_AUDIT_LIVE_OVERRIDE=false — никогда не менять профиль по embedding на prod.
ROUTE_SEMANTIC_AUDIT_ENABLED=true
ROUTE_SEMANTIC_AUDIT_LIVE_OVERRIDE=false

# NEWS_DIRECT_REPLY_ENABLED — legacy; при BRAIN_OWN_TURN_ENABLED игнорируется, см. BRAIN_OWN_TURN_ALLOW_NEWS.
NEWS_DIRECT_REPLY_ENABLED=false

# NEWS_SELF_VERIFY_ENABLED — narrative digest: self-verify с source_context (источники из NewsSource).
NEWS_SELF_VERIFY_ENABLED=true

# NEWS_CONSISTENCY_CHECK_ENABLED — log-only проверка противоречий с предыдущими turn'ами в news hot path.
NEWS_CONSISTENCY_CHECK_ENABLED=true

# NEWS_DIGEST_LLM_SUMMARY — дайджест: 3–4 предложения на пункт по заголовку RSS (без мусора из поиска).
NEWS_DIGEST_LLM_SUMMARY=true
#
# NEWS_DIGEST_FORMAT — как показывать дайджест по RSS:
#   narrative — абзацы по темам (см. NEWS_DIGEST_NARRATIVE_STYLE); пункты ленты в сессии для «1» и «подробнее про …»;
#   list — нумерованный список заголовков + сниппеты (как раньше).
# NEWS_DIGEST_NARRATIVE_STYLE — per_item | flow | world_brief.
#   per_item + запрос «новости в мире» / world_feed → авто world_brief (лид, дата в шапке, футер открытых источников).
# NEWS_DIGEST_NARRATIVE_SENTENCES_PER_ITEM — предложений в абзаце (per_item / world_brief).
# NEWS_DIGEST_WORLD_MAX_ITEMS — заголовков в промпт для world_brief (по умолчанию 10).
# NEWS_DIGEST_WORLD_THEMATIC_QUERIES — доп. SearX-запросы по сферам (Иран, Украина, экономика, космос, спорт).
# NEWS_DIGEST_WORLD_MAX_SEARCH_QUERIES — SearX-запросов за дайджест (мир, до 8; дефолт 6).
# NEWS_DIGEST_WORLD_THEMATIC_MAX — тематических запросов (Иран, Украина, …) поверх базовых.
# NEWS_DIGEST_WORLD_SEARCH_TIMEOUT_SEC — таймаут одного SearX (дефолт 22); только SearX, без DDG fallback.
# NEWS_DIGEST_WORLD_PARALLEL_SEARCH — устарело: мировой дайджест только последовательный SearX (false).
# NEWS_DIGEST_GATHER_EARLY_STOP — мир: стоп SearX, когда уже есть 2+ нормальных статьи (true).
# NEWS_DIGEST_SEARCH_QUIET_ERRORS — не писать CDC на каждый таймаут refine (true для world по умолчанию).
# NEWS_DIGEST_NARRATIVE_WORLD_TIMEOUT_SEC / WORLD_BASE_TIMEOUT_SEC — LLM narrative мир (52/38; outer ≥ adaptive free).
# NEWS_DIGEST_NARRATIVE_OUTER_MARGIN_SEC — запас with_retry outer над adaptive free (default 6).
# NEWS_DIGEST_WORLD_PAGE_ENRICH — url_fetch статей в snippet (дефолт 2 статьи, 8s).
# NEWS_DIGEST_WORLD_PAGE_ENRICH_MAX / NEWS_DIGEST_WORLD_PAGE_ENRICH_TIMEOUT_SEC — лимиты fetch.
# NEWS_DIGEST_NARRATIVE_MAX_TOKENS / NEWS_DIGEST_NARRATIVE_MAX_CHARS — длина narrative-дайджеста (ниже = быстрее p90).
#   Дефолт в коде: 2200/2800 tok, 4200 chars; expanded — 2600/3200, 4600 chars.
#   Пример: NEWS_DIGEST_NARRATIVE_MAX_TOKENS=2200
NEWS_DIGEST_NARRATIVE_MAX_TOKENS=2200
NEWS_DIGEST_NARRATIVE_MAX_CHARS=4200
# NEWS_NARRATIVE_FOOTER — футер под narrative (пусто = дефолт; мир → «Составлено на основе…»; 0/false — без футера).
NEWS_DIGEST_FORMAT=narrative
NEWS_DIGEST_NARRATIVE_STYLE=per_item
NEWS_DIGEST_NARRATIVE_SENTENCES_PER_ITEM=4
NEWS_DIGEST_WORLD_MAX_ITEMS=10
NEWS_DIGEST_WORLD_THEMATIC_QUERIES=true
NEWS_DIGEST_WORLD_MAX_SEARCH_QUERIES=6
NEWS_DIGEST_WORLD_THEMATIC_MAX=5
NEWS_DIGEST_WORLD_SEARCH_TIMEOUT_SEC=22
NEWS_DIGEST_WORLD_PARALLEL_SEARCH=false
NEWS_DIGEST_GATHER_EARLY_STOP=true
NEWS_DIGEST_NARRATIVE_WORLD_TIMEOUT_SEC=52
NEWS_DIGEST_NARRATIVE_WORLD_BASE_TIMEOUT_SEC=38
NEWS_DIGEST_NARRATIVE_OUTER_MARGIN_SEC=6
NEWS_DIGEST_WORLD_PAGE_ENRICH=true
NEWS_DIGEST_WORLD_PAGE_ENRICH_MAX=2
NEWS_DIGEST_WORLD_PAGE_ENRICH_TIMEOUT_SEC=8
# NEWS_STORY_DEEP_FOLLOWUP_ENABLED — после дайджеста «расскажи про беспилотник в Румынии» → полный разбор (поиск+статья).
NEWS_STORY_DEEP_FOLLOWUP_ENABLED=true

# NEWS_DIGEST_CACHE_ENABLED — не вызывать LLM на каждый «какие новости», если заголовки ленты те же (TTL ниже).
NEWS_DIGEST_CACHE_ENABLED=true
# NEWS_DIGEST_CACHE_TTL_SEC — окно кэша готового дайджеста (сек); по истечении снова RSS + при новых заголовках LLM.
NEWS_DIGEST_CACHE_TTL_SEC=3600
# NEWS_DIGEST_CACHE_MAX_ENTRIES — лимит ключей в памяти процесса (world/by/ru отдельно).
NEWS_DIGEST_CACHE_MAX_ENTRIES=64

# NEWS_ENRICH_ON_DIGEST — веб-поиск при сборе списка (часто «Как» → Викисловарь). Рекомендуется false.
NEWS_ENRICH_ON_DIGEST=false

# NEWS_DIGEST_SHOW_SNIPPETS — показывать абзацы сути под заголовком в списке.
NEWS_DIGEST_SHOW_SNIPPETS=true

# NEWS_ITEM_PICK_ENABLED — пункт дайджеста по номеру («2») без полного brain.
#   По умолчанию true. Выключать только явно NEWS_ITEM_PICK_ENABLED=false.
NEWS_ITEM_PICK_ENABLED=true

# NEWS_ITEM_FETCH_TIMEOUT_SEC — таймаут url_fetch/поиска для пункта (сек).
NEWS_ITEM_FETCH_TIMEOUT_SEC=12

# NEWS_ITEM_REQUIRE_TITLE_ANCHORS — отсечь чужую статью при общих словах («ракетный удар» без города из заголовка).
NEWS_ITEM_REQUIRE_TITLE_ANCHORS=true

# NEWS_ITEM_FETCH_MIN_SCORE — мин. совпадение заголовка пункта и текста страницы (0.20 по умолчанию).
NEWS_ITEM_FETCH_MIN_SCORE=0.20

# NEWS_ITEM_FULL_ARTICLE — полный текст статьи (поиск + url_fetch), не короткий LLM-пересказ.
NEWS_ITEM_FULL_ARTICLE=true

# NEWS_ITEM_FULL_MAX_CHARS — макс. длина текста статьи в Telegram (до 14000).
NEWS_ITEM_FULL_MAX_CHARS=12000

# NEWS_ITEM_MAX_IMAGES — сколько картинок с страницы отправить (og:image + img).
NEWS_ITEM_MAX_IMAGES=3

# NEWS_ITEM_DETAIL_MAX_CHARS — макс. длина текста в ответе на пункт (если NEWS_ITEM_FULL_ARTICLE=false).
NEWS_ITEM_DETAIL_MAX_CHARS=1200

# NEWS_ITEM_RSS_RESOLVE_ENABLED — по заголовку искать ссылку в Google News RSS (false при SEARCH_ONLY).
NEWS_ITEM_RSS_RESOLVE_ENABLED=false

# NEWS_ITEM_RSS_MATCH_MIN_SCORE — порог схожести заголовка с RSS (0–1).
NEWS_ITEM_RSS_MATCH_MIN_SCORE=0.32

# NEWS_ITEM_LLM_FALLBACK_ENABLED — если url_fetch/поиск пусты: 3–4 предложения по заголовку (дешёвая модель).
NEWS_ITEM_LLM_FALLBACK_ENABLED=true
# NEWS_ITEM_LLM_MODEL — пусто = ROUTER_LLM_MODEL.
# NEWS_ITEM_LLM_MAX_TOKENS=220

# NEWS_ENRICH_SEARCH_SNIPPETS — news enrich search snippets.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: NEWS_ENRICH_SEARCH_SNIPPETS=true

NEWS_ENRICH_SEARCH_SNIPPETS=true

# NEWS_ENRICH_PER_ITEM — поиск по каждому заголовку (top N) для stash-сниппетов при «1»/«2».
NEWS_ENRICH_PER_ITEM=true
# NEWS_ENRICH_PER_ITEM_MAX=4
# NEWS_ENRICH_PER_ITEM_TIMEOUT_SEC=10
# NEWS_ENRICH_MIN_MATCH_SCORE=0.15
# NEWS_SEARCH_DDG_FIRST=true — для news_* сначала DuckDuckGo HTML, не SearXNG.
# NEWS_ENRICH_AGGREGATE_FALLBACK=true — сниппет из Wikipedia/DDG aggregate если поиск пуст.
# NEWS_ITEM_BACKFILL_STASH_SNIPPET=true — после ответа на «N» сохранить текст в stash.

# NEWS_DIRECT_MAX_ITEMS — news direct max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_DIRECT_MAX_ITEMS=10

NEWS_DIRECT_MAX_ITEMS=7

# NEWS_RSS_MAX_ITEMS — news rss max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_RSS_MAX_ITEMS=10

NEWS_RSS_MAX_ITEMS=12

# NEWS_BRIEF_SOURCE_MAX_ITEMS — news brief source max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_BRIEF_SOURCE_MAX_ITEMS=10

NEWS_BRIEF_SOURCE_MAX_ITEMS=7

# NEWS_SNIPPET_MAX_CHARS — news snippet max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_SNIPPET_MAX_CHARS=10

NEWS_SNIPPET_MAX_CHARS=520

# NEWS_BRIEF_HINT_MAX_CHARS — news brief hint max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_BRIEF_HINT_MAX_CHARS=10

NEWS_BRIEF_HINT_MAX_CHARS=5500

# NEWS_REPLY_MAX_ITEMS — news reply max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_REPLY_MAX_ITEMS=10

NEWS_REPLY_MAX_ITEMS=7

# NEWS_WORLD_RSS_LANG — news world rss lang.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: NEWS_WORLD_RSS_LANG=<значение>

NEWS_WORLD_RSS_LANG=ru

# NEWS_WORLD_RSS_QUERY — news world rss query.
#   Строковое значение; пусто — дефолт в коде.
