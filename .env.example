#   false / 0 / off / no — выключено.
#   Пример: SELF_IMPROVEMENT_ADVISOR_ENABLED=true

SELF_IMPROVEMENT_ADVISOR_ENABLED=true

# Включает активную самопроверку: если проверка находит проблему,
# ответ заменяется на исправленный вариант или перегенерируется.
# Пока только для deep‑профиля.

SELF_VERIFY_ACTIVE=false

# SELF_VERIFY_MODEL — self verify model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_VERIFY_MODEL=deepseek/deepseek-v4-flash

SELF_VERIFY_MODEL=openai/gpt-4.1-nano

# SELF_VERIFY_TIMEOUT_SEC — self verify timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_VERIFY_TIMEOUT_SEC=10

SELF_VERIFY_TIMEOUT_SEC=35

# HEAVY_MODULES_UNDER_PRESSURE — heavy modules under pressure.
#   Строковое значение; пусто — дефолт в коде.
