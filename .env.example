#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESTART_WATCH_COMMAND=<значение>

RESTART_WATCH_COMMAND=docker compose restart bot

# RESTART_WATCH_INTERVAL_SEC — restart watch interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESTART_WATCH_INTERVAL_SEC=10

RESTART_WATCH_INTERVAL_SEC=5

# =============================================================================
# Qdrant (RAG книг и т.п.)
# =============================================================================

# QDRANT_URL — qdrant url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: QDRANT_URL=http://127.0.0.1:8001

# QDRANT_URL — qdrant url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: QDRANT_URL=http://127.0.0.1:8001

QDRANT_URL=

# QDRANT_API_KEY — qdrant api key.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: QDRANT_API_KEY=<значение из панели провайдера>

QDRANT_API_KEY=

# QDRANT_STARTUP_STRICT — fail-fast при старте, если Qdrant недоступен (default true).
#   false — только warning; runtime classifier деградирует в LRU.
#   Пример: QDRANT_STARTUP_STRICT=true

QDRANT_STARTUP_STRICT=true

# QDRANT_COLLECTION — qdrant collection.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: QDRANT_COLLECTION=<значение>

QDRANT_COLLECTION=gemma_books_rag

# QDRANT_EMBEDDING_MODEL — qdrant embedding model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: QDRANT_EMBEDDING_MODEL=deepseek/deepseek-v4-flash

QDRANT_EMBEDDING_MODEL=openai/text-embedding-3-small

# =============================================================================
# Router classifier (brain профиль: bypass → LRU → LLM → heuristic)
# =============================================================================
# Мастер-включатель: false → работает только эвристика, без LLM в роутере
# ROUTER_ENABLED — router enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ROUTER_ENABLED=true

# ROUTER_ENABLED — router enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ROUTER_ENABLED=true

ROUTER_ENABLED=true

# ROUTER_LLM_MODEL — router llm model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: ROUTER_LLM_MODEL=deepseek/deepseek-v4-flash

ROUTER_LLM_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# ROUTER_LLM_TIMEOUT_SEC — router llm timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: ROUTER_LLM_TIMEOUT_SEC=10

ROUTER_LLM_TIMEOUT_SEC=4.0

# ROUTER_PASSIVE_ENABLED — router passive enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ROUTER_PASSIVE_ENABLED=true

ROUTER_PASSIVE_ENABLED=false

# ROUTER_PASSIVE_MODEL — router passive model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: ROUTER_PASSIVE_MODEL=deepseek/deepseek-v4-flash

ROUTER_PASSIVE_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ROUTER_PASSIVE_TIMEOUT_SEC — router passive timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: ROUTER_PASSIVE_TIMEOUT_SEC=10

ROUTER_PASSIVE_TIMEOUT_SEC=8.0

# MCE_LATENCY_P95_DRIFT_MS — mce latency p95 drift ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MCE_LATENCY_P95_DRIFT_MS=10

MCE_LATENCY_P95_DRIFT_MS=28000

# MCE_LATENCY_DRIFT_EMIT_COOLDOWN_SEC — mce latency drift emit cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MCE_LATENCY_DRIFT_EMIT_COOLDOWN_SEC=10

MCE_LATENCY_DRIFT_EMIT_COOLDOWN_SEC=1800

# MCE_LATENCY_DRIFT_ENV_COOLDOWN_SEC — mce latency drift env cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MCE_LATENCY_DRIFT_ENV_COOLDOWN_SEC=10

MCE_LATENCY_DRIFT_ENV_COOLDOWN_SEC=1800

# ROUTER_CACHE_PATH — router cache path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: ROUTER_CACHE_PATH=data/runtime/example.json

ROUTER_CACHE_PATH=data/router_lru_cache.json

# ROUTER_RAW_LOG — router raw log.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: ROUTER_RAW_LOG=<значение>

ROUTER_RAW_LOG=data/router_passive_raw.jsonl

# ROUTER_RAW_LOG_MAX_LINES — router raw log max lines.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: ROUTER_RAW_LOG_MAX_LINES=10

ROUTER_RAW_LOG_MAX_LINES=100000

# ROUTER_PERMANENT_PATH — router permanent path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: ROUTER_PERMANENT_PATH=data/runtime/example.json

ROUTER_PERMANENT_PATH=data/router_permanent.json

