# Тонкая настройка промпта мозга (core/brain/prompt_pack.py)
# =============================================================================
# Бюджет символов для user-промпта при полной сборке
# BRAIN_USER_PROMPT_BUDGET_CHARS — brain user prompt budget chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS=10

# BRAIN_USER_PROMPT_BUDGET_CHARS — brain user prompt budget chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS=10

BRAIN_USER_PROMPT_BUDGET_CHARS=16000

# BRAIN_USER_PROMPT_BUDGET_CHARS_HOT — brain user prompt budget chars hot.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS_HOT=10

BRAIN_USER_PROMPT_BUDGET_CHARS_HOT=9000

# BRAIN_USER_PROMPT_BUDGET_CHARS_IMAGE — brain user prompt budget chars image.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS_IMAGE=10

BRAIN_USER_PROMPT_BUDGET_CHARS_IMAGE=12000

# BRAIN_USER_PROMPT_BUDGET_CHARS_COMPACT — brain user prompt budget chars compact.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS_COMPACT=10

BRAIN_USER_PROMPT_BUDGET_CHARS_COMPACT=13000

# MESSAGE_ARCHIVE_PROMPT_TAIL — message archive prompt tail.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MESSAGE_ARCHIVE_PROMPT_TAIL=<значение>

MESSAGE_ARCHIVE_PROMPT_TAIL=15

# =============================================================================
# Таймауты и ETA для LLM (core/llm_tiered.py, core/brain/eta_estimate.py)
# =============================================================================
# Порог длины промпта (символов) для пересчёта таймаута LLM
# BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD — brain llm timeout prompt chars threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD=10

# BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD — brain llm timeout prompt chars threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD=10

BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD=7000

# BRAIN_LLM_TIMEOUT_MAX_TOKENS_THRESHOLD — brain llm timeout max tokens threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_TIMEOUT_MAX_TOKENS_THRESHOLD=10

BRAIN_LLM_TIMEOUT_MAX_TOKENS_THRESHOLD=1800

# BRAIN_LLM_FREE_TIMEOUT_SHORT_SEC — brain llm free timeout short sec.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_LLM_FREE_TIMEOUT_SHORT_SEC=true

BRAIN_LLM_FREE_TIMEOUT_SHORT_SEC=0

# BRAIN_LLM_ETA_OVERHEAD_SEC — brain llm eta overhead sec.
#   Фикс. задержка (сеть, TTFT) поверх prompt+gen; аудит p50 brain ~3.4 с.
#   Пример: BRAIN_LLM_ETA_OVERHEAD_SEC=10

BRAIN_LLM_ETA_OVERHEAD_SEC=1.8

# =============================================================================
# Self-Learning Engine (core/self_learning/): closed-loop self-improvement from errors
# =============================================================================
# Enable the self-learning system. If 'false', no lessons are generated or injected.
# SELF_LEARNING_ENABLED — self learning enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_LEARNING_ENABLED=true

# SELF_LEARNING_ENABLED — self learning enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_LEARNING_ENABLED=true

SELF_LEARNING_ENABLED=true

# SELF_LEARNING_MAX_INJECTED_LESSONS — self learning max injected lessons.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_LEARNING_MAX_INJECTED_LESSONS=10

SELF_LEARNING_MAX_INJECTED_LESSONS=3

# SELF_LEARNING_RETENTION_HALF_LIFE_SEC — self learning retention half life sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_LEARNING_RETENTION_HALF_LIFE_SEC=10

SELF_LEARNING_RETENTION_HALF_LIFE_SEC=604800

# SELF_LEARNING_FORGET_THRESHOLD — self learning forget threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_LEARNING_FORGET_THRESHOLD=10

SELF_LEARNING_FORGET_THRESHOLD=0.1

# SELF_LEARNING_RETIRE_SCORE — self learning retire score.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_LEARNING_RETIRE_SCORE=<значение>

SELF_LEARNING_RETIRE_SCORE=0.2

# SELF_LEARNING_CON_SOLIDATE_SCORE — self learning con solidate score.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_LEARNING_CON_SOLIDATE_SCORE=<значение>

SELF_LEARNING_CON_SOLIDATE_SCORE=0.9

# SELF_LEARNING_REFLECTION_MODEL — self learning reflection model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_LEARNING_REFLECTION_MODEL=deepseek/deepseek-v4-flash

SELF_LEARNING_REFLECTION_MODEL=meta-llama/llama-3.1-8b-instruct

# =============================================================================
# Code Evolution (Фаза 9) — Self-Code Evolution
# =============================================================================
# Master switch
# CODE_EVOL_ENABLED — code evol enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CODE_EVOL_ENABLED=true

# CODE_EVOL_ENABLED — code evol enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CODE_EVOL_ENABLED=true

CODE_EVOL_ENABLED=true

# CODE_EVOL_ALLOWED_DIRS — code evol allowed dirs.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_ALLOWED_DIRS=<значение>

CODE_EVOL_ALLOWED_DIRS=core

# CODE_EVOL_PATCHES_MAX — code evol patches max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_PATCHES_MAX=<значение>

CODE_EVOL_PATCHES_MAX=50

# CODE_EVOL_GIT_USER — code evol git user.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_GIT_USER=<значение>

CODE_EVOL_GIT_USER=gemma-bot

# CODE_EVOL_GIT_EMAIL — code evol git email.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_GIT_EMAIL=<значение>

CODE_EVOL_GIT_EMAIL=bot@localhost

# CODE_EVOL_DEPLOY_SSH — code evol deploy ssh.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_DEPLOY_SSH=<значение>

# CODE_EVOL_DEPLOY_SSH=

# CODE_EVOL_DEPLOY_CMD — code evol deploy cmd.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_DEPLOY_CMD=<значение>

CODE_EVOL_DEPLOY_CMD=bash /opt/gemma_agent/scripts/gemma_panel.sh update

# CODE_EVOL_OPTIMIZER_INTERVAL — code evol optimizer interval.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CODE_EVOL_OPTIMIZER_INTERVAL=10

CODE_EVOL_OPTIMIZER_INTERVAL=720

# =============================================================================
# Доп. ключи (используются в коде, ранее только в catalog/ops)
# =============================================================================

# GEMMA_PROJECT_ROOT — корень репозитория (на сервере /opt/gemma_agent).
# GEMMA_PROJECT_ROOT=/opt/gemma_agent

# BRAIN_INCOMPLETE_CONTINUE — догенерация оборванного ответа (finish_reason=length).
BRAIN_INCOMPLETE_CONTINUE_ENABLED=true
BRAIN_INCOMPLETE_CONTINUE_MIN_USER_CHARS=120

# EXEC_MODULES_TIMEOUT_SEC / EXECUTION_TIMEOUT_SEC — таймаут модулей и execute_plan.
# EXEC_MODULES_TIMEOUT_SEC=90
# EXECUTION_TIMEOUT_SEC=120

