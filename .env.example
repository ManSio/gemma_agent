SELF_MODEL_AUTONOMY_EXTENDED_ENABLED=false

#
# Связка с recall: только при STYLE+EXTENDED в context.self_model.dynamic появляются clarify_rate / context_stability.
# Чтобы по ним подмешивать «тонкий» пакет архива/digest в мозг — отдельно включите MEMORY_RECALL_SELF_MODEL_BOOST_ENABLED
# (см. блок MemoryRecallFacade ниже; без этого флага extended сам recall не усиливает).
