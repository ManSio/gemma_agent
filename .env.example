SPATIAL_INTERPRET_ENABLED=true

# SPATIAL_INTERPRET_SKIP_WHEN_READY — не вызывать interpret LLM, если прямоугольник L×W уже готов.
#   Экономит 1 vision-вызов на гардеробную/комнату с размерами. Коридор (segments) — interpret остаётся.
#   Пример: SPATIAL_INTERPRET_SKIP_WHEN_READY=true
SPATIAL_INTERPRET_SKIP_WHEN_READY=true

