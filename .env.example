#   Пример: REFLECTION_HEAVY_ENABLED=true

REFLECTION_HEAVY_ENABLED=true

# REFLECTION_HEAVY_MIN_USER_CHARS — reflection heavy min user chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
