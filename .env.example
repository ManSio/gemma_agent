# --- Self-deployment: авто деплой сгенерированных модулей (генерация → тест → git → редеплой) ---
# Включает: pytest → git add/commit/push → SSH remote pull + restart

SELF_DEPLOY_ENABLED=false

# SELF_DEPLOY_BRANCH — self deploy branch.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_BRANCH=<значение>

SELF_DEPLOY_BRANCH=main

# SELF_DEPLOY_GIT_USER_NAME — self deploy git user name.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_GIT_USER_NAME=<значение>

SELF_DEPLOY_GIT_USER_NAME=GemmaAgent

# SELF_DEPLOY_GIT_USER_EMAIL — self deploy git user email.
