SPATIAL_AREA_TOLERANCE_PCT=5

# SPATIAL_MIN_ELEMENT_CONFIDENCE — порог confidence для элементов «Вижу на плане» (0–1).
#   Ниже порога → «Не уверен», не как факт. Пример: SPATIAL_MIN_ELEMENT_CONFIDENCE=0.45

SPATIAL_MIN_ELEMENT_CONFIDENCE=0.45

# SPATIAL_INTERPRET_ENABLED — осмысление плана (шахты, ниши, стена под шкаф) после perceive.
