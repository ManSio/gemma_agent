#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_LAT_MIN_SEC=10

BRAIN_LLM_ETA_LEARN_LAT_MIN_SEC=0.35

# BRAIN_LLM_ETA_LEARN_LAT_MAX_SEC — brain llm eta learn lat max sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_LAT_MAX_SEC=10

BRAIN_LLM_ETA_LEARN_LAT_MAX_SEC=720

# BRAIN_LLM_ETA_LEARN_MAX_MULT — brain llm eta learn max mult.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_MAX_MULT=10

BRAIN_LLM_ETA_LEARN_MAX_MULT=2.75

# OPENROUTER_HTTP_REFERER — openrouter http referer.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_HTTP_REFERER=<значение>

OPENROUTER_HTTP_REFERER=https://github.com/ManSio/gemma_agent

# OPENAI_API_KEY — openai api key.
#   Строковое значение; пусто — дефолт в коде.
