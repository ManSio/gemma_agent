RUNTIME_DIAG_TOOL_MAX_JSON_CHARS=180000

# =============================================================================
# Память успешных ответов («опыт»; без slash-команд)
# =============================================================================
# Что делает: после УСПЕШНОГО ответа пишет строку в JSONL; при следующем похожем запросе,
#   если роутинг «неуверенный», подмешивает в промпт краткие прошлые ответы (тот же текст + intent + модуль).
# Условия подмешивания (любое из):
#   • причина планировщика начинается с chat_orchestrator_fallback (нет модуля под intent → ушли в чат);
#   • predictive_hint.confidence ниже порога (слабый доменный сигнал: не «код/финансы», короткий чат и т.п.).
# false — не писать файл и не подмешивать.
# EXPERIENCE_MEMORY_ENABLED — experience memory enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: EXPERIENCE_MEMORY_ENABLED=true

# EXPERIENCE_MEMORY_ENABLED — experience memory enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: EXPERIENCE_MEMORY_ENABLED=true

EXPERIENCE_MEMORY_ENABLED=true

# Ниже этого числа confidence — считаем запрос «размытым» и пробуем подмешать опыт (если записи есть).
# Выше порога (например 0.5–0.95 при явных ключевых словах кода/финансов) — опыт в промпт не идёт.

EXPERIENCE_HINT_CONF_THRESHOLD=0.22

# GEMMA_EXPERIENCE_PATH — gemma experience path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_EXPERIENCE_PATH=data/runtime/example.json

GEMMA_EXPERIENCE_PATH=data/runtime/experience_digest.jsonl

# EXPERIENCE_MAX_LINES — experience max lines.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: EXPERIENCE_MAX_LINES=10

EXPERIENCE_MAX_LINES=4000

# EXPERIENCE_MAX_FILE_BYTES — experience max file bytes.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: EXPERIENCE_MAX_FILE_BYTES=10

EXPERIENCE_MAX_FILE_BYTES=2097152

# EXPERIENCE_NEGATIVE_RECORDING_ENABLED — experience negative recording enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: EXPERIENCE_NEGATIVE_RECORDING_ENABLED=true

EXPERIENCE_NEGATIVE_RECORDING_ENABLED=true

# EXPERIENCE_NEGATIVE_HINT_ENABLED — experience negative hint enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: EXPERIENCE_NEGATIVE_HINT_ENABLED=true

EXPERIENCE_NEGATIVE_HINT_ENABLED=true

# EXPERIENCE_HINT_IN_PROMPT — подсказка из experience_memory_hint в external_hint brain (slim off).
#   false — только запись опыта, без текста в промпте.

EXPERIENCE_HINT_IN_PROMPT=true

# EXPERIENCE_NEGATIVE_HINT_LIMIT — experience negative hint limit.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: EXPERIENCE_NEGATIVE_HINT_LIMIT=10

EXPERIENCE_NEGATIVE_HINT_LIMIT=2

# EXPERIENCE_NEGATIVE_HINT_UNCERTAIN_ONLY — experience negative hint uncertain only.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: EXPERIENCE_NEGATIVE_HINT_UNCERTAIN_ONLY=true

EXPERIENCE_NEGATIVE_HINT_UNCERTAIN_ONLY=false

# TURN_OUTCOME_CLARIFY_HEURISTIC — turn outcome clarify heuristic.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_OUTCOME_CLARIFY_HEURISTIC=true

TURN_OUTCOME_CLARIFY_HEURISTIC=true

# =============================================================================
# План на несколько шагов (lookahead, без второго LLM)
# =============================================================================
# После решения планировщика строится лёгкий план: следующие шаги, проверки после ответа,
#   вероятные продолжения пользователя. Попадает в goal_plan.lookahead и thinking_markers.
# Отдельного вызова LLM нет — только эвристики (плагин, math, код, погода/курс, fallback-чат, иначе общий).
# LOOKAHEAD_PLANNER_ENABLED — lookahead planner enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: LOOKAHEAD_PLANNER_ENABLED=true

# LOOKAHEAD_PLANNER_ENABLED — lookahead planner enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: LOOKAHEAD_PLANNER_ENABLED=true

LOOKAHEAD_PLANNER_ENABLED=true

# LOOKAHEAD_MAX_STEPS — lookahead max steps.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LOOKAHEAD_MAX_STEPS=10

LOOKAHEAD_MAX_STEPS=5

# LOOKAHEAD_HORIZON — lookahead horizon.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LOOKAHEAD_HORIZON=<значение>

LOOKAHEAD_HORIZON=3

# MULTI_STEP_RUNNER_MAX_STEPS — multi step runner max steps.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MULTI_STEP_RUNNER_MAX_STEPS=10

MULTI_STEP_RUNNER_MAX_STEPS=24

# Многоракурсное рассуждение (эмпатия, гипотезы, проверки, ресурсы, стратегия) — компактный блок в external_hint
# только для nested/deep или длинных текстов с маркерами сценария/дилеммы. Обычный чат не раздувает.
# Булевы флаги ниже (и ряд дугих) можно переключать из Telegram: /admin → «⚙️ Настройки»
# — сохраняется data/runtime/admin_telegram_settings.json и имеет приоритет над .env для этих ключей.

STRATEGIC_LENSES_HINT_ENABLED=true

# =============================================================================
# Глубина задачи, память стратегий (путь шагов), микро-план LLM, цепочка инструментов
# =============================================================================
# task_tier: shallow | nested | deep — эвристика по текущему тексту и последним репликам пользователя; в goal_plan и dialogue_state.
# STRATEGY_LLM_OUTLINE_* — JSON outline с опциональным scenarios[] (сценарные ветки); поднимает tier при multi/thorough.
# Успешный ход с непустым lookahead.steps → строка в strategy_paths.jsonl (сводка шагов).
# Подсказка в промпт для nested/deep; для shallow тоже — только если:
# STRATEGY_PATH_HINT_FOR_SHALLOW — strategy path hint for shallow.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: STRATEGY_PATH_HINT_FOR_SHALLOW=true

