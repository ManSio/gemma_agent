# =============================================================================
# Автономика: дайджест сессии, «усталость», риск маршрута, probe после hot-install
# =============================================================================

# --- Дайджест сессии (краткая сводка ходов в JSONL, аналог «консолидации») ---
# Когда пишется: накопились ходы одного user_id и выполнено ЛИБО ≥ SESSION_DIGEST_EVERY_N_TURNS,
#   ЛИБО суммарный размер буфера ≥ SESSION_DIGEST_BUFFER_CHARS.
# В строке: счётчики ok/fallback/clarify/error/failure и до 8 коротких образцов (user_excerpt).
# false — не вести журнал.
# SESSION_DIGEST_ENABLED — session digest enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SESSION_DIGEST_ENABLED=true

# SESSION_DIGEST_ENABLED — session digest enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SESSION_DIGEST_ENABLED=true

SESSION_DIGEST_ENABLED=true

# SESSION_DIGEST_EVERY_N_TURNS — session digest every n turns.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SESSION_DIGEST_EVERY_N_TURNS=<значение>

SESSION_DIGEST_EVERY_N_TURNS=12

# SESSION_DIGEST_BUFFER_CHARS — session digest buffer chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SESSION_DIGEST_BUFFER_CHARS=10

SESSION_DIGEST_BUFFER_CHARS=6000

# SESSION_DIGEST_MIN_USER_CHARS — session digest min user chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SESSION_DIGEST_MIN_USER_CHARS=10

SESSION_DIGEST_MIN_USER_CHARS=2

# GEMMA_SESSION_DIGEST_PATH — gemma session digest path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_SESSION_DIGEST_PATH=data/runtime/example.json

GEMMA_SESSION_DIGEST_PATH=data/runtime/session_digest.jsonl

# --- «Усталость» по латентности (ужать промпт и ответ) ---
# Когда включается: p95 за последние измерения в OBS для ключа telegram_pipeline ≥ FATIGUE_P95_TELEGRAM_MS
#   ИЛИ p95 для openrouter_completion_ms ≥ FATIGUE_P95_OPENROUTER_MS.
# Эффект: verbosity → concise, принудительно slim-сборка промпта мозга (меньше контекста).
# false — не реагировать на задержки.

AUTONOMIC_FATIGUE_ENABLED=true

# FATIGUE_P95_TELEGRAM_MS — fatigue p95 telegram ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: FATIGUE_P95_TELEGRAM_MS=10

FATIGUE_P95_TELEGRAM_MS=14000

# FATIGUE_P95_OPENROUTER_MS — fatigue p95 openrouter ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: FATIGUE_P95_OPENROUTER_MS=10

FATIGUE_P95_OPENROUTER_MS=55000

# --- Cost-aware autopilot (дневной бюджет токенов без ручного свитча) ---
# Режимы: normal / saving / hard_saving по доле от дневного бюджета.
# Эффекты:
#   • saving: concise + меньше стратегических подсказок на коротких general-запросах;
#   • hard_saving: сильнее ужатие, отключение части hints и инструментов для короткого чата.

COST_AUTOPILOT_ENABLED=true

# COST_DAILY_TOKEN_BUDGET — cost daily token budget.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: COST_DAILY_TOKEN_BUDGET=<значение>

COST_DAILY_TOKEN_BUDGET=300000

# COST_DAILY_USD_BUDGET — hard daily LLM spend cap in USD (blocks OpenRouter when exceeded).
#   Пример: COST_DAILY_USD_BUDGET=10

COST_DAILY_USD_BUDGET=10

# COST_DAILY_USD_HARD_STOP — block LLM calls when daily USD budget exceeded.
#   true / false

COST_DAILY_USD_HARD_STOP=true

# OPENROUTER_MAX_CONCURRENT_CALLS — global parallel OpenRouter HTTP cap.
#   Пример: OPENROUTER_MAX_CONCURRENT_CALLS=10

OPENROUTER_MAX_CONCURRENT_CALLS=10

# CIRCUIT_BREAKER_FAILURE_THRESHOLD — OpenRouter failures before circuit opens.
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_WINDOW_SEC — failure counting window.
CIRCUIT_BREAKER_WINDOW_SEC=60
# CIRCUIT_BREAKER_OPEN_SEC — cooldown while circuit is open.
CIRCUIT_BREAKER_OPEN_SEC=300

# POLICY_CALL_HISTORY_RETENTION_MIN — PolicyEngine call_history retention minutes.
POLICY_CALL_HISTORY_RETENTION_MIN=10

# COST_SAVING_THRESHOLD — cost saving threshold.
