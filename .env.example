# =============================================================================
# Пример .env — скопируйте в .env и заполните секреты вверху.
#   cp .env.example .env
# Развёрнутые комментарии (true/false, примеры): config/env_catalog/*.env.fragment
# Полная синхронизация в рабочий .env: python scripts/sync_env_from_example.py
# Только флаги из каталога: python scripts/apply_env_catalog.py
# Реальные id/ключи: docs/OPS_PRIVATE.local.md (не в git). docs/OPERATIONS_AND_ADMIN.md
# =============================================================================
#
# PROFILES (defaults below = chat-first for 3–8 users):
#   power_agent — fuller Plan→Execute→Verify (Goal Runner, self-verify, quality loop)
#     Fragment: config/power_agent.env.fragment
#     Apply:    python scripts/apply_power_agent_env.py
#     Docs:     docs/AGENT_LOOP.md
#   personal_prod — stable family mode (disables noisy autonomy)
#     Apply:    python scripts/apply_personal_prod_env.py
# =============================================================================

# --- Telegram: токен бота от @BotFather (без него бот не запустится)
# TELEGRAM_TOKEN — токен бота от @BotFather.
#   Пусто — бот не стартует. Утечка → /revoke в BotFather и новый токен.
#   Пример: TELEGRAM_TOKEN=123456:ABC-DEF...

TELEGRAM_TOKEN=

# TELEGRAM_BOT_MENU_OFF — telegram bot menu off.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TELEGRAM_BOT_MENU_OFF=true

TELEGRAM_BOT_MENU_OFF=1

# --- Telegram Webhook (вкл. вместо polling; требует публичный HTTPS URL)
#     Если задан WEBHOOK_URL — бот слушает webhook, иначе fallback на polling.
#     Placeholder your.domain.com игнорируется (polling) — см. core/telegram_webhook_config.py

WEBHOOK_URL=

# WEBHOOK_PATH — webhook path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: WEBHOOK_PATH=data/runtime/example.json

WEBHOOK_PATH=/webhook

# WEBHOOK_HOST — webhook host.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: WEBHOOK_HOST=<значение>

WEBHOOK_HOST=0.0.0.0

# WEBHOOK_PORT — webhook port.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: WEBHOOK_PORT=10

WEBHOOK_PORT=8443

# WEBHOOK_SECRET — webhook secret.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: WEBHOOK_SECRET=10

# WEBHOOK_SECRET=

# WEBHOOK_MAX_CONNECTIONS — webhook max connections.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: WEBHOOK_MAX_CONNECTIONS=10

WEBHOOK_MAX_CONNECTIONS=40

# ADMIN_USER_IDS — admin user ids (через запятую; тест VPNTEST — второй id в OPS_PRIVATE / серверном .env).
#   Строковое значение; пусто — дефолт в коде.
#   Пример: ADMIN_USER_IDS=123456789

ADMIN_USER_IDS=123456789

# ADMIN_STARTUP_NOTIFY — admin startup notify.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ADMIN_STARTUP_NOTIFY=true

ADMIN_STARTUP_NOTIFY=true

# ADMIN_NOTIFY_USER_IDS — admin notify user ids.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: ADMIN_NOTIFY_USER_IDS=<значение>

ADMIN_NOTIFY_USER_IDS=123456789

# ADMIN_QUOTA_DM_ENABLED — ЛС админу при исчерпании баланса/лимита OpenRouter (403/402 и т.п.).
#   true — включено (дефолт).
#   Пример: ADMIN_QUOTA_DM_ENABLED=true

ADMIN_QUOTA_DM_ENABLED=true

# ADMIN_QUOTA_DM_COOLDOWN_SEC — не слать повтор той же quota-ошибки чаще (сек).
#   Пример: ADMIN_QUOTA_DM_COOLDOWN_SEC=3600

ADMIN_QUOTA_DM_COOLDOWN_SEC=3600

# ADMIN_QUOTA_DM_RATE_LIMIT_COOLDOWN_SEC — cooldown для 429 rate limit.
#   Пример: ADMIN_QUOTA_DM_RATE_LIMIT_COOLDOWN_SEC=900

ADMIN_QUOTA_DM_RATE_LIMIT_COOLDOWN_SEC=900

# USER_ACCESS_APPROVAL_REQUIRED — user access approval required.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: USER_ACCESS_APPROVAL_REQUIRED=true

USER_ACCESS_APPROVAL_REQUIRED=true

# USER_ACCESS_PENDING_MESSAGE — user access pending message.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: USER_ACCESS_PENDING_MESSAGE=<значение>

USER_ACCESS_PENDING_MESSAGE='⏳ Заявка отправлена администратору. Ожидайте подтверждения.'

# USER_ACCESS_BLOCKED_MESSAGE — user access blocked message.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: USER_ACCESS_BLOCKED_MESSAGE=<значение>

USER_ACCESS_BLOCKED_MESSAGE='⛔ Доступ к боту для этого аккаунта закрыт.'

# USER_ACCESS_GUEST_REPLY_QUOTA — user access guest reply quota.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: USER_ACCESS_GUEST_REPLY_QUOTA=<значение>

USER_ACCESS_GUEST_REPLY_QUOTA=10

# USER_ACCESS_GUEST_QUOTA_EXHAUSTED_MESSAGE — user access guest quota exhausted message.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: USER_ACCESS_GUEST_QUOTA_EXHAUSTED_MESSAGE=<значение>

USER_ACCESS_GUEST_QUOTA_EXHAUSTED_MESSAGE='⏳ Лимит пробных ответов исчерпан. Дождитесь подтверждения администратора.'

# =============================================================================
# Автопилот и дайджесты
# =============================================================================

# --- Режим автопилота ядра: on/off (см. core/autopilot_mode.py).
#     При on подставляются только пустые переменные: логи/сеть/тики + адаптация мозга
#     (STRATEGY_LLM_OUTLINE_*, BRAIN_TOOL_CHAIN_MAX, BRAIN_TOOL_ROUTING_HINT, LOOKAHEAD_*).
#     Явные строки в .env всегда важнее — тонкую настройку не нужно отключать «вручную» пакетом.
# GEMMA_AUTOPILOT_MODE — пакет дефолтов автопилота (on/off).
#   on — подставляет пустые ключи из autopilot_mode.py (логи, tool chain…).
#   off — только то, что явно задано в .env.

# GEMMA_AUTOPILOT_MODE — пакет дефолтов автопилота (on/off).
#   on — подставляет пустые ключи из autopilot_mode.py (логи, tool chain…).
#   off — только то, что явно задано в .env.

GEMMA_AUTOPILOT_MODE=on

# DIALOGUE_FEEDBACK_SIGNALS_ENABLED — dialogue feedback signals enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOGUE_FEEDBACK_SIGNALS_ENABLED=true

DIALOGUE_FEEDBACK_SIGNALS_ENABLED=true

# FEEDBACK_BUTTON_DEBOUNCE_SEC — не применять 👍/👎 дважды за N сек (двойной тап Telegram).
#   Пример: FEEDBACK_BUTTON_DEBOUNCE_SEC=2

FEEDBACK_BUTTON_DEBOUNCE_SEC=2

# AUTOPILOT_CYCLE_INTERVAL_SEC — autopilot cycle interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_CYCLE_INTERVAL_SEC=10

AUTOPILOT_CYCLE_INTERVAL_SEC=900

# AUTOPILOT_INNER_TICK_SEC — autopilot inner tick sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_INNER_TICK_SEC=10

AUTOPILOT_INNER_TICK_SEC=60

# AUTOPILOT_REPORT_TO_ADMINS — autopilot report to admins.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_REPORT_TO_ADMINS=true

AUTOPILOT_REPORT_TO_ADMINS=true

# AUTOPILOT_LLM_TRIAGE_ENABLED — autopilot llm triage enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_TRIAGE_ENABLED=true

AUTOPILOT_LLM_TRIAGE_ENABLED=false

# AUTOPILOT_LLM_TRIAGE_MIN_ANOMALIES — autopilot llm triage min anomalies.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_TRIAGE_MIN_ANOMALIES=true

AUTOPILOT_LLM_TRIAGE_MIN_ANOMALIES=1

# AUTOPILOT_LLM_TRIAGE_COOLDOWN_SEC — autopilot llm triage cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_TRIAGE_COOLDOWN_SEC=10

AUTOPILOT_LLM_TRIAGE_COOLDOWN_SEC=3600

# AUTOPILOT_LLM_TRIAGE_MAX_PAYLOAD_CHARS — autopilot llm triage max payload chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_TRIAGE_MAX_PAYLOAD_CHARS=10

AUTOPILOT_LLM_TRIAGE_MAX_PAYLOAD_CHARS=12000

# AUTOPILOT_LLM_TRIAGE_MAX_REPLY_CHARS — autopilot llm triage max reply chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_TRIAGE_MAX_REPLY_CHARS=10

AUTOPILOT_LLM_TRIAGE_MAX_REPLY_CHARS=3500

# AUTOPILOT_LLM_TRIAGE_REQUIRE_DM_REPORT — autopilot llm triage require dm report.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_TRIAGE_REQUIRE_DM_REPORT=true

AUTOPILOT_LLM_TRIAGE_REQUIRE_DM_REPORT=false

# AUTOPILOT_ACTIONS_ENABLED — autopilot actions enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_ACTIONS_ENABLED=true

AUTOPILOT_ACTIONS_ENABLED=true

# AUTOPILOT_DIGEST_HOURS_UTC — autopilot digest hours utc.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_DIGEST_HOURS_UTC=10

AUTOPILOT_DIGEST_HOURS_UTC=8,20

# AUTOPILOT_DIGEST_QUIET_ONLY — autopilot digest quiet only.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_DIGEST_QUIET_ONLY=true

AUTOPILOT_DIGEST_QUIET_ONLY=false

# AUTOPILOT_IDLE_MIN_SEC — autopilot idle min sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_IDLE_MIN_SEC=10

AUTOPILOT_IDLE_MIN_SEC=900

# AUTOPILOT_IDLE_LLM_PROBE — autopilot idle llm probe.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_IDLE_LLM_PROBE=true

AUTOPILOT_IDLE_LLM_PROBE=true

# AUTOPILOT_IDLE_LLM_PROBE_MODEL — autopilot idle llm probe model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: AUTOPILOT_IDLE_LLM_PROBE_MODEL=deepseek/deepseek-v4-flash

AUTOPILOT_IDLE_LLM_PROBE_MODEL=openrouter/free

# AUTOPILOT_QUIET_HOURS_UTC — autopilot quiet hours utc.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_QUIET_HOURS_UTC=10

AUTOPILOT_QUIET_HOURS_UTC=0,1,2,3,4,5,22,23

# AUTOPILOT_LLM_PROBE_MIN_INTERVAL_SEC — autopilot llm probe min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_PROBE_MIN_INTERVAL_SEC=10

AUTOPILOT_LLM_PROBE_MIN_INTERVAL_SEC=7200

# AUTOPILOT_LLM_PROBE_NOTIFY_ON_FAIL — autopilot llm probe notify on fail.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_PROBE_NOTIFY_ON_FAIL=true

AUTOPILOT_LLM_PROBE_NOTIFY_ON_FAIL=true

# USAGE_LEARNING_SAVE_EVERY — usage learning save every.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: USAGE_LEARNING_SAVE_EVERY=<значение>

USAGE_LEARNING_SAVE_EVERY=25

# USAGE_LEARNING_STATE_PATH — usage learning state path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USAGE_LEARNING_STATE_PATH=data/runtime/example.json

USAGE_LEARNING_STATE_PATH=./data/runtime/usage_learning_state.json

# USAGE_LEARNING_DIGEST_PATH — usage learning digest path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USAGE_LEARNING_DIGEST_PATH=data/runtime/example.json

USAGE_LEARNING_DIGEST_PATH=./data/runtime/usage_learning_digest_checkpoint.json

# =============================================================================
# Логи и телеметрия
# =============================================================================

# --- Уровень логирования Python (DEBUG, INFO, …)
# LOG_LEVEL — log level.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LOG_LEVEL=<значение>

# LOG_LEVEL — log level.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LOG_LEVEL=<значение>

LOG_LEVEL=INFO

# LOG_FORMAT — log format.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LOG_FORMAT=<значение>

LOG_FORMAT=json

# GEMMA_REPORT_TIMEZONE — gemma report timezone.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_REPORT_TIMEZONE=<значение>

GEMMA_REPORT_TIMEZONE=Europe/Minsk

# GEMMA_INSTANCE_ATTRIBUTION_ENABLED — gemma instance attribution enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_INSTANCE_ATTRIBUTION_ENABLED=true

GEMMA_INSTANCE_ATTRIBUTION_ENABLED=false

# GEMMA_INSTANCE_AUTHOR — gemma instance author.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_INSTANCE_AUTHOR=<значение>

GEMMA_INSTANCE_AUTHOR=GemmaProject

# GEMMA_INSTANCE_CREDIT_LINE — gemma instance credit line.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_INSTANCE_CREDIT_LINE=<значение>

GEMMA_INSTANCE_CREDIT_LINE='Этот бот настроил …'

# GEMMA_CORE_LOG_FULL — gemma core log full.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_CORE_LOG_FULL=true

GEMMA_CORE_LOG_FULL=true

# GEMMA_LLM_AUDIT_LOG — gemma llm audit log.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_LLM_AUDIT_LOG=true

GEMMA_LLM_AUDIT_LOG=true

# GEMMA_LOG_ROTATE_HOURS — gemma log rotate hours.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GEMMA_LOG_ROTATE_HOURS=10

GEMMA_LOG_ROTATE_HOURS=6

# GEMMA_LOG_FILE_MAX_MB — gemma log file max mb.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GEMMA_LOG_FILE_MAX_MB=10

GEMMA_LOG_FILE_MAX_MB=32

# GEMMA_LOG_FILE_BACKUPS — gemma log file backups.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_LOG_FILE_BACKUPS=<значение>

GEMMA_LOG_FILE_BACKUPS=20

# GEMMA_LOG_COMPACT — gemma log compact.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_LOG_COMPACT=true

GEMMA_LOG_COMPACT=true

# GEMMA_CRITICAL_LOG_ENABLED — gemma critical log enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_CRITICAL_LOG_ENABLED=true

GEMMA_CRITICAL_LOG_ENABLED=true

# GEMMA_CRITICAL_LOG_FILE — gemma critical log file.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_CRITICAL_LOG_FILE=<значение>

GEMMA_CRITICAL_LOG_FILE=./data/logs/gemma_critical.log

# GEMMA_CRITICAL_CONTEXT_BUFFER_LINES — gemma critical context buffer lines.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_CRITICAL_CONTEXT_BUFFER_LINES=<значение>

GEMMA_CRITICAL_CONTEXT_BUFFER_LINES=140

# GEMMA_CRITICAL_CONTEXT_TAIL_LINES — gemma critical context tail lines.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_CRITICAL_CONTEXT_TAIL_LINES=<значение>

GEMMA_CRITICAL_CONTEXT_TAIL_LINES=30

# LATENCY_TRACE_LOG — latency trace log.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LATENCY_TRACE_LOG=<значение>

LATENCY_TRACE_LOG=all

# LATENCY_TRACE_SLOW_MS — latency trace slow ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LATENCY_TRACE_SLOW_MS=10

LATENCY_TRACE_SLOW_MS=1800

# LIVE_PULSE_PLANNER_TAIL — live pulse planner tail.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LIVE_PULSE_PLANNER_TAIL=<значение>

LIVE_PULSE_PLANNER_TAIL=48

# LIVE_PULSE_TELEGRAM_P95_WARN_MS — порог warn для p95 pipeline (мс). При GEMMA_AUTOPILOT_MODE=on
#   autopilot подставляет 60000 warn и 90000 critical, если не задано явно.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LIVE_PULSE_TELEGRAM_P95_WARN_MS=10

# Полный ход — не 8 с. Код defaults: warn 18000 / critical 90000 / openrouter 12000 (мс).
LIVE_PULSE_TELEGRAM_P95_WARN_MS=18000

# LIVE_PULSE_TELEGRAM_P95_CRITICAL_MS — live pulse telegram p95 critical ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LIVE_PULSE_TELEGRAM_P95_CRITICAL_MS=90000

LIVE_PULSE_TELEGRAM_P95_CRITICAL_MS=90000

# LIVE_PULSE_OPENROUTER_P95_CRITICAL_MS — live pulse openrouter p95 critical ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LIVE_PULSE_OPENROUTER_P95_CRITICAL_MS=12000

LIVE_PULSE_OPENROUTER_P95_CRITICAL_MS=12000

