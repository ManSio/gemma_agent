# OPENAI_API_KEY=

# =============================================================================
# Mem0 (HTTP API v3: облако или локальный mem0_server, опционально)
# =============================================================================

# --- Базовый URL API Mem0 (без /api/v1 — пути добиваются в коде)
# MEM0_API_URL — локальный mem0_server (127.0.0.1:8001) или облако https://api.mem0.ai
#   Пример: MEM0_API_URL=http://127.0.0.1:8001

MEM0_API_URL=http://127.0.0.1:8001

# MEM0_API_KEY — mem0 api key (облако; для local — MEM0_LOCAL_API_KEY).
#   Секрет — не коммитить.
#   Пример: MEM0_API_KEY=<значение>

MEM0_API_KEY=

# MEM0_LOCAL — true + URL 127.0.0.1:8001 — локальный mem0_server.

MEM0_LOCAL=true

# MEM0_LOCAL_API_KEY — mem0 local api key.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_LOCAL_API_KEY=<значение>

MEM0_LOCAL_API_KEY=local

# Синоним флага: MEM0_SELF_HOSTED=true
# Локальный сервер с эмбеддингами (rewrite выкл по умолчанию): scripts/mem0_local_server.py

MEM0_LLM_REWRITE=false

# MEM0_LLM_COMPRESS — mem0 llm compress.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MEM0_LLM_COMPRESS=true

MEM0_LLM_COMPRESS=false

# MEM0_OPENROUTER_PROVIDER_ORDER — mem0 openrouter provider order.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_OPENROUTER_PROVIDER_ORDER=<значение>

MEM0_OPENROUTER_PROVIDER_ORDER=DeepSeek,baidu

# MEM0_OPENROUTER_PROVIDER_IGNORE — mem0 openrouter provider ignore.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_OPENROUTER_PROVIDER_IGNORE=<значение>

MEM0_OPENROUTER_PROVIDER_IGNORE=deepinfra

#
# --- Префикс путей к memories (по умолчанию v3 → /v3/memories/... как у Mem0 Platform).
# Если локальный сервер отдаёт 404 на /v3/..., откройте его /docs и выставьте префикс под ваши маршруты;
# пустое значение MEM0_API_PREFIX= — запросы пойдут в /memories/... от корня MEM0_API_URL.

MEM0_API_PREFIX=v3

# MEM0_MIRROR_API_KEY — mem0 mirror api key.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_MIRROR_API_KEY=<значение>

# MEM0_MIRROR_API_KEY=

# MEM0_MIRROR_WRITE — mem0 mirror write.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MEM0_MIRROR_WRITE=true

MEM0_MIRROR_WRITE=true

# =============================================================================
# HTTP API (api.py)
# =============================================================================

# --- Включить REST API
# API_ENABLED — api enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: API_ENABLED=true

# API_ENABLED — api enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: API_ENABLED=true

API_ENABLED=true

# API_HOST — api host.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: API_HOST=<значение>

API_HOST=0.0.0.0

# API_PORT — api port.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: API_PORT=10

API_PORT=8000

# API_TOKEN — api token.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: API_TOKEN=<значение из панели провайдера>

API_TOKEN=

# API_MESSAGE_MAX_CHARS — max user message length for /api/v1/chat, bot-relay, ops/probe.
#   Число символов; порог из .env (дефолт 10000).
#   Пример: API_MESSAGE_MAX_CHARS=10000

API_MESSAGE_MAX_CHARS=10000

# API_RELAY_META_MAX_JSON_CHARS — max serialized JSON size for bot-relay meta field.
#   Пример: API_RELAY_META_MAX_JSON_CHARS=4096

API_RELAY_META_MAX_JSON_CHARS=4096

# API_MAX_REQUEST_BODY_BYTES — reject HTTP bodies larger than this (413).
#   Пример: API_MAX_REQUEST_BODY_BYTES=65536

API_MAX_REQUEST_BODY_BYTES=65536

# API_RATE_LIMIT_ENABLED — api rate limit enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: API_RATE_LIMIT_ENABLED=true

API_RATE_LIMIT_ENABLED=true

# API_RATE_LIMIT_HEAVY_RPM — api rate limit heavy rpm.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: API_RATE_LIMIT_HEAVY_RPM=10

API_RATE_LIMIT_HEAVY_RPM=6

# API_RATE_LIMIT_HEAVY_MIN_INTERVAL_SEC — api rate limit heavy min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: API_RATE_LIMIT_HEAVY_MIN_INTERVAL_SEC=10

API_RATE_LIMIT_HEAVY_MIN_INTERVAL_SEC=10

# AGENT_PROBE_HTTP_MIN_INTERVAL_SEC — agent probe http min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AGENT_PROBE_HTTP_MIN_INTERVAL_SEC=10

AGENT_PROBE_HTTP_MIN_INTERVAL_SEC=12

# AGENT_PROBE_HTTP_ENDPOINT — agent probe http endpoint.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: AGENT_PROBE_HTTP_ENDPOINT=http://127.0.0.1:8001

AGENT_PROBE_HTTP_ENDPOINT=chat

# AGENT_PROBE_API_URL — agent probe api url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: AGENT_PROBE_API_URL=http://127.0.0.1:8001

AGENT_PROBE_API_URL=http://127.0.0.1:8000

# OPS_TRACE_ENABLED — ops trace enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPS_TRACE_ENABLED=true

OPS_TRACE_ENABLED=true

