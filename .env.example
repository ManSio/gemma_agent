#   true / 1 / on — маршрут spatial_design вместо прямой image_generation для чертежей.
#   Пример: SPATIAL_DESIGN_ENABLED=true

SPATIAL_DESIGN_ENABLED=true

# SPATIAL_VISION_MODEL — vision-модель для JSON-разбора плана (OpenRouter slug).
