HEAVY_MODULES_UNDER_PRESSURE=rag,books_rag,vision_describe,vision_ocr,image_generator

# =============================================================================
# Резильенс и safe mode
# =============================================================================

# RESILIENCE_AUTONOMY_ENABLED — resilience autonomy enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RESILIENCE_AUTONOMY_ENABLED=true

# RESILIENCE_AUTONOMY_ENABLED — resilience autonomy enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RESILIENCE_AUTONOMY_ENABLED=true

RESILIENCE_AUTONOMY_ENABLED=true

# RESILIENCE_RUNTIME_DIR — resilience runtime dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: RESILIENCE_RUNTIME_DIR=data/runtime/example.json

RESILIENCE_RUNTIME_DIR=./data/runtime

# =============================================================================
# Событийная шина (EventBus v2) — async‑шина для самовосстановления
# =============================================================================
# Размер буфера последних событий в памяти (0 = не хранить)
# EVENT_BUS_HISTORY_SIZE — event bus history size.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EVENT_BUS_HISTORY_SIZE=<значение>

# EVENT_BUS_HISTORY_SIZE — event bus history size.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EVENT_BUS_HISTORY_SIZE=<значение>

EVENT_BUS_HISTORY_SIZE=1000

# EVENT_BUS_PERSIST_PATH — event bus persist path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: EVENT_BUS_PERSIST_PATH=data/runtime/example.json

# EVENT_BUS_PERSIST_PATH=

# =============================================================================
# Healers — подписчики событийной шины
# =============================================================================
# HEALERS_ENABLED — master switch: false = не ставить healers на event bus. На PERSONAL_PROD: true (mutation off).
# HEALERS_ENV_MUTATION_ENABLED — AutoLatency/AutoHostPressure могут менять os.environ; на проде false.

HEALERS_ENABLED=true

HEALERS_ENV_MUTATION_ENABLED=true

# ModuleFailureHealer: сколько падений модуля подряд до создания эфемерного патча
# HEALER_MODULE_MAX_FAILURES — healer module max failures.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_MODULE_MAX_FAILURES=10

# HEALER_MODULE_MAX_FAILURES — healer module max failures.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_MODULE_MAX_FAILURES=10

HEALER_MODULE_MAX_FAILURES=3

# HEALER_ANOMALY_WINDOW_SEC — healer anomaly window sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_ANOMALY_WINDOW_SEC=10

HEALER_ANOMALY_WINDOW_SEC=600

# HEALER_ANOMALY_MAX_COUNT — healer anomaly max count.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_ANOMALY_MAX_COUNT=10

HEALER_ANOMALY_MAX_COUNT=8

# HEALER_SAFE_MODE_REENTRY_COOLDOWN_SEC — healer safe mode reentry cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_SAFE_MODE_REENTRY_COOLDOWN_SEC=10

HEALER_SAFE_MODE_REENTRY_COOLDOWN_SEC=120

# =============================================================================
# AutoHealers — автоматическое лечение без команды
# =============================================================================
# ModuleFailureHealer: при скольких падениях auto-disable модуль (0=откл)
# HEALER_MODULE_AUTO_DISABLE_AT — healer module auto disable at.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HEALER_MODULE_AUTO_DISABLE_AT=<значение>

