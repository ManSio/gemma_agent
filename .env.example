# --- Корень манифестов плагинов modules/
# MODULES_PATH — modules path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: MODULES_PATH=data/runtime/example.json

# MODULES_PATH — modules path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: MODULES_PATH=data/runtime/example.json

MODULES_PATH=./modules

# CORE_LIBRARIES_PATH — core libraries path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: CORE_LIBRARIES_PATH=data/runtime/example.json

CORE_LIBRARIES_PATH=./core_libraries

# PROJECT_ROOT — project root.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: PROJECT_ROOT=<значение>

PROJECT_ROOT=

# USER_PERSONAS_PATH — user personas path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USER_PERSONAS_PATH=data/runtime/example.json

USER_PERSONAS_PATH=data/user_personas.json

# GEMMA_UPDATE_AUTOSTASH_PANEL — gemma update autostash panel.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_UPDATE_AUTOSTASH_PANEL=true

GEMMA_UPDATE_AUTOSTASH_PANEL=true

# RUNTIME_ENSURE_DATA_LAYOUT — runtime ensure data layout.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RUNTIME_ENSURE_DATA_LAYOUT=true

RUNTIME_ENSURE_DATA_LAYOUT=true

# RUNTIME_DIR_MODE — runtime dir mode.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RUNTIME_DIR_MODE=<значение>

RUNTIME_DIR_MODE=750

# --- Копировать примеры в data/runtime при старте, если файлов ещё нет:
#     system_directive_addon.txt ← config/system_directive_addon_v3.example.txt
#     operator_rules.json ← config/operator_rules.example.json

RUNTIME_CONFIG_SEED=true

# RUNTIME_DIRECTIVE_SEED_FORCE — runtime directive seed force.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RUNTIME_DIRECTIVE_SEED_FORCE=true

RUNTIME_DIRECTIVE_SEED_FORCE=true

# RUNTIME_OPERATOR_RULES_SEED_FORCE — runtime operator rules seed force.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RUNTIME_OPERATOR_RULES_SEED_FORCE=true

RUNTIME_OPERATOR_RULES_SEED_FORCE=true

# PLUGIN_MANIFEST_PATHS — plugin manifest paths.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: PLUGIN_MANIFEST_PATHS=data/runtime/example.json

PLUGIN_MANIFEST_PATHS=

# RAG_DATABASE_PATH — rag database path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: RAG_DATABASE_PATH=data/runtime/example.json

RAG_DATABASE_PATH=./data/rag

# CACHE_PATH — cache path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: CACHE_PATH=data/runtime/example.json

CACHE_PATH=./data/cache

# MODELS_PATH — models path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: MODELS_PATH=data/runtime/example.json

MODELS_PATH=./models

# BEHAVIOR_DATA_DIR — behavior data dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: BEHAVIOR_DATA_DIR=data/runtime/example.json

BEHAVIOR_DATA_DIR=./data/users

# USER_AGENT_IMPRESSION_ENABLED — user agent impression enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: USER_AGENT_IMPRESSION_ENABLED=true

USER_AGENT_IMPRESSION_ENABLED=true

# ERROR_ANALYSIS_DIR — error analysis dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: ERROR_ANALYSIS_DIR=data/runtime/example.json

ERROR_ANALYSIS_DIR=./data

# GEMMA_LLM_USAGE_PERSIST — gemma llm usage persist.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_LLM_USAGE_PERSIST=true

GEMMA_LLM_USAGE_PERSIST=true

# GEMMA_LLM_USAGE_PATH — gemma llm usage path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_LLM_USAGE_PATH=data/runtime/example.json

# LLM_TELEMETRY_DEFAULT_TAG=openrouter_chat — fallback tag в llm_usage если вызов без telemetry_tag.

# GEMMA_LLM_USAGE_PATH=

# ADMIN_SELF_METRICS_HOURS — окно llm_usage/turns для /admin_self (1–168 ч).
#   Пример: ADMIN_SELF_METRICS_HOURS=24

# ADMIN_SELF_METRICS_HOURS=24

# DATABASE_PATH — database path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: DATABASE_PATH=data/runtime/example.json

DATABASE_PATH=./data/database.sqlite

# =============================================================================
# Шифрование (случайные hex; без них часть security может не работать как ожидается)
# =============================================================================
# ENCRYPTION_KEY — encryption key.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: ENCRYPTION_KEY=<значение из панели провайдера>

# ENCRYPTION_KEY — encryption key.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: ENCRYPTION_KEY=<значение из панели провайдера>

# Fernet key: encrypt Mem0 stub + facts.json on disk. Generate: python scripts/generate_encryption_key.py
ENCRYPTION_KEY=

# PROMPT_INJECTION_GUARD_ENABLED — strip injection-like lines from user text before LLM (default true)
PROMPT_INJECTION_GUARD_ENABLED=true

# SECURITY_AES_KEY — security aes key.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: SECURITY_AES_KEY=<значение из панели провайдера>

SECURITY_AES_KEY=

# SECURITY_SALT — security salt.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: SECURITY_SALT=<значение из панели провайдера>

SECURITY_SALT=

# =============================================================================
# OpenRouter и модели
# =============================================================================

# --- После стольких «условных» обращений провайдер может переключить модель/ключ
# MODEL_SWITCH_THRESHOLD — model switch threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MODEL_SWITCH_THRESHOLD=100

MODEL_SWITCH_THRESHOLD=100

# OPENROUTER_HTTP_TOTAL_TIMEOUT_SEC — openrouter http total timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_HTTP_TOTAL_TIMEOUT_SEC=10

OPENROUTER_HTTP_TOTAL_TIMEOUT_SEC=120

# OPENROUTER_CONNECTIVITY_FORCE_FREE — openrouter connectivity force free.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_CONNECTIVITY_FORCE_FREE=true

OPENROUTER_CONNECTIVITY_FORCE_FREE=true

# OPENROUTER_CONNECTIVITY_MODEL — openrouter connectivity model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_CONNECTIVITY_MODEL=deepseek/deepseek-v4-flash

OPENROUTER_CONNECTIVITY_MODEL=openrouter/free

# OPENROUTER_HTTP_RETRY_ATTEMPTS — openrouter http retry attempts.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_HTTP_RETRY_ATTEMPTS=true

OPENROUTER_HTTP_RETRY_ATTEMPTS=2

# OPENROUTER_HTTP_RETRY_GAP_SEC — openrouter http retry gap sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_HTTP_RETRY_GAP_SEC=10

OPENROUTER_HTTP_RETRY_GAP_SEC=10

# OPENROUTER_MODELS_CACHE_SEC — openrouter models cache sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_MODELS_CACHE_SEC=10

OPENROUTER_MODELS_CACHE_SEC=600

# --- Авто-fallback на free-модель при точном признаке нехватки баланса (HTTP 402 / insufficient credits).
# Включено по умолчанию: при no-balance один повтор запроса на free-модель.

OPENROUTER_NO_BALANCE_FALLBACK_TO_FREE=true

# OPENROUTER_NO_BALANCE_FALLBACK_MODEL — openrouter no balance fallback model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_NO_BALANCE_FALLBACK_MODEL=deepseek/deepseek-v4-flash

OPENROUTER_NO_BALANCE_FALLBACK_MODEL=openrouter/free

# OPENROUTER_NO_BALANCE_COOLDOWN_SEC — openrouter no balance cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_NO_BALANCE_COOLDOWN_SEC=10

OPENROUTER_NO_BALANCE_COOLDOWN_SEC=900

# OPENROUTER_API_KEY — ключ OpenRouter для LLM/vision/STT.
#   Пусто — мозг и платные вызовы недоступны (остаются эвристики/RSS).

OPENROUTER_API_KEY=

# OPENROUTER_API_KEY_DEV — openrouter api key dev.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: OPENROUTER_API_KEY_DEV=<значение из панели провайдера>

OPENROUTER_API_KEY_DEV=

# OPENROUTER_MODEL_FREE — openrouter model free.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_FREE=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_FREE=openrouter/free

# --- «Dev» / тяжёлая ветка в коде (часто для сложного чата и рассуждений; в примере: DeepSeek Pro)
# См. core/llm_tiered.py, core/openrouter_provider.py. Контракт плагинов для бота/ИИ: docs/PLUGIN_AUTHOR_HANDBOOK_RU.md

OPENROUTER_MODEL_DEV=deepseek/deepseek-v4-pro

# OPENROUTER_MODEL_QWEN — openrouter model qwen.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_QWEN=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_QWEN=deepseek/deepseek-v4-flash

# BRAIN_LLM_FREE_MODEL — brain llm free model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: BRAIN_LLM_FREE_MODEL=deepseek/deepseek-v4-flash

BRAIN_LLM_FREE_MODEL=deepseek/deepseek-v4-flash

# BRAIN_FAST_CHITCHAT_MODEL — brain fast chitchat model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: BRAIN_FAST_CHITCHAT_MODEL=deepseek/deepseek-v4-flash

BRAIN_FAST_CHITCHAT_MODEL=deepseek/deepseek-v4-flash

# BRAIN_FAST_CHITCHAT_DETERMINISTIC — привет/как дела без LLM (default true)
BRAIN_FAST_CHITCHAT_DETERMINISTIC=true

# BRAIN_LLM_PREMIUM_MODEL — brain llm premium model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: BRAIN_LLM_PREMIUM_MODEL=deepseek/deepseek-v4-flash

BRAIN_LLM_PREMIUM_MODEL=deepseek/deepseek-v4-pro

# OPENROUTER_X_TITLE — openrouter x title.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_X_TITLE=<значение>

OPENROUTER_X_TITLE='Gemma Agent'

# USER_FACING_SHORT_TURN_MAX_CHARS — user facing short turn max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: USER_FACING_SHORT_TURN_MAX_CHARS=10

USER_FACING_SHORT_TURN_MAX_CHARS=56

# DISCOURSE_RESOLVER_ENABLED — единый discourse resolver до intent/router (эллипсис, наследование нити).
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.

DISCOURSE_RESOLVER_ENABLED=true

# DISCOURSE_STRUCT_MAX_CHARS — макс. длина реплики для структурного continuation (по умолчанию = USER_FACING_SHORT_TURN_MAX_CHARS).

DISCOURSE_STRUCT_MAX_CHARS=56

# DISCOURSE_STRUCT_MAX_WORDS — макс. число слов для структурного continuation.

DISCOURSE_STRUCT_MAX_WORDS=8

# DISCOURSE_NOVEL_TOPIC_TOKENS — сколько новых content-токенов (len>=4) вне last Q/A рвут immediate followup.
DISCOURSE_NOVEL_TOPIC_TOKENS=2

# REGEX_INPUT_MAX_LEN — макс. длина строки перед regex на user-text (ReDoS guard).
REGEX_INPUT_MAX_LEN=4096

# OUTBOUND_THREAD_GUARD_ENABLED — pre_send guard: meta-ответ на immediate followup активной нити.
OUTBOUND_THREAD_GUARD_ENABLED=true
# OUTBOUND_THREAD_MIN_TOKEN_OVERLAP — мин. пересечение content-токенов reply с anchor нити.
OUTBOUND_THREAD_MIN_TOKEN_OVERLAP=1

# TURN_MEANING_AGENT_PROFILE — brain profile при referent=agent (не quick_explain philosophy).
TURN_MEANING_AGENT_PROFILE=standard

# DISCOURSE_MIN_LAST_ASSISTANT_CHARS — мин. длина last_assistant для наследования нити.

DISCOURSE_MIN_LAST_ASSISTANT_CHARS=60

# DISCOURSE_REWRITE_ENABLED — IUR-lite: переписать эллипсис с привязкой к last QA.

DISCOURSE_REWRITE_ENABLED=true

# DISCOURSE_THREAD_JUDGE_ENABLED — LLM-судья на пограничных structural continuation (stay/branch/correct).
DISCOURSE_THREAD_JUDGE_ENABLED=true

# DISCOURSE_THREAD_JUDGE_MODEL — модель judge (fallback: ROUTER_LLM_MODEL).
# DISCOURSE_THREAD_JUDGE_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# DISCOURSE_THREAD_JUDGE_TIMEOUT_SEC — таймаут judge, сек.
DISCOURSE_THREAD_JUDGE_TIMEOUT_SEC=8

# DISCOURSE_THREAD_JUDGE_MIN_CONFIDENCE — мин. confidence для применения решения judge.
DISCOURSE_THREAD_JUDGE_MIN_CONFIDENCE=0.55

# CONTEXT_DEPRIORITIZE_FAILED_TURNS — убирать старые fallback-ответы из recent_messages.
CONTEXT_DEPRIORITIZE_FAILED_TURNS=true

# OPENROUTER_REASONING_FALLBACK_IF_EMPTY — openrouter reasoning fallback if empty.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_REASONING_FALLBACK_IF_EMPTY=true

OPENROUTER_REASONING_FALLBACK_IF_EMPTY=true

# OPENROUTER_REASONING_FALLBACK_MAX_CHARS — openrouter reasoning fallback max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_REASONING_FALLBACK_MAX_CHARS=10

OPENROUTER_REASONING_FALLBACK_MAX_CHARS=12000

# OPENROUTER_REASONING_FALLBACK_SKIP_R1 — openrouter reasoning fallback skip r1.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_REASONING_FALLBACK_SKIP_R1=true

OPENROUTER_REASONING_FALLBACK_SKIP_R1=true

# OPENROUTER_EXPOSE_REASONING — openrouter expose reasoning.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_EXPOSE_REASONING=true

OPENROUTER_EXPOSE_REASONING=false

# TELEGRAM_ADMIN_STREAM_REASONING — admin-only: CoT в progress при stream (private + aus:asr).
#   Нужно также TELEGRAM_STREAM_REPLY_ENABLED=true.
TELEGRAM_ADMIN_STREAM_REASONING=false

# TELEGRAM_STREAM_REASONING_MAX_CHARS — лимит текста CoT в progress-сообщении.
TELEGRAM_STREAM_REASONING_MAX_CHARS=1800

# OPENROUTER_SILENT_REFUSAL_RETRY — при content_filter и пустом content: один retry на fallback-модель.
OPENROUTER_SILENT_REFUSAL_RETRY=true
# OPENROUTER_SILENT_REFUSAL_FALLBACK_MODEL=openrouter/free

# OPENROUTER_PROMPT_CACHE_MODE — openrouter prompt cache mode.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_PROMPT_CACHE_MODE=true

OPENROUTER_PROMPT_CACHE_MODE=off

# OPENROUTER_CACHE_FIRST_PROVIDERS — openrouter cache first providers.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_CACHE_FIRST_PROVIDERS=true

OPENROUTER_CACHE_FIRST_PROVIDERS=true

# OPENROUTER_CACHE_FIRST_DEFAULT_ORDER — openrouter cache first default order.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_CACHE_FIRST_DEFAULT_ORDER=<значение>

OPENROUTER_CACHE_FIRST_DEFAULT_ORDER=DeepSeek,baidu

# OPENROUTER_CACHE_FIRST_DEFAULT_IGNORE — openrouter cache first default ignore.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_CACHE_FIRST_DEFAULT_IGNORE=<значение>

OPENROUTER_CACHE_FIRST_DEFAULT_IGNORE=deepinfra

# OPENROUTER_PROVIDER_ORDER — openrouter provider order.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_PROVIDER_ORDER=<значение>

OPENROUTER_PROVIDER_ORDER=DeepSeek,baidu

# OPENROUTER_PROVIDER_QUANTIZATIONS — openrouter provider quantizations.
#   Применяется только к deepseek/* (brain). Не ставить на liquid/:free — 404 router.
#   Пример: OPENROUTER_PROVIDER_QUANTIZATIONS=fp8

OPENROUTER_PROVIDER_QUANTIZATIONS=fp8

# OPENROUTER_PROVIDER_IGNORE — openrouter provider ignore.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_PROVIDER_IGNORE=<значение>

OPENROUTER_PROVIDER_IGNORE=deepinfra

# OPENROUTER_PROVIDER_ALLOW_FALLBACKS — openrouter provider allow fallbacks.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true

OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true

# OPENROUTER_ANTHROPIC_CACHE_TTL — openrouter anthropic cache ttl.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_ANTHROPIC_CACHE_TTL=10

# OPENROUTER_ANTHROPIC_CACHE_TTL=

# --- Сессионный KV-кэш (X-Session-Id) для OpenRouter.
#     Включён по умолчанию: бот отправляет заголовок X-Session-Id в каждый запрос.
#     OpenRouter использует его для привязки prefix-cache к сессии пользователя.
#     Выключите (false), если кэш мешает или нужна изоляция каждого запроса.

OPENROUTER_SESSION_HEADERS_ENABLED=true

# OPENROUTER_ANTHROPIC_CACHE_TTL — openrouter anthropic cache ttl.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_ANTHROPIC_CACHE_TTL=10

OPENROUTER_ANTHROPIC_CACHE_TTL=1h

# OPENROUTER_CACHE_STABLE_HINTS_FOR_SHALLOW — openrouter cache stable hints for shallow.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_CACHE_STABLE_HINTS_FOR_SHALLOW=true

OPENROUTER_CACHE_STABLE_HINTS_FOR_SHALLOW=true

# ADMIN_KV_DEBUG_WINDOW_ROWS — admin kv debug window rows.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: ADMIN_KV_DEBUG_WINDOW_ROWS=<значение>

ADMIN_KV_DEBUG_WINDOW_ROWS=20

# OPENROUTER_GEN_TEMPERATURE — openrouter gen temperature.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_TEMPERATURE=<значение>

OPENROUTER_GEN_TEMPERATURE=0.6

# OPENROUTER_GEN_TOP_P — openrouter gen top p.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_TOP_P=<значение>

OPENROUTER_GEN_TOP_P=0.8

# OPENROUTER_GEN_MAX_TOKENS — openrouter gen max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_GEN_MAX_TOKENS=10

OPENROUTER_GEN_MAX_TOKENS=2000

# OPENROUTER_GEN_PRESENCE_PENALTY — openrouter gen presence penalty.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_PRESENCE_PENALTY=<значение>

OPENROUTER_GEN_PRESENCE_PENALTY=0.0

# OPENROUTER_GEN_FREQUENCY_PENALTY — openrouter gen frequency penalty.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_FREQUENCY_PENALTY=<значение>

OPENROUTER_GEN_FREQUENCY_PENALTY=0.0

# OPENROUTER_GEN_REPETITION_PENALTY — openrouter gen repetition penalty.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_REPETITION_PENALTY=<значение>

OPENROUTER_GEN_REPETITION_PENALTY=0.0

# OPENROUTER_GEN_TOP_K — openrouter gen top k.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_TOP_K=<значение>

OPENROUTER_GEN_TOP_K=40

# OPENROUTER_GEN_MIN_P — openrouter gen min p.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_GEN_MIN_P=10

OPENROUTER_GEN_MIN_P=0.05

# OPENROUTER_GEN_SEED — openrouter gen seed.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_SEED=<значение>

OPENROUTER_GEN_SEED=42

# Unified reasoning map (OpenRouter 2026): reasoning.effort|enabled|exclude|max_tokens
# https://openrouter.ai/docs/guides/best-practices/reasoning-tokens
# OPENROUTER_REASONING_ENABLED — master switch (true=on).
OPENROUTER_REASONING_ENABLED=true
# exclude=true: модель думает внутри, CoT не в ответе (безопаснее для TG; reasoning_tokens в usage).
OPENROUTER_REASONING_EXCLUDE=true
# high для всех brain_* кроме OPENROUTER_REASONING_SKIP_TAGS (fast_chitchat, direct_dialog, …).
OPENROUTER_BRAIN_REASONING_EFFORT=high
# При effort high/xhigh поднять max_tokens, если ниже (≈80% бюджета уходит в CoT).
OPENROUTER_REASONING_HIGH_MIN_MAX_TOKENS=2048
# Префиксы моделей, куда слать reasoning (чужие slug — игнор).
OPENROUTER_REASONING_MODEL_PREFIXES=deepseek/
# OPENROUTER_REASONING_SKIP_TAGS=brain_fast_chitchat,brain_direct_dialog,router_classifier,...

# OPENROUTER_GEN_REASONING_EFFORT — глобальный effort для НЕ-brain тегов (none=выкл).
#   xhigh|high|medium|low|minimal|none
OPENROUTER_GEN_REASONING_EFFORT=none

# OPENROUTER_GEN_<TAG>_REASONING_EFFORT=high|xhigh|…
# OPENROUTER_GEN_<TAG>_REASONING_ENABLED=true
# OPENROUTER_GEN_<TAG>_REASONING_EXCLUDE=true
# OPENROUTER_GEN_<TAG>_REASONING_MAX_TOKENS=800
# Примеры tag: brain_first, brain_second, vision_precaption, task_outline.

OPENROUTER_GEN_BRAIN_FIRST_REASONING_EFFORT=high

OPENROUTER_GEN_BRAIN_SECOND_REASONING_EFFORT=high

# OPENROUTER_GEN_STOP — stop sequences (pipe-separated; без backticks — bash-safe).
#   Пример: OPENROUTER_GEN_STOP='```||</answer>'

OPENROUTER_GEN_STOP='```||</answer>'

#
# Точечные оверрайды по telemetry_tag:
# OPENROUTER_GEN_<TAG>_TEMPERATURE=...
# OPENROUTER_GEN_<TAG>_TOP_P=...
# OPENROUTER_GEN_<TAG>_MAX_TOKENS=...
# OPENROUTER_GEN_<TAG>_PRESENCE_PENALTY=...
# OPENROUTER_GEN_<TAG>_FREQUENCY_PENALTY=...
# OPENROUTER_GEN_<TAG>_REPETITION_PENALTY=...
# OPENROUTER_GEN_<TAG>_TOP_K=...
# OPENROUTER_GEN_<TAG>_MIN_P=...
# OPENROUTER_GEN_<TAG>_SEED=...
# OPENROUTER_GEN_<TAG>_REASONING_EFFORT=xhigh|high|medium|low|minimal|none
# OPENROUTER_GEN_<TAG>_STOP=["...","..."]  (или "a||b")
# Примеры tag: brain_first, brain_second, vision_precaption, task_outline.

OPENROUTER_GEN_BRAIN_FIRST_TEMPERATURE=0.4

# OPENROUTER_GEN_BRAIN_SECOND_TOP_P — openrouter gen brain second top p.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_GEN_BRAIN_SECOND_TOP_P=10

OPENROUTER_GEN_BRAIN_SECOND_TOP_P=0.9

# OPENROUTER_GEN_VISION_PRECAPTION_MAX_TOKENS — openrouter gen vision precaption max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_GEN_VISION_PRECAPTION_MAX_TOKENS=10

OPENROUTER_GEN_VISION_PRECAPTION_MAX_TOKENS=512

# DEFAULT_MODEL — default model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: DEFAULT_MODEL=deepseek/deepseek-v4-flash

DEFAULT_MODEL=free

# TELEGRAM_PROGRESS_LABEL_FORECAST — telegram progress label forecast.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: TELEGRAM_PROGRESS_LABEL_FORECAST=<значение>

TELEGRAM_PROGRESS_LABEL_FORECAST=Прогноз ≈

# TELEGRAM_PROGRESS_INITIAL — telegram progress initial.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: TELEGRAM_PROGRESS_INITIAL=<значение>

TELEGRAM_PROGRESS_INITIAL=⏳ Думаю…

# TELEGRAM_PROGRESS_SEED_CONTEXT_CHARS — telegram progress seed context chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_PROGRESS_SEED_CONTEXT_CHARS=10

TELEGRAM_PROGRESS_SEED_CONTEXT_CHARS=3800

# TELEGRAM_PROGRESS_ASSEMBLY_BUFFER_SEC — telegram progress assembly buffer sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Базовый буфер до первого LLM; при ≥3 образцах смешивается с EMA из llm_eta_stats.json.
#   Аудит VPS 05/2026: p50 хода ~13.7 с, p50 brain LLM ~3.4 с → сборка+роутинг ~10 с.
#   Пример: TELEGRAM_PROGRESS_ASSEMBLY_BUFFER_SEC=10

TELEGRAM_PROGRESS_ASSEMBLY_BUFFER_SEC=10

# TELEGRAM_PROGRESS_SEED_TIMEOUT_MULT — telegram progress seed timeout mult.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_PROGRESS_SEED_TIMEOUT_MULT=10

TELEGRAM_PROGRESS_SEED_TIMEOUT_MULT=2.25

# TELEGRAM_PROGRESS_SEED_TIMEOUT_MIN_SEC — telegram progress seed timeout min sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_PROGRESS_SEED_TIMEOUT_MIN_SEC=10

TELEGRAM_PROGRESS_SEED_TIMEOUT_MIN_SEC=55

# TELEGRAM_PROGRESS_MIN_INTERVAL_SEC — telegram progress min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_PROGRESS_MIN_INTERVAL_SEC=10

TELEGRAM_PROGRESS_MIN_INTERVAL_SEC=2

# TELEGRAM_PROGRESS_ETC_REFRESH_SEC — telegram progress etc refresh sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_PROGRESS_ETC_REFRESH_SEC=10

TELEGRAM_PROGRESS_ETC_REFRESH_SEC=5

# TELEGRAM_PROGRESS_SAME_STAGE_INTERVAL_SEC — telegram progress same stage interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_PROGRESS_SAME_STAGE_INTERVAL_SEC=10

TELEGRAM_PROGRESS_SAME_STAGE_INTERVAL_SEC=10

# TELEGRAM_PROGRESS_ETC_REFRESH_ENABLED — telegram progress etc refresh enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TELEGRAM_PROGRESS_ETC_REFRESH_ENABLED=true

TELEGRAM_PROGRESS_ETC_REFRESH_ENABLED=true

# TELEGRAM_PROGRESS_LABEL_ELAPSED — telegram progress label elapsed.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: TELEGRAM_PROGRESS_LABEL_ELAPSED=<значение>

TELEGRAM_PROGRESS_LABEL_ELAPSED=Прошло

# Потоковая отдача ответа в личке (edit progress-сообщения). По умолчанию выкл — включать на LAN.
TELEGRAM_STREAM_REPLY_ENABLED=false
TELEGRAM_STREAM_PRIVATE_ONLY=true
# true: stream только на brain_direct_dialog (не конфликт с progress на тяжёлом brain)
TELEGRAM_STREAM_DIRECT_ONLY=true
# Минимальный интервал между edit_message при stream (мс)
TELEGRAM_STREAM_MIN_EDIT_INTERVAL_MS=900
# Не edit progress, пока накоплено меньше N символов
TELEGRAM_STREAM_MIN_CHARS=20
TELEGRAM_STREAM_CANCEL_SUFFIX=⏹ Остановлено.

# Предупреждение в лог при большом промпте (без обрезки)
BRAIN_CONTEXT_BUDGET_WARN_ENABLED=true
BRAIN_CONTEXT_BUDGET_WARN_CHARS=12000

# conversation_epoch: новый KV-контекст на /new и после простоя (сек)
CONVERSATION_EPOCH_IDLE_TTL_SEC=86400
# Слоты диалога (погода-await-city, нить статьи) — core/dialogue_slots.py
DIALOGUE_SLOTS_ENABLED=true

# TELEGRAM_REPLY_MODE_FOOTER — подпись режима внизу ответа (admin-отладка).
#   off — выкл; admin — только ADMIN_USER_IDS; owner — OWNER_TELEGRAM_ID; all — всем (не на проде).
#   Метка для grep: [gemma:mf|v1|i=...|m=...|t=...] в turns.jsonl и в чате.
#   Пример: TELEGRAM_REPLY_MODE_FOOTER=admin

TELEGRAM_REPLY_MODE_FOOTER=off
DIALOGUE_SLOT_TURNS=6
DIALOGUE_SLOT_WEATHER_TURNS=3
# SLOT_REGISTRY_ENABLED — контракт accepts_turn на kind (weather/article/spatial); false = только weather bind.
SLOT_REGISTRY_ENABLED=true
# TURN_MEANING_ENABLED — единый verdict намерения хода (structural + LLM judge) до discourse/collapse.
TURN_MEANING_ENABLED=true
# TURN_SHORTCUT_GATE_ENABLED — блокировать weather/geo/pre_llm shortcuts при referent=agent|user или correction.
TURN_SHORTCUT_GATE_ENABLED=true
DIALOGUE_SLOT_ARTICLE_TURNS=8
LEXICAL_DIALOG_RECALL_ENABLED=true
LEXICAL_DIALOG_RECALL_MAX_CHARS=1200
LEXICAL_DIALOG_RECALL_MAX_SNIPPETS=4

# session_digest: не писать flush при длинном буфере одной темы
SESSION_DIGEST_DEDUP_ENABLED=true
SESSION_DIGEST_DEDUP_MIN_TURNS=10
# MEM-4 / Q2: не подмешивать session_digest в brain prompt, если recent уже ≥ BRAIN_STANDARD_RECENT_COUNT user-ходов.
SESSION_DIGEST_SKIP_WHEN_RECENT_FULL=true

# BRAIN_LLM_TOKENS_PER_SEC_EST — brain llm tokens per sec est (gen-токены).
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Fallback, если в llm_eta_stats.json мало образцов ema_tps для корзины.
#   Аудит VPS 05/2026: brain p50 latency ~3.4 с, типичный completion ~150–280 tok → ~52 tok/s.
#   Пример: BRAIN_LLM_TOKENS_PER_SEC_EST=10

BRAIN_LLM_TOKENS_PER_SEC_EST=52

# BRAIN_LLM_ETA_PROMPT_TPS — скорость «прогона» prompt-токенов (tok/s) в ETA.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_PROMPT_TPS=10

BRAIN_LLM_ETA_PROMPT_TPS=1400

# BRAIN_LLM_ETA_PROMPT_CHARS_PER_TOK — символов на prompt-токен (оценка длины промпта).
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_PROMPT_CHARS_PER_TOK=10

BRAIN_LLM_ETA_PROMPT_CHARS_PER_TOK=4.2

# BRAIN_LLM_ETA_MAX_TOK_FRAC — доля max_tokens как ожидаемый completion (не весь лимит).
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_MAX_TOK_FRAC=10

BRAIN_LLM_ETA_MAX_TOK_FRAC=0.28

# BRAIN_LLM_ETA_SHORT_USER_CHARS — короткая реплика пользователя (символов).
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_SHORT_USER_CHARS=10

BRAIN_LLM_ETA_SHORT_USER_CHARS=80

# BRAIN_LLM_ETA_SHORT_GEN_TOKENS — ожидаемый completion для короткой реплики.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_SHORT_GEN_TOKENS=10

BRAIN_LLM_ETA_SHORT_GEN_TOKENS=220

# BRAIN_LLM_ETA_MIN_GEN_TOKENS — нижняя граница gen-токенов в ETA.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_MIN_GEN_TOKENS=10

BRAIN_LLM_ETA_MIN_GEN_TOKENS=140

# BRAIN_LLM_ETA_ASSEMBLY_LEARN_ENABLED — учить EMA сборки промпта (arm → первый LLM).
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_LLM_ETA_ASSEMBLY_LEARN_ENABLED=true

BRAIN_LLM_ETA_ASSEMBLY_LEARN_ENABLED=true

# BRAIN_LLM_ETA_ASSEMBLY_LEARN_MIN_SAMPLES — мин. образцов assembly EMA для seed.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_ASSEMBLY_LEARN_MIN_SAMPLES=10

BRAIN_LLM_ETA_ASSEMBLY_LEARN_MIN_SAMPLES=3

# BRAIN_LLM_ETA_USER_CHARS_PER_TOK — brain llm eta user chars per tok.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_USER_CHARS_PER_TOK=10

BRAIN_LLM_ETA_USER_CHARS_PER_TOK=5.5

# BRAIN_LLM_ETA_GEN_TOKENS_CAP — brain llm eta gen tokens cap.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_LLM_ETA_GEN_TOKENS_CAP=<значение>

BRAIN_LLM_ETA_GEN_TOKENS_CAP=8000

# BRAIN_LLM_ETA_LEARN_ENABLED — brain llm eta learn enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_LLM_ETA_LEARN_ENABLED=true

BRAIN_LLM_ETA_LEARN_ENABLED=true

# BRAIN_LLM_ETA_LEARN_EMA_ALPHA — brain llm eta learn ema alpha.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_LLM_ETA_LEARN_EMA_ALPHA=<значение>

BRAIN_LLM_ETA_LEARN_EMA_ALPHA=0.12

# BRAIN_LLM_ETA_LEARN_MIN_SAMPLES — brain llm eta learn min samples.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_MIN_SAMPLES=10

BRAIN_LLM_ETA_LEARN_MIN_SAMPLES=4

# BRAIN_LLM_ETA_LEARN_BLEND_SPAN — brain llm eta learn blend span.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_LLM_ETA_LEARN_BLEND_SPAN=<значение>

BRAIN_LLM_ETA_LEARN_BLEND_SPAN=18

