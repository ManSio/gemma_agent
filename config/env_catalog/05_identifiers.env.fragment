# =============================================================================
# Идентификаторы Telegram (подставляются apply_env_catalog из docs/OPS_PRIVATE.local.md)
# В git только плейсхолдеры; реальные id — в OPS_PRIVATE.local.md
# =============================================================================

# ADMIN_USER_IDS — кто видит /admin_* и ACL (через запятую).
#   Пример: 123456789,987654321
ADMIN_USER_IDS=123456789

# ADMIN_NOTIFY_USER_IDS — кому слать стартовые/системные уведомления (часто = админы).
ADMIN_NOTIFY_USER_IDS=123456789

# POST_DEPLOY_PROBE_USER_ID — user_id для post_deploy_smoke и agent_turn_probe.
POST_DEPLOY_PROBE_USER_ID=123456789

# OWNER_TELEGRAM_ID — владелец (fallback для probe, если POST_DEPLOY пуст).
OWNER_TELEGRAM_ID=123456789

# Тестовый Telegram (VPNTEST): второй id в ADMIN_USER_IDS — из OPS_PRIVATE TEST_ADMIN_TELEGRAM_ID.
