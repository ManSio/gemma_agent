# =============================================================================
# Vision (мозг + картинки)
# =============================================================================

# OPENROUTER_MODEL_VISION — openrouter model vision.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_VISION=deepseek/deepseek-v4-flash

# OPENROUTER_MODEL_VISION — openrouter model vision.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_VISION=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_VISION=google/gemma-3-12b-it

# BRAIN_VISION_TWO_STEP — brain vision two step.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_VISION_TWO_STEP=true

BRAIN_VISION_TWO_STEP=true

# BRAIN_VISION_FALLBACK_SINGLE_STAGE — brain vision fallback single stage.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_VISION_FALLBACK_SINGLE_STAGE=true

BRAIN_VISION_FALLBACK_SINGLE_STAGE=true

# BRAIN_IMAGE_SLIM_PROMPT — brain image slim prompt.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_IMAGE_SLIM_PROMPT=true

BRAIN_IMAGE_SLIM_PROMPT=true

# BRAIN_VISION_PRECAPTION_TIMEOUT_SEC — brain vision precaption timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_VISION_PRECAPTION_TIMEOUT_SEC=10

BRAIN_VISION_PRECAPTION_TIMEOUT_SEC=90
