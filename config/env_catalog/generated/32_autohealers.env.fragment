# =============================================================================
# AutoHealers — автоматическое лечение без команды
# =============================================================================
# ModuleFailureHealer: при скольких падениях auto-disable модуль (0=откл)
# HEALER_MODULE_AUTO_DISABLE_AT — healer module auto disable at.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HEALER_MODULE_AUTO_DISABLE_AT=<значение>

# HEALER_MODULE_AUTO_DISABLE_AT — healer module auto disable at.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HEALER_MODULE_AUTO_DISABLE_AT=<значение>

HEALER_MODULE_AUTO_DISABLE_AT=5

# HEALER_LATENCY_P95_THRESHOLD_MS — healer latency p95 threshold ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_LATENCY_P95_THRESHOLD_MS=10

HEALER_LATENCY_P95_THRESHOLD_MS=10000

# HEALER_LATENCY_COOLDOWN_SEC — healer latency cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_LATENCY_COOLDOWN_SEC=10

HEALER_LATENCY_COOLDOWN_SEC=300

# HEALER_FAIL_RATIO_THRESHOLD — healer fail ratio threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_FAIL_RATIO_THRESHOLD=10

HEALER_FAIL_RATIO_THRESHOLD=0.3

# HEALER_FAIL_RATIO_COOLDOWN_SEC — healer fail ratio cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_FAIL_RATIO_COOLDOWN_SEC=10

HEALER_FAIL_RATIO_COOLDOWN_SEC=300

# HEALER_HOST_COOLDOWN_SEC — healer host cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_HOST_COOLDOWN_SEC=10

HEALER_HOST_COOLDOWN_SEC=600
