# =============================================================================
# UniversalSearch: SearXNG (рекомендуется при санкциях/блоках) + DuckDuckGo (без ключей, хрупко с VPS)
# =============================================================================
# Сей свой или доверенный инстанс SearXNG — не требует Tavily/Brave; движки (в т.ч. региональные) задаёте в SearXNG.
# SEARXNG_INSTANCE_URL — свой SearXNG для UniversalSearch.
#   Пусто — fallback DuckDuckGo/Tavily/Brave по другим флагам.
#   Пример: http://searxng.local:8080

# SEARXNG_INSTANCE_URL — свой SearXNG для UniversalSearch.
#   Пусто — fallback DuckDuckGo/Tavily/Brave по другим флагам.
#   Пример: http://searxng.local:8080

SEARXNG_INSTANCE_URL=https://search.example.com

# SEARXNG_ENABLED — searxng enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SEARXNG_ENABLED=true

SEARXNG_ENABLED=true

# SEARXNG_MAX_RESULTS — searxng max results.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SEARXNG_MAX_RESULTS=10

SEARXNG_MAX_RESULTS=8   # макс. в коде 20; для VPS «полный» профиль: bash scripts/apply_search_max_env.sh

# UNIVERSAL_SEARCH_LOCAL_FIRST — universal search local first.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: UNIVERSAL_SEARCH_LOCAL_FIRST=true

UNIVERSAL_SEARCH_LOCAL_FIRST=true

# UNIVERSAL_SEARCH_FREE_ONLY — universal search free only.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: UNIVERSAL_SEARCH_FREE_ONLY=true

UNIVERSAL_SEARCH_FREE_ONLY=true

# UNIVERSAL_SEARCH_MAX_SUMMARY_CHARS — universal search max summary chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: UNIVERSAL_SEARCH_MAX_SUMMARY_CHARS=10

UNIVERSAL_SEARCH_MAX_SUMMARY_CHARS=6000   # SEARCH_MAX на VPS: 8000

# UNIVERSAL_SEARCH_TIMEOUT_SEC — universal search timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: UNIVERSAL_SEARCH_TIMEOUT_SEC=10

UNIVERSAL_SEARCH_TIMEOUT_SEC=45

# DUCKDUCKGO_HTML_FALLBACK — duckduckgo html fallback.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DUCKDUCKGO_HTML_FALLBACK=true

DUCKDUCKGO_HTML_FALLBACK=true

# DUCKDUCKGO_HTML_URL — duckduckgo html url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: DUCKDUCKGO_HTML_URL=http://127.0.0.1:8001

DUCKDUCKGO_HTML_URL=https://html.duckduckgo.com/html/

# DUCKDUCKGO_HTML_MAX_RESULTS — duckduckgo html max results.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: DUCKDUCKGO_HTML_MAX_RESULTS=10

DUCKDUCKGO_HTML_MAX_RESULTS=8

# DUCKDUCKGO_HTML_TIMEOUT_SEC — duckduckgo html timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: DUCKDUCKGO_HTML_TIMEOUT_SEC=10

DUCKDUCKGO_HTML_TIMEOUT_SEC=20
