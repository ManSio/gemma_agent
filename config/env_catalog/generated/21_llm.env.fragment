# =============================================================================
# Кэш готовых ответов (без LLM): консервативно, только указанные модули
# =============================================================================
# Вкл: повтор той же фразы отдаёт сохранённый текст; кнопка «Пересчитать» (math) / «Без кэша» сбрасывает на один ход.
# Не кэшируется: reply/forward/вложения, URL, «курс/новости/погода…», slash кроме /calc.
# BRAIN_RESPONSE_CACHE_ENABLED — brain response cache enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_RESPONSE_CACHE_ENABLED=true

# BRAIN_RESPONSE_CACHE_ENABLED — brain response cache enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_RESPONSE_CACHE_ENABLED=true

BRAIN_RESPONSE_CACHE_ENABLED=false

# BRAIN_RESPONSE_CACHE_MODULES — brain response cache modules.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_RESPONSE_CACHE_MODULES=<значение>

BRAIN_RESPONSE_CACHE_MODULES=math,echo

# BRAIN_RESPONSE_CACHE_TTL_SEC — brain response cache ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_RESPONSE_CACHE_TTL_SEC=10

BRAIN_RESPONSE_CACHE_TTL_SEC=3600

# BRAIN_RESPONSE_CACHE_MAX_ENTRIES — brain response cache max entries.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_RESPONSE_CACHE_MAX_ENTRIES=10

BRAIN_RESPONSE_CACHE_MAX_ENTRIES=500

# BRAIN_RESPONSE_CACHE_MIN_CHARS — brain response cache min chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_RESPONSE_CACHE_MIN_CHARS=10

BRAIN_RESPONSE_CACHE_MIN_CHARS=8

# BRAIN_RESPONSE_CACHE_MAX_CHARS — brain response cache max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_RESPONSE_CACHE_MAX_CHARS=10

BRAIN_RESPONSE_CACHE_MAX_CHARS=2000

# BRAIN_RESPONSE_CACHE_SHOW_BADGE — brain response cache show badge.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_RESPONSE_CACHE_SHOW_BADGE=true

BRAIN_RESPONSE_CACHE_SHOW_BADGE=false
