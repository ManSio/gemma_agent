# =============================================================================
# Метрики хоста (psutil)
# =============================================================================

# RESOURCE_METRICS_TTL_SEC — resource metrics ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESOURCE_METRICS_TTL_SEC=10

# RESOURCE_METRICS_TTL_SEC — resource metrics ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESOURCE_METRICS_TTL_SEC=10

RESOURCE_METRICS_TTL_SEC=8

# RESOURCE_METRICS_BOOT_DELAY_SEC — resource metrics boot delay sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESOURCE_METRICS_BOOT_DELAY_SEC=10

RESOURCE_METRICS_BOOT_DELAY_SEC=45

# RESOURCE_CPU_SAMPLE_INTERVAL_SEC — resource cpu sample interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESOURCE_CPU_SAMPLE_INTERVAL_SEC=10

RESOURCE_CPU_SAMPLE_INTERVAL_SEC=0.25

# RESOURCE_CPU_BOOT_GRACE_SEC — resource cpu boot grace sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESOURCE_CPU_BOOT_GRACE_SEC=10

RESOURCE_CPU_BOOT_GRACE_SEC=180

# RESOURCE_WARN_CPU_PERCENT — resource warn cpu percent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESOURCE_WARN_CPU_PERCENT=<значение>

RESOURCE_WARN_CPU_PERCENT=88

# RESOURCE_WARN_MEM_PERCENT — resource warn mem percent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESOURCE_WARN_MEM_PERCENT=<значение>

RESOURCE_WARN_MEM_PERCENT=88

# RESOURCE_WARN_DISK_PERCENT — resource warn disk percent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESOURCE_WARN_DISK_PERCENT=<значение>

RESOURCE_WARN_DISK_PERCENT=90

# RESOURCE_CRIT_CPU_PERCENT — resource crit cpu percent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESOURCE_CRIT_CPU_PERCENT=<значение>

RESOURCE_CRIT_CPU_PERCENT=98

# RESOURCE_CRIT_MEM_PERCENT — resource crit mem percent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESOURCE_CRIT_MEM_PERCENT=<значение>

RESOURCE_CRIT_MEM_PERCENT=96

# RESOURCE_CRIT_DISK_PERCENT — resource crit disk percent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESOURCE_CRIT_DISK_PERCENT=<значение>

RESOURCE_CRIT_DISK_PERCENT=97

# RESOURCE_PRESSURE_DEGRADES — resource pressure degrades.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RESOURCE_PRESSURE_DEGRADES=true

RESOURCE_PRESSURE_DEGRADES=true

# RESOURCE_PRESSURE_CRITICAL — resource pressure critical.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RESOURCE_PRESSURE_CRITICAL=true

RESOURCE_PRESSURE_CRITICAL=true
