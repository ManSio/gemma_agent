# =============================================================================
# Parallel Batch (core/batch_processor.py, core/batch_continuation.py)
# =============================================================================
# Параллельные сабвызовы для profile=batch (независимые пункты списка)
# BATCH_PARALLEL_ENABLED — batch parallel enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BATCH_PARALLEL_ENABLED=true

# BATCH_PARALLEL_ENABLED — batch parallel enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BATCH_PARALLEL_ENABLED=true

BATCH_PARALLEL_ENABLED=true

# BATCH_PARALLEL_INITIAL — batch parallel initial.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BATCH_PARALLEL_INITIAL=<значение>

BATCH_PARALLEL_INITIAL=2

# BATCH_PARALLEL_MAX_CAP — batch parallel max cap.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BATCH_PARALLEL_MAX_CAP=10

BATCH_PARALLEL_MAX_CAP=12

# BATCH_PARALLEL_MIN_ITEMS — batch parallel min items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BATCH_PARALLEL_MIN_ITEMS=10

BATCH_PARALLEL_MIN_ITEMS=3

# BATCH_PARALLEL_MAX_TOKENS — batch parallel max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BATCH_PARALLEL_MAX_TOKENS=10

BATCH_PARALLEL_MAX_TOKENS=2000

# BATCH_PARALLEL_TIMEOUT_SEC — batch parallel timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BATCH_PARALLEL_TIMEOUT_SEC=10

BATCH_PARALLEL_TIMEOUT_SEC=30

# BATCH_PARALLEL_RATE_LIMIT_BACKOFF — batch parallel rate limit backoff.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BATCH_PARALLEL_RATE_LIMIT_BACKOFF=10

BATCH_PARALLEL_RATE_LIMIT_BACKOFF=30

# BATCH_MAX_ITEMS — batch max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BATCH_MAX_ITEMS=10

BATCH_MAX_ITEMS=200

# BATCH_MAX_HINT_CHARS — batch max hint chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BATCH_MAX_HINT_CHARS=10

BATCH_MAX_HINT_CHARS=3000
