# =============================================================================
# Auto-Rollback — откат неудачных авто-лечений
# =============================================================================
# UndoLog: кулдаун проверки pending записей
# AUTO_ROLLBACK_COOLDOWN_SEC — auto rollback cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTO_ROLLBACK_COOLDOWN_SEC=10

# AUTO_ROLLBACK_COOLDOWN_SEC — auto rollback cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTO_ROLLBACK_COOLDOWN_SEC=10

AUTO_ROLLBACK_COOLDOWN_SEC=60

# UNDO_LOG_PATH — undo log path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: UNDO_LOG_PATH=data/runtime/example.json

UNDO_LOG_PATH=data/runtime/undo_log.jsonl
