# =============================================================================
# OpenRouter и модели
# =============================================================================

# --- После стольких «условных» обращений провайдер может переключить модель/ключ
# MODEL_SWITCH_THRESHOLD — model switch threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MODEL_SWITCH_THRESHOLD=10

# MODEL_SWITCH_THRESHOLD — model switch threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MODEL_SWITCH_THRESHOLD=10

MODEL_SWITCH_THRESHOLD=100

# OPENROUTER_HTTP_TOTAL_TIMEOUT_SEC — openrouter http total timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_HTTP_TOTAL_TIMEOUT_SEC=10

OPENROUTER_HTTP_TOTAL_TIMEOUT_SEC=120

# OPENROUTER_CONNECTIVITY_FORCE_FREE — openrouter connectivity force free.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_CONNECTIVITY_FORCE_FREE=true

OPENROUTER_CONNECTIVITY_FORCE_FREE=true

# OPENROUTER_CONNECTIVITY_MODEL — openrouter connectivity model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_CONNECTIVITY_MODEL=deepseek/deepseek-v4-flash

OPENROUTER_CONNECTIVITY_MODEL=openrouter/free

# OPENROUTER_HTTP_RETRY_ATTEMPTS — openrouter http retry attempts.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_HTTP_RETRY_ATTEMPTS=true

OPENROUTER_HTTP_RETRY_ATTEMPTS=1

# OPENROUTER_HTTP_RETRY_GAP_SEC — openrouter http retry gap sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_HTTP_RETRY_GAP_SEC=10

OPENROUTER_HTTP_RETRY_GAP_SEC=10

# OPENROUTER_MODELS_CACHE_SEC — openrouter models cache sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_MODELS_CACHE_SEC=10

OPENROUTER_MODELS_CACHE_SEC=600

# --- Авто-fallback на free-модель при точном признаке нехватки баланса (HTTP 402 / insufficient credits).
# Включено по умолчанию: при no-balance один повтор запроса на free-модель.

OPENROUTER_NO_BALANCE_FALLBACK_TO_FREE=true

# OPENROUTER_NO_BALANCE_FALLBACK_MODEL — openrouter no balance fallback model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_NO_BALANCE_FALLBACK_MODEL=deepseek/deepseek-v4-flash

OPENROUTER_NO_BALANCE_FALLBACK_MODEL=openrouter/free

# OPENROUTER_NO_BALANCE_COOLDOWN_SEC — openrouter no balance cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_NO_BALANCE_COOLDOWN_SEC=10

OPENROUTER_NO_BALANCE_COOLDOWN_SEC=900

# OPENROUTER_API_KEY — ключ OpenRouter для LLM/vision/STT.
#   Пусто — мозг и платные вызовы недоступны (остаются эвристики/RSS).

OPENROUTER_API_KEY=

# OPENROUTER_API_KEY_DEV — openrouter api key dev.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: OPENROUTER_API_KEY_DEV=<значение из панели провайдера>

OPENROUTER_API_KEY_DEV=

# OPENROUTER_MODEL_FREE — openrouter model free.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_FREE=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_FREE=openrouter/free

# --- «Dev» / тяжёлая ветка в коде (часто для сложного чата и рассуждений; в примере: DeepSeek Pro)
# См. core/llm_tiered.py, core/openrouter_provider.py. Контракт плагинов для бота/ИИ: docs/PLUGIN_AUTHOR_HANDBOOK_RU.md

OPENROUTER_MODEL_DEV=deepseek/deepseek-v4-pro

# OPENROUTER_MODEL_QWEN — openrouter model qwen.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_QWEN=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_QWEN=deepseek/deepseek-v4-flash

# OPENROUTER_MODEL_FREE — openrouter model free.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_FREE=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_FREE=deepseek/deepseek-v4-flash

# OPENROUTER_MODEL_DEV — openrouter model dev.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_DEV=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_DEV=deepseek/deepseek-v4-flash

# OPENROUTER_MODEL_QWEN — openrouter model qwen.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_QWEN=deepseek/deepseek-v4-flash

OPENROUTER_MODEL_QWEN=deepseek/deepseek-v4-flash

# MODEL_SWITCH_THRESHOLD — model switch threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MODEL_SWITCH_THRESHOLD=10

MODEL_SWITCH_THRESHOLD=100000

# BRAIN_LLM_FREE_MODEL — brain llm free model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: BRAIN_LLM_FREE_MODEL=deepseek/deepseek-v4-flash

BRAIN_LLM_FREE_MODEL=deepseek/deepseek-v4-flash

# BRAIN_FAST_CHITCHAT_MODEL — brain fast chitchat model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: BRAIN_FAST_CHITCHAT_MODEL=deepseek/deepseek-v4-flash

BRAIN_FAST_CHITCHAT_MODEL=deepseek/deepseek-v4-flash

# BRAIN_LLM_PREMIUM_MODEL — brain llm premium model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: BRAIN_LLM_PREMIUM_MODEL=deepseek/deepseek-v4-flash

BRAIN_LLM_PREMIUM_MODEL=deepseek/deepseek-v4-pro

# OPENROUTER_X_TITLE — openrouter x title.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_X_TITLE=<значение>

OPENROUTER_X_TITLE='Gemma Agent'

# USER_FACING_SHORT_TURN_MAX_CHARS — user facing short turn max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: USER_FACING_SHORT_TURN_MAX_CHARS=10

USER_FACING_SHORT_TURN_MAX_CHARS=56

# OPENROUTER_REASONING_FALLBACK_IF_EMPTY — openrouter reasoning fallback if empty.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_REASONING_FALLBACK_IF_EMPTY=true

OPENROUTER_REASONING_FALLBACK_IF_EMPTY=true

# OPENROUTER_REASONING_FALLBACK_MAX_CHARS — openrouter reasoning fallback max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_REASONING_FALLBACK_MAX_CHARS=10

OPENROUTER_REASONING_FALLBACK_MAX_CHARS=12000

# OPENROUTER_REASONING_FALLBACK_SKIP_R1 — openrouter reasoning fallback skip r1.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_REASONING_FALLBACK_SKIP_R1=true

OPENROUTER_REASONING_FALLBACK_SKIP_R1=true

# OPENROUTER_EXPOSE_REASONING — openrouter expose reasoning.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_EXPOSE_REASONING=true

OPENROUTER_EXPOSE_REASONING=false

# OPENROUTER_PROMPT_CACHE_MODE — openrouter prompt cache mode.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_PROMPT_CACHE_MODE=true

OPENROUTER_PROMPT_CACHE_MODE=off

# OPENROUTER_PROMPT_CACHE_MODE — openrouter prompt cache mode.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_PROMPT_CACHE_MODE=<значение>

OPENROUTER_PROMPT_CACHE_MODE=anthropic_auto

# OPENROUTER_CACHE_FIRST_PROVIDERS — openrouter cache first providers.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_CACHE_FIRST_PROVIDERS=true

OPENROUTER_CACHE_FIRST_PROVIDERS=true

# OPENROUTER_CACHE_FIRST_DEFAULT_ORDER — openrouter cache first default order.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_CACHE_FIRST_DEFAULT_ORDER=<значение>

OPENROUTER_CACHE_FIRST_DEFAULT_ORDER=DeepSeek,baidu

# OPENROUTER_CACHE_FIRST_DEFAULT_IGNORE — openrouter cache first default ignore.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_CACHE_FIRST_DEFAULT_IGNORE=<значение>

OPENROUTER_CACHE_FIRST_DEFAULT_IGNORE=deepinfra

# OPENROUTER_PROVIDER_ORDER — openrouter provider order.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_PROVIDER_ORDER=<значение>

OPENROUTER_PROVIDER_ORDER=DeepSeek,baidu

# OPENROUTER_PROVIDER_QUANTIZATIONS — openrouter provider quantizations.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_PROVIDER_QUANTIZATIONS=<значение>

OPENROUTER_PROVIDER_QUANTIZATIONS=fp8

# OPENROUTER_PROVIDER_IGNORE — openrouter provider ignore.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_PROVIDER_IGNORE=<значение>

OPENROUTER_PROVIDER_IGNORE=deepinfra

# OPENROUTER_PROVIDER_ALLOW_FALLBACKS — openrouter provider allow fallbacks.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true

OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true

# OPENROUTER_ANTHROPIC_CACHE_TTL — openrouter anthropic cache ttl.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_ANTHROPIC_CACHE_TTL=10

# OPENROUTER_ANTHROPIC_CACHE_TTL=

# --- Сессионный KV-кэш (X-Session-Id) для OpenRouter.
#     Включён по умолчанию: бот отправляет заголовок X-Session-Id в каждый запрос.
#     OpenRouter использует его для привязки prefix-cache к сессии пользователя.
#     Выключите (false), если кэш мешает или нужна изоляция каждого запроса.

OPENROUTER_SESSION_HEADERS_ENABLED=true

# OPENROUTER_ANTHROPIC_CACHE_TTL — openrouter anthropic cache ttl.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_ANTHROPIC_CACHE_TTL=10

OPENROUTER_ANTHROPIC_CACHE_TTL=1h

# OPENROUTER_CACHE_STABLE_HINTS_FOR_SHALLOW — openrouter cache stable hints for shallow.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPENROUTER_CACHE_STABLE_HINTS_FOR_SHALLOW=true

OPENROUTER_CACHE_STABLE_HINTS_FOR_SHALLOW=true

# ADMIN_KV_DEBUG_WINDOW_ROWS — admin kv debug window rows.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: ADMIN_KV_DEBUG_WINDOW_ROWS=<значение>

ADMIN_KV_DEBUG_WINDOW_ROWS=20

# OPENROUTER_GEN_TEMPERATURE — openrouter gen temperature.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_TEMPERATURE=<значение>

OPENROUTER_GEN_TEMPERATURE=0.6

# OPENROUTER_GEN_TOP_P — openrouter gen top p.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_TOP_P=<значение>

OPENROUTER_GEN_TOP_P=0.8

# OPENROUTER_GEN_MAX_TOKENS — openrouter gen max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_GEN_MAX_TOKENS=10

OPENROUTER_GEN_MAX_TOKENS=2000

# OPENROUTER_GEN_PRESENCE_PENALTY — openrouter gen presence penalty.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_PRESENCE_PENALTY=<значение>

OPENROUTER_GEN_PRESENCE_PENALTY=0.0

# OPENROUTER_GEN_FREQUENCY_PENALTY — openrouter gen frequency penalty.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_FREQUENCY_PENALTY=<значение>

OPENROUTER_GEN_FREQUENCY_PENALTY=0.0

# OPENROUTER_GEN_REPETITION_PENALTY — openrouter gen repetition penalty.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_REPETITION_PENALTY=<значение>

OPENROUTER_GEN_REPETITION_PENALTY=0.0

# OPENROUTER_GEN_TOP_K — openrouter gen top k.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_TOP_K=<значение>

OPENROUTER_GEN_TOP_K=40

# OPENROUTER_GEN_MIN_P — openrouter gen min p.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OPENROUTER_GEN_MIN_P=10

OPENROUTER_GEN_MIN_P=0.05

# OPENROUTER_GEN_SEED — openrouter gen seed.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_SEED=<значение>

OPENROUTER_GEN_SEED=42

# OPENROUTER_REASONING_ENABLED — master switch unified reasoning map.
OPENROUTER_REASONING_ENABLED=true

# OPENROUTER_REASONING_EXCLUDE — exclude reasoning from response body (internal CoT).
OPENROUTER_REASONING_EXCLUDE=true

# OPENROUTER_BRAIN_REASONING_EFFORT — default effort for brain_* telemetry tags.
OPENROUTER_BRAIN_REASONING_EFFORT=high

# OPENROUTER_REASONING_HIGH_MIN_MAX_TOKENS — floor max_tokens when effort high/xhigh.
OPENROUTER_REASONING_HIGH_MIN_MAX_TOKENS=2048

# OPENROUTER_REASONING_MODEL_PREFIXES — comma-separated model slug prefixes.
OPENROUTER_REASONING_MODEL_PREFIXES=deepseek/

# OPENROUTER_GEN_REASONING_EFFORT — global effort for non-brain tags (none=off).
OPENROUTER_GEN_REASONING_EFFORT=none

OPENROUTER_GEN_BRAIN_FIRST_REASONING_EFFORT=high

OPENROUTER_GEN_BRAIN_SECOND_REASONING_EFFORT=high

# OPENROUTER_GEN_STOP — openrouter gen stop.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_STOP=<значение>

OPENROUTER_GEN_STOP=["```","</answer>"]

# OPENROUTER_GEN_STOP — openrouter gen stop.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_GEN_STOP=<значение>

OPENROUTER_GEN_STOP='```||</answer>'

#
# Точечные оверрайды по telemetry_tag:
# OPENROUTER_GEN_<TAG>_TEMPERATURE=...
# OPENROUTER_GEN_<TAG>_TOP_P=...
# OPENROUTER_GEN_<TAG>_MAX_TOKENS=...
# OPENROUTER_GEN_<TAG>_PRESENCE_PENALTY=...
# OPENROUTER_GEN_<TAG>_FREQUENCY_PENALTY=...
# OPENROUTER_GEN_<TAG>_REPETITION_PENALTY=...
# OPENROUTER_GEN_<TAG>_TOP_K=...
# OPENROUTER_GEN_<TAG>_MIN_P=...
# OPENROUTER_GEN_<TAG>_SEED=...
# OPENROUTER_GEN_<TAG>_REASONING_EFFORT=xhigh|high|medium|low|minimal|none
# OPENROUTER_GEN_<TAG>_STOP=["...","..."]  (или "a||b")
# Примеры tag: brain_first, brain_second, vision_precaption, task_outline.

OPENROUTER_GEN_BRAIN_FIRST_TEMPERATURE=0.4

# OPENROUTER_GEN_BRAIN_SECOND_TOP_P — openrouter gen brain second top p.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
