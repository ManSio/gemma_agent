#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_LLM_ETA_LEARN_ENABLED=true

BRAIN_LLM_ETA_LEARN_ENABLED=true

# BRAIN_LLM_ETA_LEARN_EMA_ALPHA — brain llm eta learn ema alpha.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_LLM_ETA_LEARN_EMA_ALPHA=<значение>

BRAIN_LLM_ETA_LEARN_EMA_ALPHA=0.12

# BRAIN_LLM_ETA_LEARN_MIN_SAMPLES — brain llm eta learn min samples.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_MIN_SAMPLES=10

BRAIN_LLM_ETA_LEARN_MIN_SAMPLES=4

# BRAIN_LLM_ETA_LEARN_BLEND_SPAN — brain llm eta learn blend span.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_LLM_ETA_LEARN_BLEND_SPAN=<значение>

BRAIN_LLM_ETA_LEARN_BLEND_SPAN=18

# BRAIN_LLM_ETA_LEARN_LAT_MIN_SEC — brain llm eta learn lat min sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_LAT_MIN_SEC=10

BRAIN_LLM_ETA_LEARN_LAT_MIN_SEC=0.35

# BRAIN_LLM_ETA_LEARN_LAT_MAX_SEC — brain llm eta learn lat max sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_LAT_MAX_SEC=10

BRAIN_LLM_ETA_LEARN_LAT_MAX_SEC=720

# BRAIN_LLM_ETA_LEARN_MAX_MULT — brain llm eta learn max mult.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_LEARN_MAX_MULT=10

BRAIN_LLM_ETA_LEARN_MAX_MULT=2.75

# OPENROUTER_HTTP_REFERER — openrouter http referer.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENROUTER_HTTP_REFERER=<значение>

OPENROUTER_HTTP_REFERER=https://github.com/gemma-agent/gemma-agent

# OPENAI_API_KEY — openai api key.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OPENAI_API_KEY=<значение>

# OPENAI_API_KEY=
