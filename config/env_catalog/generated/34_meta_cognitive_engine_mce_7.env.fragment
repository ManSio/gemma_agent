# =============================================================================
# Meta-Cognitive Engine (MCE) — Фаза 7
# =============================================================================
# Master switch: вкл/выкл весь MCE
# MCE_ENABLED — mce enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MCE_ENABLED=true

# MCE_ENABLED — mce enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MCE_ENABLED=true

MCE_ENABLED=true

# MCE_TICK_INTERVAL — mce tick interval.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MCE_TICK_INTERVAL=10

MCE_TICK_INTERVAL=5

# MCE_HEALER_FLOOD_EMIT_COOLDOWN_SEC — mce healer flood emit cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MCE_HEALER_FLOOD_EMIT_COOLDOWN_SEC=10

MCE_HEALER_FLOOD_EMIT_COOLDOWN_SEC=3600

# MCE_EXPERIMENT_ENABLED — mce experiment enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MCE_EXPERIMENT_ENABLED=true

MCE_EXPERIMENT_ENABLED=false

# MCE_DRIFT_LESSON_DECAY_DAYS — mce drift lesson decay days.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MCE_DRIFT_LESSON_DECAY_DAYS=<значение>

MCE_DRIFT_LESSON_DECAY_DAYS=7

# MCE_CONFIDENCE_RECOVERY_THRESHOLD — mce confidence recovery threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MCE_CONFIDENCE_RECOVERY_THRESHOLD=10

MCE_CONFIDENCE_RECOVERY_THRESHOLD=0.4

# MCE_HISTORY_MAX — mce history max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MCE_HISTORY_MAX=<значение>

MCE_HISTORY_MAX=100

# MCE_DIGEST_INTERVAL_HOURS — mce digest interval hours.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MCE_DIGEST_INTERVAL_HOURS=10

MCE_DIGEST_INTERVAL_HOURS=6
