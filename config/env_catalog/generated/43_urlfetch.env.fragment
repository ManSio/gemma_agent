# =============================================================================
# UrlFetch (мозг: загрузка страниц)
# =============================================================================

# URL_FETCH_ENABLED — url fetch enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: URL_FETCH_ENABLED=true

# URL_FETCH_ENABLED — url fetch enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: URL_FETCH_ENABLED=true

URL_FETCH_ENABLED=true

# URL_FETCH_MAX_BYTES — url fetch max bytes.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: URL_FETCH_MAX_BYTES=10

URL_FETCH_MAX_BYTES=2097152

# URL_FETCH_MAX_CHARS_RESPONSE — url fetch max chars response.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: URL_FETCH_MAX_CHARS_RESPONSE=10

URL_FETCH_MAX_CHARS_RESPONSE=12000

# URL_FETCH_MAX_REDIRECTS — url fetch max redirects.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: URL_FETCH_MAX_REDIRECTS=10

URL_FETCH_MAX_REDIRECTS=5

# URL_FETCH_TIMEOUT_SEC — url fetch timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: URL_FETCH_TIMEOUT_SEC=10

URL_FETCH_TIMEOUT_SEC=15

# URL_FETCH_MAX_CODE_CHARS — url fetch max code chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: URL_FETCH_MAX_CODE_CHARS=10

URL_FETCH_MAX_CODE_CHARS=8000

# По умолчанию в коде: браузероподобные заголовки и UA Chrome (меньше 403 на law.example.com и др.). Выключить: URL_FETCH_BROWSER_COMPAT=false
# При необходимости задайте свой UA: HTTP_USER_AGENT=Mozilla/5.0 ...

URL_FETCH_ACCEPT_LANGUAGE=ru-BY,ru-RU;q=0.9,ru;q=0.8,en;q=0.7

# URL_FETCH_MIRROR_BASE — url fetch mirror base.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: URL_FETCH_MIRROR_BASE=<значение>

URL_FETCH_MIRROR_BASE=https://r.jina.ai/

# URL_FETCH_MIRROR_HTTP_STATUSES — url fetch mirror http statuses.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: URL_FETCH_MIRROR_HTTP_STATUSES=<значение>

URL_FETCH_MIRROR_HTTP_STATUSES=401,403,429,451,503

# TASK_SCOUT_MAX_TOKENS — task scout max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TASK_SCOUT_MAX_TOKENS=10

TASK_SCOUT_MAX_TOKENS=1600

# TASK_SCOUT_PLAYBOOK_PATH — task scout playbook path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: TASK_SCOUT_PLAYBOOK_PATH=data/runtime/example.json

TASK_SCOUT_PLAYBOOK_PATH=   # по умолчанию data/runtime/task_scout_playbooks.jsonl

# TASK_SCOUT_PLAYBOOK_MAX_LINES — task scout playbook max lines.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TASK_SCOUT_PLAYBOOK_MAX_LINES=10

TASK_SCOUT_PLAYBOOK_MAX_LINES=2000

# USER_KNOWLEDGE_ARCHIVE_MAX_BYTES — user knowledge archive max bytes.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: USER_KNOWLEDGE_ARCHIVE_MAX_BYTES=10

USER_KNOWLEDGE_ARCHIVE_MAX_BYTES=2500000

# USER_KNOWLEDGE_ARCHIVE_DIR — user knowledge archive dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USER_KNOWLEDGE_ARCHIVE_DIR=data/runtime/example.json

USER_KNOWLEDGE_ARCHIVE_DIR=   # по умолчанию data/user_library/knowledge_archive

# USER_KNOWLEDGE_ARCHIVE_INDEX — user knowledge archive index.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: USER_KNOWLEDGE_ARCHIVE_INDEX=<значение>

USER_KNOWLEDGE_ARCHIVE_INDEX=  # по умолчанию data/runtime/user_knowledge_archive.jsonl

# USER_KNOWLEDGE_ARCHIVE_INDEX_MAX_LINES — user knowledge archive index max lines.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: USER_KNOWLEDGE_ARCHIVE_INDEX_MAX_LINES=10

USER_KNOWLEDGE_ARCHIVE_INDEX_MAX_LINES=8000

# USER_KNOWLEDGE_ARCHIVE_VERIFY_MAX_QUERIES — user knowledge archive verify max queries.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: USER_KNOWLEDGE_ARCHIVE_VERIFY_MAX_QUERIES=10

USER_KNOWLEDGE_ARCHIVE_VERIFY_MAX_QUERIES=2

# USER_KNOWLEDGE_ARCHIVE_SEARCH_MAX_FILES — user knowledge archive search max files.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: USER_KNOWLEDGE_ARCHIVE_SEARCH_MAX_FILES=10

USER_KNOWLEDGE_ARCHIVE_SEARCH_MAX_FILES=120   # лимит файлов на один вызов archive_search (полнотекст по заметкам и личной библиотеке)
