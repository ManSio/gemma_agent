# =============================================================================
# Тонкая настройка промпта мозга (core/brain/prompt_pack.py)
# =============================================================================
# Бюджет символов для user-промпта при полной сборке
# BRAIN_USER_PROMPT_BUDGET_CHARS — brain user prompt budget chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS=10

# BRAIN_USER_PROMPT_BUDGET_CHARS — brain user prompt budget chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS=10

BRAIN_USER_PROMPT_BUDGET_CHARS=16000

# BRAIN_USER_PROMPT_BUDGET_CHARS_HOT — brain user prompt budget chars hot.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS_HOT=10

BRAIN_USER_PROMPT_BUDGET_CHARS_HOT=9000

# BRAIN_USER_PROMPT_BUDGET_CHARS_IMAGE — brain user prompt budget chars image.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS_IMAGE=10

BRAIN_USER_PROMPT_BUDGET_CHARS_IMAGE=12000

# BRAIN_USER_PROMPT_BUDGET_CHARS_COMPACT — brain user prompt budget chars compact.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_PROMPT_BUDGET_CHARS_COMPACT=10

BRAIN_USER_PROMPT_BUDGET_CHARS_COMPACT=13000

# MESSAGE_ARCHIVE_PROMPT_TAIL — message archive prompt tail.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MESSAGE_ARCHIVE_PROMPT_TAIL=<значение>

MESSAGE_ARCHIVE_PROMPT_TAIL=15
