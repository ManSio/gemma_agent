# =============================================================================
# Движки оркестратора
# =============================================================================

# PREDICTIVE_BEHAVIOR_ENABLED — predictive behavior enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: PREDICTIVE_BEHAVIOR_ENABLED=true

# PREDICTIVE_BEHAVIOR_ENABLED — predictive behavior enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: PREDICTIVE_BEHAVIOR_ENABLED=true

PREDICTIVE_BEHAVIOR_ENABLED=true

# PREDICTIVE_CONFIDENCE_THRESHOLD — predictive confidence threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: PREDICTIVE_CONFIDENCE_THRESHOLD=10

PREDICTIVE_CONFIDENCE_THRESHOLD=0.6

# GOAL_ENGINE_ENABLED — goal engine enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_ENGINE_ENABLED=true

GOAL_ENGINE_ENABLED=true

# Goal Runner 2.0 (ядро): /goal_run «цель» → LLM-план JSON → /goal_step выполняет шаги (run_tool). По умолчанию выкл.
# Режим «исполнитель» (one-toggle): включает Goal Runner + автостарт + smart + автономный агент + run-all; алиас GOAL_RUNNER_ULTIMATE.

GOAL_RUNNER_EXECUTOR_MODE=true

# GOAL_RUNNER_ENABLED — goal runner enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_ENABLED=true

GOAL_RUNNER_ENABLED=false

# GOAL_RUNNER_AUTO_START — goal runner auto start.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_AUTO_START=true

GOAL_RUNNER_AUTO_START=true

# GOAL_RUNNER_AUTO_START_SMART — goal runner auto start smart.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_AUTO_START_SMART=true

GOAL_RUNNER_AUTO_START_SMART=false

# GOAL_RUNNER_AUTO_START_SMART_MIN_CHARS — goal runner auto start smart min chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_AUTO_START_SMART_MIN_CHARS=10

GOAL_RUNNER_AUTO_START_SMART_MIN_CHARS=120

# GOAL_RUNNER_MULTISTEP_MIN_CHARS — goal runner multistep min chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_MULTISTEP_MIN_CHARS=10

GOAL_RUNNER_MULTISTEP_MIN_CHARS=24

# GOAL_RUNNER_BRAIN_NUDGE — goal runner brain nudge.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_BRAIN_NUDGE=true

GOAL_RUNNER_BRAIN_NUDGE=true

# GOAL_RUNNER_TELEGRAM_PROGRESS — goal runner telegram progress.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_TELEGRAM_PROGRESS=true

GOAL_RUNNER_TELEGRAM_PROGRESS=false

# GOAL_RUNNER_STEAL_TURNS — goal runner steal turns.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_STEAL_TURNS=true

GOAL_RUNNER_STEAL_TURNS=false

# GOAL_RUNNER_MAX_PLAN_STEPS — goal runner max plan steps.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_MAX_PLAN_STEPS=10

GOAL_RUNNER_MAX_PLAN_STEPS=10

# GOAL_RUNNER_MAX_TOOLS_PER_MESSAGE — goal runner max tools per message.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_MAX_TOOLS_PER_MESSAGE=10

GOAL_RUNNER_MAX_TOOLS_PER_MESSAGE=3

# GOAL_RUNNER_STEP_RETRIES — goal runner step retries.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GOAL_RUNNER_STEP_RETRIES=<значение>

GOAL_RUNNER_STEP_RETRIES=2

# GOAL_RUNNER_TOOLS_CATALOG_CAP — goal runner tools catalog cap.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GOAL_RUNNER_TOOLS_CATALOG_CAP=<значение>

GOAL_RUNNER_TOOLS_CATALOG_CAP=120

# GOAL_RUNNER_MAX_WALL_TIME_SEC — goal runner max wall time sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_MAX_WALL_TIME_SEC=10

GOAL_RUNNER_MAX_WALL_TIME_SEC=300

# GOAL_RUNNER_MAX_REPLANS — goal runner max replans.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_MAX_REPLANS=10

GOAL_RUNNER_MAX_REPLANS=2

# GOAL_RUNNER_RUN_ALL_IN_ONE — goal runner run all in one.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_RUN_ALL_IN_ONE=true

GOAL_RUNNER_RUN_ALL_IN_ONE=false

# GOAL_RUNNER_RUN_ALL_MAX_TOOLS — goal runner run all max tools.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_RUN_ALL_MAX_TOOLS=10

GOAL_RUNNER_RUN_ALL_MAX_TOOLS=48

# GOAL_RUNNER_RUN_ALL_MAX_TOTAL_TOOLS — goal runner run all max total tools.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_RUN_ALL_MAX_TOTAL_TOOLS=10

GOAL_RUNNER_RUN_ALL_MAX_TOTAL_TOOLS=160

# GOAL_RUNNER_AUTONOMOUS_AGENT — goal runner autonomous agent.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_AUTONOMOUS_AGENT=true

GOAL_RUNNER_AUTONOMOUS_AGENT=false

# GOAL_RUNNER_AUTONOMOUS_MAX_CONTROLLER — goal runner autonomous max controller.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_AUTONOMOUS_MAX_CONTROLLER=10

GOAL_RUNNER_AUTONOMOUS_MAX_CONTROLLER=24

# GOAL_RUNNER_AUTONOMOUS_MAX_TAIL_REPLANS — goal runner autonomous max tail replans.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GOAL_RUNNER_AUTONOMOUS_MAX_TAIL_REPLANS=10

GOAL_RUNNER_AUTONOMOUS_MAX_TAIL_REPLANS=5

# GOAL_RUNNER_PLAN_VALIDATOR — goal runner plan validator.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_PLAN_VALIDATOR=true

GOAL_RUNNER_PLAN_VALIDATOR=true

# GOAL_RUNNER_PLAN_AUTO_APPEND_ANSWER — goal runner plan auto append answer.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_RUNNER_PLAN_AUTO_APPEND_ANSWER=true

GOAL_RUNNER_PLAN_AUTO_APPEND_ANSWER=false

# SELF_MAINTENANCE_ENABLED — self maintenance enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_MAINTENANCE_ENABLED=true

SELF_MAINTENANCE_ENABLED=true

# SELF_MAINTENANCE_INTERVAL_SEC — self maintenance interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_MAINTENANCE_INTERVAL_SEC=10

SELF_MAINTENANCE_INTERVAL_SEC=600

# SELF_IMPROVEMENT_ADVISOR_ENABLED — self improvement advisor enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_IMPROVEMENT_ADVISOR_ENABLED=true

SELF_IMPROVEMENT_ADVISOR_ENABLED=true

# Включает активную самопроверку: если проверка находит проблему,
# ответ заменяется на исправленный вариант или перегенерируется.
# Пока только для deep‑профиля.

SELF_VERIFY_ACTIVE=false

# SELF_VERIFY_MODEL — self verify model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_VERIFY_MODEL=deepseek/deepseek-v4-flash

SELF_VERIFY_MODEL=openai/gpt-4.1-nano

# SELF_VERIFY_TIMEOUT_SEC — self verify timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_VERIFY_TIMEOUT_SEC=10

SELF_VERIFY_TIMEOUT_SEC=35

# HEAVY_MODULES_UNDER_PRESSURE — heavy modules under pressure.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HEAVY_MODULES_UNDER_PRESSURE=<значение>

HEAVY_MODULES_UNDER_PRESSURE=rag,books_rag,vision_describe,vision_ocr,image_generator
