# =============================================================================
# Self-Learning Engine (core/self_learning/): closed-loop self-improvement from errors
# =============================================================================
# Enable the self-learning system. If 'false', no lessons are generated or injected.
# SELF_LEARNING_ENABLED — self learning enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_LEARNING_ENABLED=true

# SELF_LEARNING_ENABLED — self learning enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_LEARNING_ENABLED=true

SELF_LEARNING_ENABLED=true

# SELF_LEARNING_MAX_INJECTED_LESSONS — self learning max injected lessons.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_LEARNING_MAX_INJECTED_LESSONS=10

SELF_LEARNING_MAX_INJECTED_LESSONS=3

# SELF_LEARNING_RETENTION_HALF_LIFE_SEC — self learning retention half life sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_LEARNING_RETENTION_HALF_LIFE_SEC=10

SELF_LEARNING_RETENTION_HALF_LIFE_SEC=604800

# SELF_LEARNING_FORGET_THRESHOLD — self learning forget threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_LEARNING_FORGET_THRESHOLD=10

SELF_LEARNING_FORGET_THRESHOLD=0.1

# SELF_LEARNING_RETIRE_SCORE — self learning retire score.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_LEARNING_RETIRE_SCORE=<значение>

SELF_LEARNING_RETIRE_SCORE=0.2

# SELF_LEARNING_CON_SOLIDATE_SCORE — self learning con solidate score.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_LEARNING_CON_SOLIDATE_SCORE=<значение>

SELF_LEARNING_CON_SOLIDATE_SCORE=0.9

# SELF_LEARNING_REFLECTION_MODEL — self learning reflection model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_LEARNING_REFLECTION_MODEL=deepseek/deepseek-v4-flash

SELF_LEARNING_REFLECTION_MODEL=meta-llama/llama-3.1-8b-instruct
