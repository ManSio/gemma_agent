# =============================================================================
# Память диалога и ретеншн
# =============================================================================

# DIALOGUE_MEMORY_MAX — dialogue memory max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOGUE_MEMORY_MAX=<значение>

# DIALOGUE_MEMORY_MAX — dialogue memory max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOGUE_MEMORY_MAX=<значение>

DIALOGUE_MEMORY_MAX=10

# DIALOGUE_MESSAGE_ARCHIVE_ENABLED — dialogue message archive enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOGUE_MESSAGE_ARCHIVE_ENABLED=true

DIALOGUE_MESSAGE_ARCHIVE_ENABLED=true

# DIALOGUE_MESSAGE_ARCHIVE_MAX — dialogue message archive max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOGUE_MESSAGE_ARCHIVE_MAX=<значение>

DIALOGUE_MESSAGE_ARCHIVE_MAX=50

# DIALOGUE_ARCHIVE_BACKFILL_ENABLED — dialogue archive backfill enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOGUE_ARCHIVE_BACKFILL_ENABLED=true

DIALOGUE_ARCHIVE_BACKFILL_ENABLED=true

# DIALOGUE_ARCHIVE_BACKFILL_LAST_N — dialogue archive backfill last n.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOGUE_ARCHIVE_BACKFILL_LAST_N=<значение>

DIALOGUE_ARCHIVE_BACKFILL_LAST_N=15

# DIALOGUE_ARCHIVE_BACKFILL_LAST_N_ANALYSIS — dialogue archive backfill last n analysis.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOGUE_ARCHIVE_BACKFILL_LAST_N_ANALYSIS=<значение>

DIALOGUE_ARCHIVE_BACKFILL_LAST_N_ANALYSIS=40

# DIALOGUE_ARCHIVE_BACKFILL_SHORT_REPLY_CHARS — dialogue archive backfill short reply chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: DIALOGUE_ARCHIVE_BACKFILL_SHORT_REPLY_CHARS=10

DIALOGUE_ARCHIVE_BACKFILL_SHORT_REPLY_CHARS=120

# DIALOG_RECALL_NL_ROUTE_ENABLED — dialog recall nl route enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOG_RECALL_NL_ROUTE_ENABLED=true

DIALOG_RECALL_NL_ROUTE_ENABLED=false

# DIALOG_RECALL_BRAIN_TOOL_ENABLED — dialog recall brain tool enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOG_RECALL_BRAIN_TOOL_ENABLED=true

DIALOG_RECALL_BRAIN_TOOL_ENABLED=true

# DIALOG_MEMORY_RECALL_ENABLED — dialog memory recall enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOG_MEMORY_RECALL_ENABLED=true

DIALOG_MEMORY_RECALL_ENABLED=true

# DIALOG_RECALL_ARCHIVE_DEFAULT — dialog recall archive default.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOG_RECALL_ARCHIVE_DEFAULT=<значение>

DIALOG_RECALL_ARCHIVE_DEFAULT=28

# DIALOG_RECALL_SEARCH_WINDOW — dialog recall search window.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOG_RECALL_SEARCH_WINDOW=<значение>

DIALOG_RECALL_SEARCH_WINDOW=80

# DIALOG_RECALL_LINE_MAX — dialog recall line max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOG_RECALL_LINE_MAX=<значение>

DIALOG_RECALL_LINE_MAX=220

# DIALOG_RECALL_DIGEST_MAX — dialog recall digest max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: DIALOG_RECALL_DIGEST_MAX=<значение>

DIALOG_RECALL_DIGEST_MAX=5

# --- MemoryRecallFacade (core/memory_recall_facade.py): единый детерминированный recall в мозг (pipeline → external_hint)
# false — только относительное время «вчера/неделю назад»; true — дополнительно фон (summary+digest+хвост архива) при «продолжай/как раньше» и коротком recent_dialogue.

MEMORY_RECALL_AUTO_ENABLED=false

# MEMORY_RECALL_AUTO_MAX_RECENT_MESSAGES — memory recall auto max recent messages.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MEMORY_RECALL_AUTO_MAX_RECENT_MESSAGES=10

MEMORY_RECALL_AUTO_MAX_RECENT_MESSAGES=8

# MEMORY_RECALL_AUTO_ARCHIVE_TAIL — memory recall auto archive tail.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEMORY_RECALL_AUTO_ARCHIVE_TAIL=<значение>

MEMORY_RECALL_AUTO_ARCHIVE_TAIL=20

# MEMORY_RECALL_DIGEST_MAX — memory recall digest max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEMORY_RECALL_DIGEST_MAX=<значение>

MEMORY_RECALL_DIGEST_MAX=4

# MEMORY_RECALL_SELF_MODEL_BOOST_ENABLED — memory recall self model boost enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MEMORY_RECALL_SELF_MODEL_BOOST_ENABLED=true

MEMORY_RECALL_SELF_MODEL_BOOST_ENABLED=false

# MEMORY_RECALL_SELF_MODEL_CLARIFY_RATE_MIN — memory recall self model clarify rate min.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: MEMORY_RECALL_SELF_MODEL_CLARIFY_RATE_MIN=deepseek/deepseek-v4-flash

MEMORY_RECALL_SELF_MODEL_CLARIFY_RATE_MIN=0.35

# MEMORY_RECALL_SELF_MODEL_CONTEXT_STAB_MAX — memory recall self model context stab max.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: MEMORY_RECALL_SELF_MODEL_CONTEXT_STAB_MAX=deepseek/deepseek-v4-flash

MEMORY_RECALL_SELF_MODEL_CONTEXT_STAB_MAX=0.55

# DIALOG_RECALL_LLM_ENABLED — dialog recall llm enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOG_RECALL_LLM_ENABLED=true

DIALOG_RECALL_LLM_ENABLED=false

# DIALOG_RECALL_LLM_MAX_CHARS — dialog recall llm max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: DIALOG_RECALL_LLM_MAX_CHARS=10

DIALOG_RECALL_LLM_MAX_CHARS=9000

# RETENTION_LOG_DAYS — retention log days.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RETENTION_LOG_DAYS=<значение>

RETENTION_LOG_DAYS=30

# RETENTION_BEHAVIOR_DAYS — retention behavior days.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RETENTION_BEHAVIOR_DAYS=<значение>

RETENTION_BEHAVIOR_DAYS=90
