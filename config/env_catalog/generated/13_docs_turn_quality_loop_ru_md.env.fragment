# =============================================================================
# Фоновая перепроверка ходов — docs/TURN_QUALITY_LOOP_RU.md
# =============================================================================
# TURN_QUALITY_LOOP_ENABLED — turn quality loop enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_QUALITY_LOOP_ENABLED=true

# TURN_QUALITY_LOOP_ENABLED — turn quality loop enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_QUALITY_LOOP_ENABLED=true

TURN_QUALITY_LOOP_ENABLED=true

# TURN_QUALITY_AUTO_PENDING_CORRECTION — turn quality auto pending correction.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_QUALITY_AUTO_PENDING_CORRECTION=true

TURN_QUALITY_AUTO_PENDING_CORRECTION=true

# TURN_QUALITY_COMMERCE_ONLY_LEARNING — turn quality commerce only learning.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_QUALITY_COMMERCE_ONLY_LEARNING=true

TURN_QUALITY_COMMERCE_ONLY_LEARNING=true

# TURN_QUALITY_LESSON_DRAFT — turn quality lesson draft.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_QUALITY_LESSON_DRAFT=true

TURN_QUALITY_LESSON_DRAFT=true

# TURN_QUALITY_SCAN_ON_TICK — turn quality scan on tick.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_QUALITY_SCAN_ON_TICK=true

TURN_QUALITY_SCAN_ON_TICK=true

# TURN_QUALITY_SCAN_LIMIT — turn quality scan limit.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TURN_QUALITY_SCAN_LIMIT=10

TURN_QUALITY_SCAN_LIMIT=30

# TURN_QUALITY_SCAN_MAX_AGE_SEC — turn quality scan max age sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TURN_QUALITY_SCAN_MAX_AGE_SEC=10

TURN_QUALITY_SCAN_MAX_AGE_SEC=3600

# TURN_QUALITY_AUDIT_PATH — turn quality audit path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: TURN_QUALITY_AUDIT_PATH=data/runtime/example.json

TURN_QUALITY_AUDIT_PATH=data/runtime/quality_audit.jsonl
