# =============================================================================

# HEAVY_WORKER_ENABLED — heavy worker enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HEAVY_WORKER_ENABLED=true

# HEAVY_WORKER_ENABLED — heavy worker enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HEAVY_WORKER_ENABLED=true

HEAVY_WORKER_ENABLED=true

# HEAVY_WORKER_CONCURRENCY — heavy worker concurrency.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HEAVY_WORKER_CONCURRENCY=<значение>

HEAVY_WORKER_CONCURRENCY=2

# HEAVY_WORKER_QUEUE_MAX — heavy worker queue max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HEAVY_WORKER_QUEUE_MAX=<значение>

HEAVY_WORKER_QUEUE_MAX=500

# HEAVY_WORKER_TIMEOUT_SEC — heavy worker timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEAVY_WORKER_TIMEOUT_SEC=10

HEAVY_WORKER_TIMEOUT_SEC=120

# OP_TIMEOUT_SEC — op timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: OP_TIMEOUT_SEC=10

OP_TIMEOUT_SEC=120

# OP_RETRIES — op retries.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OP_RETRIES=<значение>

OP_RETRIES=2

# BRAIN_LLM_FREE_TIMEOUT_SEC — brain llm free timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_FREE_TIMEOUT_SEC=10

BRAIN_LLM_FREE_TIMEOUT_SEC=55

# BRAIN_LLM_PREMIUM_TIMEOUT_SEC — brain llm premium timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_PREMIUM_TIMEOUT_SEC=10

BRAIN_LLM_PREMIUM_TIMEOUT_SEC=180

# BRAIN_LLM_TIERED_RETRY — brain llm tiered retry.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_LLM_TIERED_RETRY=true

BRAIN_LLM_TIERED_RETRY=true

# BRAIN_LLM_FREE_ATTEMPTS — brain llm free attempts.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_LLM_FREE_ATTEMPTS=<значение>

BRAIN_LLM_FREE_ATTEMPTS=3

# BRAIN_LLM_FREE_RETRY_GAP_SEC — brain llm free retry gap sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_FREE_RETRY_GAP_SEC=10

BRAIN_LLM_FREE_RETRY_GAP_SEC=10

# BRAIN_LLM_WAIT_BEFORE_PREMIUM_SEC — brain llm wait before premium sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_WAIT_BEFORE_PREMIUM_SEC=10

BRAIN_LLM_WAIT_BEFORE_PREMIUM_SEC=15
