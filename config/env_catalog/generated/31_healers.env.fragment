# =============================================================================
# Healers — подписчики событийной шины
# =============================================================================
# ModuleFailureHealer: сколько падений модуля подряд до создания эфемерного патча
# HEALER_MODULE_MAX_FAILURES — healer module max failures.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_MODULE_MAX_FAILURES=10

# HEALER_MODULE_MAX_FAILURES — healer module max failures.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_MODULE_MAX_FAILURES=10

HEALER_MODULE_MAX_FAILURES=3

# HEALER_ANOMALY_WINDOW_SEC — healer anomaly window sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_ANOMALY_WINDOW_SEC=10

HEALER_ANOMALY_WINDOW_SEC=600

# HEALER_ANOMALY_MAX_COUNT — healer anomaly max count.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_ANOMALY_MAX_COUNT=10

HEALER_ANOMALY_MAX_COUNT=8

# HEALER_SAFE_MODE_REENTRY_COOLDOWN_SEC — healer safe mode reentry cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HEALER_SAFE_MODE_REENTRY_COOLDOWN_SEC=10

HEALER_SAFE_MODE_REENTRY_COOLDOWN_SEC=120
