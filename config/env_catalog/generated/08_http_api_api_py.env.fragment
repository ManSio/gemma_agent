# =============================================================================
# HTTP API (api.py)
# =============================================================================

# --- Включить REST API
# API_ENABLED — api enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: API_ENABLED=true

# API_ENABLED — api enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: API_ENABLED=true

API_ENABLED=true

# API_HOST — api host.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: API_HOST=<значение>

API_HOST=0.0.0.0

# API_PORT — api port.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: API_PORT=10

API_PORT=8000

# API_TOKEN — api token.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: API_TOKEN=<значение из панели провайдера>

API_TOKEN=

# API_RATE_LIMIT_ENABLED — api rate limit enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: API_RATE_LIMIT_ENABLED=true

API_RATE_LIMIT_ENABLED=true

# API_RATE_LIMIT_HEAVY_RPM — api rate limit heavy rpm.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: API_RATE_LIMIT_HEAVY_RPM=10

API_RATE_LIMIT_HEAVY_RPM=6

# API_RATE_LIMIT_HEAVY_MIN_INTERVAL_SEC — api rate limit heavy min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: API_RATE_LIMIT_HEAVY_MIN_INTERVAL_SEC=10

API_RATE_LIMIT_HEAVY_MIN_INTERVAL_SEC=10

# AGENT_PROBE_HTTP_MIN_INTERVAL_SEC — agent probe http min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AGENT_PROBE_HTTP_MIN_INTERVAL_SEC=10

AGENT_PROBE_HTTP_MIN_INTERVAL_SEC=12

# AGENT_PROBE_HTTP_ENDPOINT — agent probe http endpoint.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: AGENT_PROBE_HTTP_ENDPOINT=http://127.0.0.1:8001

AGENT_PROBE_HTTP_ENDPOINT=chat

# AGENT_PROBE_API_URL — agent probe api url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: AGENT_PROBE_API_URL=http://127.0.0.1:8001

AGENT_PROBE_API_URL=http://127.0.0.1:8000

# OPS_TRACE_ENABLED — ops trace enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: OPS_TRACE_ENABLED=true

OPS_TRACE_ENABLED=true

# GEMMA_OPS_TRACE_PATH — gemma ops trace path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_OPS_TRACE_PATH=data/runtime/example.json

GEMMA_OPS_TRACE_PATH=data/runtime/ops_trace.jsonl

# BRAIN_INCLUDE_ARCHIVE_IN_PROMPT — brain include archive in prompt.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_INCLUDE_ARCHIVE_IN_PROMPT=true

BRAIN_INCLUDE_ARCHIVE_IN_PROMPT=false

# TELEGRAM_SINGLE_BEST_OUTPUT — telegram single best output.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TELEGRAM_SINGLE_BEST_OUTPUT=true

TELEGRAM_SINGLE_BEST_OUTPUT=true

# API_CORS_ENABLED — api cors enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: API_CORS_ENABLED=true

API_CORS_ENABLED=false

# API_CORS_ORIGINS — api cors origins.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: API_CORS_ORIGINS=<значение>

API_CORS_ORIGINS=*
