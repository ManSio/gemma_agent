# =============================================================================
# Глубина задачи, память стратегий (путь шагов), микро-план LLM, цепочка инструментов
# =============================================================================
# task_tier: shallow | nested | deep — эвристика по текущему тексту и последним репликам пользователя; в goal_plan и dialogue_state.
# STRATEGY_LLM_OUTLINE_* — JSON outline с опциональным scenarios[] (сценарные ветки); поднимает tier при multi/thorough.
# Успешный ход с непустым lookahead.steps → строка в strategy_paths.jsonl (сводка шагов).
# Подсказка в промпт для nested/deep; для shallow тоже — только если:
# STRATEGY_PATH_HINT_FOR_SHALLOW — strategy path hint for shallow.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: STRATEGY_PATH_HINT_FOR_SHALLOW=true

# STRATEGY_PATH_HINT_FOR_SHALLOW — strategy path hint for shallow.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: STRATEGY_PATH_HINT_FOR_SHALLOW=true

STRATEGY_PATH_HINT_FOR_SHALLOW=false

# STRATEGY_PATH_MEMORY_ENABLED — strategy path memory enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: STRATEGY_PATH_MEMORY_ENABLED=true

STRATEGY_PATH_MEMORY_ENABLED=true

# GEMMA_STRATEGY_PATH — gemma strategy path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_STRATEGY_PATH=data/runtime/example.json

GEMMA_STRATEGY_PATH=data/runtime/strategy_paths.jsonl

# STRATEGY_PATH_MAX_LINES — strategy path max lines.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: STRATEGY_PATH_MAX_LINES=10

STRATEGY_PATH_MAX_LINES=6000

# STRATEGY_PATH_LOOKBACK — strategy path lookback.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: STRATEGY_PATH_LOOKBACK=data/runtime/example.json

STRATEGY_PATH_LOOKBACK=160

# STRATEGY_LLM_OUTLINE_ENABLED — strategy llm outline enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: STRATEGY_LLM_OUTLINE_ENABLED=true

STRATEGY_LLM_OUTLINE_ENABLED=true

# STRATEGY_LLM_OUTLINE_MIN_CHARS — strategy llm outline min chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: STRATEGY_LLM_OUTLINE_MIN_CHARS=10

STRATEGY_LLM_OUTLINE_MIN_CHARS=420

# STRATEGY_LLM_OUTLINE_ALWAYS — strategy llm outline always.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: STRATEGY_LLM_OUTLINE_ALWAYS=true

STRATEGY_LLM_OUTLINE_ALWAYS=false

# STRATEGY_LLM_OUTLINE_MAX_TOKENS — strategy llm outline max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: STRATEGY_LLM_OUTLINE_MAX_TOKENS=10

STRATEGY_LLM_OUTLINE_MAX_TOKENS=320

# OPENROUTER_MODEL_TASK_OUTLINE — openrouter model task outline.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_TASK_OUTLINE=deepseek/deepseek-v4-flash

# OPENROUTER_MODEL_TASK_OUTLINE=

#
# Мета-намерение: один короткий JSON-классификатор до мозга (обратная связь / разбор переписки / сброс сюжета).
# Выкл по умолчанию — без лишнего запроса к API; GEMMA_AUTOPILOT_MODE подставляет true.

META_INTENT_PROBE_ENABLED=false

# META_INTENT_MIN_CONFIDENCE — meta intent min confidence.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: META_INTENT_MIN_CONFIDENCE=10

META_INTENT_MIN_CONFIDENCE=0.5

# META_INTENT_MAX_TOKENS — meta intent max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: META_INTENT_MAX_TOKENS=10

META_INTENT_MAX_TOKENS=120

# META_INTENT_MAX_USER_CHARS — meta intent max user chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: META_INTENT_MAX_USER_CHARS=10

META_INTENT_MAX_USER_CHARS=3200

# META_INTENT_PROBE_MIN_USER_CHARS — meta intent probe min user chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: META_INTENT_PROBE_MIN_USER_CHARS=10

META_INTENT_PROBE_MIN_USER_CHARS=4

# OPENROUTER_MODEL_META_INTENT — openrouter model meta intent.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: OPENROUTER_MODEL_META_INTENT=deepseek/deepseek-v4-flash

# OPENROUTER_MODEL_META_INTENT=

# BRAIN_TOOL_CHAIN_MAX — brain tool chain max.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_TOOL_CHAIN_MAX=true

BRAIN_TOOL_CHAIN_MAX=0
