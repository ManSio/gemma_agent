# =============================================================================
# Автопилот и дайджесты
# =============================================================================

# --- Режим автопилота ядра: on/off (см. core/autopilot_mode.py).
#     При on подставляются только пустые переменные: логи/сеть/тики + адаптация мозга
#     (STRATEGY_LLM_OUTLINE_*, BRAIN_TOOL_CHAIN_MAX, BRAIN_TOOL_ROUTING_HINT, LOOKAHEAD_*).
#     Явные строки в .env всегда важнее — тонкую настройку не нужно отключать «вручную» пакетом.
# GEMMA_AUTOPILOT_MODE — пакет дефолтов автопилота (on/off).
#   on — подставляет пустые ключи из autopilot_mode.py (логи, tool chain…).
#   off — только то, что явно задано в .env.

# GEMMA_AUTOPILOT_MODE — пакет дефолтов автопилота (on/off).
#   on — подставляет пустые ключи из autopilot_mode.py (логи, tool chain…).
#   off — только то, что явно задано в .env.

GEMMA_AUTOPILOT_MODE=on

# DIALOGUE_FEEDBACK_SIGNALS_ENABLED — dialogue feedback signals enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOGUE_FEEDBACK_SIGNALS_ENABLED=true

DIALOGUE_FEEDBACK_SIGNALS_ENABLED=true

# AUTOPILOT_CYCLE_INTERVAL_SEC — autopilot cycle interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_CYCLE_INTERVAL_SEC=10

AUTOPILOT_CYCLE_INTERVAL_SEC=900

# AUTOPILOT_INNER_TICK_SEC — autopilot inner tick sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_INNER_TICK_SEC=10

AUTOPILOT_INNER_TICK_SEC=60

# AUTOPILOT_REPORT_TO_ADMINS — autopilot report to admins.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_REPORT_TO_ADMINS=true

AUTOPILOT_REPORT_TO_ADMINS=true

# AUTOPILOT_LLM_TRIAGE_ENABLED — autopilot llm triage enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_TRIAGE_ENABLED=true

AUTOPILOT_LLM_TRIAGE_ENABLED=false

# AUTOPILOT_LLM_TRIAGE_MIN_ANOMALIES — autopilot llm triage min anomalies.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_TRIAGE_MIN_ANOMALIES=true

AUTOPILOT_LLM_TRIAGE_MIN_ANOMALIES=1

# AUTOPILOT_LLM_TRIAGE_COOLDOWN_SEC — autopilot llm triage cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_TRIAGE_COOLDOWN_SEC=10

AUTOPILOT_LLM_TRIAGE_COOLDOWN_SEC=3600

# AUTOPILOT_LLM_TRIAGE_MAX_PAYLOAD_CHARS — autopilot llm triage max payload chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_TRIAGE_MAX_PAYLOAD_CHARS=10

AUTOPILOT_LLM_TRIAGE_MAX_PAYLOAD_CHARS=12000

# AUTOPILOT_LLM_TRIAGE_MAX_REPLY_CHARS — autopilot llm triage max reply chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_TRIAGE_MAX_REPLY_CHARS=10

AUTOPILOT_LLM_TRIAGE_MAX_REPLY_CHARS=3500

# AUTOPILOT_LLM_TRIAGE_REQUIRE_DM_REPORT — autopilot llm triage require dm report.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_TRIAGE_REQUIRE_DM_REPORT=true

AUTOPILOT_LLM_TRIAGE_REQUIRE_DM_REPORT=false

# AUTOPILOT_ACTIONS_ENABLED — autopilot actions enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_ACTIONS_ENABLED=true

AUTOPILOT_ACTIONS_ENABLED=true

# AUTOPILOT_DIGEST_HOURS_UTC — autopilot digest hours utc.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_DIGEST_HOURS_UTC=10

AUTOPILOT_DIGEST_HOURS_UTC=8,20

# AUTOPILOT_DIGEST_QUIET_ONLY — autopilot digest quiet only.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_DIGEST_QUIET_ONLY=true

AUTOPILOT_DIGEST_QUIET_ONLY=false

# AUTOPILOT_IDLE_MIN_SEC — autopilot idle min sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_IDLE_MIN_SEC=10

AUTOPILOT_IDLE_MIN_SEC=900

# AUTOPILOT_IDLE_LLM_PROBE — autopilot idle llm probe.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_IDLE_LLM_PROBE=true

AUTOPILOT_IDLE_LLM_PROBE=true

# AUTOPILOT_IDLE_LLM_PROBE_MODEL — autopilot idle llm probe model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: AUTOPILOT_IDLE_LLM_PROBE_MODEL=deepseek/deepseek-v4-flash

AUTOPILOT_IDLE_LLM_PROBE_MODEL=openrouter/free

# AUTOPILOT_QUIET_HOURS_UTC — autopilot quiet hours utc.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_QUIET_HOURS_UTC=10

AUTOPILOT_QUIET_HOURS_UTC=0,1,2,3,4,5,22,23

# AUTOPILOT_LLM_PROBE_MIN_INTERVAL_SEC — autopilot llm probe min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: AUTOPILOT_LLM_PROBE_MIN_INTERVAL_SEC=10

AUTOPILOT_LLM_PROBE_MIN_INTERVAL_SEC=7200

# AUTOPILOT_LLM_PROBE_NOTIFY_ON_FAIL — autopilot llm probe notify on fail.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTOPILOT_LLM_PROBE_NOTIFY_ON_FAIL=true

AUTOPILOT_LLM_PROBE_NOTIFY_ON_FAIL=true

# USAGE_LEARNING_SAVE_EVERY — usage learning save every.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: USAGE_LEARNING_SAVE_EVERY=<значение>

USAGE_LEARNING_SAVE_EVERY=25

# USAGE_LEARNING_STATE_PATH — usage learning state path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USAGE_LEARNING_STATE_PATH=data/runtime/example.json

USAGE_LEARNING_STATE_PATH=./data/runtime/usage_learning_state.json

# USAGE_LEARNING_DIGEST_PATH — usage learning digest path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USAGE_LEARNING_DIGEST_PATH=data/runtime/example.json

USAGE_LEARNING_DIGEST_PATH=./data/runtime/usage_learning_digest_checkpoint.json
