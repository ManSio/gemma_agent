# =============================================================================
# Автономные бэкапы
# =============================================================================

# AUTONOMY_LAYER_ENABLED — autonomy layer enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTONOMY_LAYER_ENABLED=true

# AUTONOMY_LAYER_ENABLED — autonomy layer enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTONOMY_LAYER_ENABLED=true

AUTONOMY_LAYER_ENABLED=true

# AUTONOMY_BACKUP_ROOT — autonomy backup root.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: AUTONOMY_BACKUP_ROOT=<значение>

AUTONOMY_BACKUP_ROOT=./data/autonomy_backups

# AUTONOMY_BACKUP_RETENTION — autonomy backup retention.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: AUTONOMY_BACKUP_RETENTION=<значение>

AUTONOMY_BACKUP_RETENTION=14

# AUTONOMY_BACKUP_EVERY_N_MAINTENANCE — autonomy backup every n maintenance.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: AUTONOMY_BACKUP_EVERY_N_MAINTENANCE=true

AUTONOMY_BACKUP_EVERY_N_MAINTENANCE=1

# AUTONOMY_CRITICAL_PATHS — autonomy critical paths.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: AUTONOMY_CRITICAL_PATHS=data/runtime/example.json

AUTONOMY_CRITICAL_PATHS=
