# =============================================================================
# Mem0 (HTTP API v3: облако или локальный mem0_server, опционально)
# =============================================================================

# --- Базовый URL API Mem0 (без /api/v1 — пути добиваются в коде)
# MEM0_API_URL — mem0 api url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: MEM0_API_URL=http://127.0.0.1:8001

# MEM0_API_URL — mem0 api url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: MEM0_API_URL=http://127.0.0.1:8001

MEM0_API_URL=https://api.mem0.ai

# MEM0_API_KEY — mem0 api key.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: MEM0_API_KEY=<значение из панели провайдера>

MEM0_API_KEY=

# MEM0_LOCAL — память через локальный mem0_server (true) или облако Mem0.
#   true + MEM0_API_URL=http://127.0.0.1:8001 — типично на deploy-host.

MEM0_LOCAL=true

# MEM0_API_URL — mem0 api url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: MEM0_API_URL=http://127.0.0.1:8001

MEM0_API_URL=http://127.0.0.1:8001

# MEM0_LOCAL_API_KEY — mem0 local api key.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_LOCAL_API_KEY=<значение>

MEM0_LOCAL_API_KEY=local

# Синоним флага: MEM0_SELF_HOSTED=true
# Локальный сервер с эмбеддингами (rewrite выкл по умолчанию): scripts/mem0_local_server.py

MEM0_LLM_REWRITE=false

# MEM0_LLM_COMPRESS — mem0 llm compress.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MEM0_LLM_COMPRESS=true

MEM0_LLM_COMPRESS=false

# MEM0_OPENROUTER_PROVIDER_ORDER — mem0 openrouter provider order.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_OPENROUTER_PROVIDER_ORDER=<значение>

MEM0_OPENROUTER_PROVIDER_ORDER=DeepSeek,baidu

# MEM0_OPENROUTER_PROVIDER_IGNORE — mem0 openrouter provider ignore.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_OPENROUTER_PROVIDER_IGNORE=<значение>

MEM0_OPENROUTER_PROVIDER_IGNORE=deepinfra

#
# --- Префикс путей к memories (по умолчанию v3 → /v3/memories/... как у Mem0 Platform).
# Если локальный сервер отдаёт 404 на /v3/..., откройте его /docs и выставьте префикс под ваши маршруты;
# пустое значение MEM0_API_PREFIX= — запросы пойдут в /memories/... от корня MEM0_API_URL.

MEM0_API_PREFIX=v3

# MEM0_MIRROR_API_KEY — mem0 mirror api key.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MEM0_MIRROR_API_KEY=<значение>

# MEM0_MIRROR_API_KEY=

# MEM0_MIRROR_WRITE — mem0 mirror write.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MEM0_MIRROR_WRITE=true

MEM0_MIRROR_WRITE=true
