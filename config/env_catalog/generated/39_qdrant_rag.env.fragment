# =============================================================================
# Qdrant (RAG книг и т.п.)
# =============================================================================

# QDRANT_URL — qdrant url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: QDRANT_URL=http://127.0.0.1:8001

# QDRANT_URL — qdrant url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: QDRANT_URL=http://127.0.0.1:8001

QDRANT_URL=

# QDRANT_API_KEY — qdrant api key.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: QDRANT_API_KEY=<значение из панели провайдера>

QDRANT_API_KEY=

# QDRANT_COLLECTION — qdrant collection.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: QDRANT_COLLECTION=<значение>

QDRANT_COLLECTION=gemma_books_rag

# QDRANT_EMBEDDING_MODEL — qdrant embedding model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: QDRANT_EMBEDDING_MODEL=deepseek/deepseek-v4-flash

QDRANT_EMBEDDING_MODEL=openai/text-embedding-3-small
