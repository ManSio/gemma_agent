# =============================================================================
# Сеть и проверки
# =============================================================================

# CONNECTIVITY_CHECK_TIMEOUT_SEC — connectivity check timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CONNECTIVITY_CHECK_TIMEOUT_SEC=10

# CONNECTIVITY_CHECK_TIMEOUT_SEC — connectivity check timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CONNECTIVITY_CHECK_TIMEOUT_SEC=10

CONNECTIVITY_CHECK_TIMEOUT_SEC=25

# CONNECTIVITY_INCLUDE_HTTP_PROBES — connectivity include http probes.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CONNECTIVITY_INCLUDE_HTTP_PROBES=true

CONNECTIVITY_INCLUDE_HTTP_PROBES=true

# CONNECTIVITY_SKIP_PLUGIN_HTTP_PROBES — connectivity skip plugin http probes.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CONNECTIVITY_SKIP_PLUGIN_HTTP_PROBES=true

CONNECTIVITY_SKIP_PLUGIN_HTTP_PROBES=false

# CONNECTIVITY_EXTRA_HTTP_PROBES — connectivity extra http probes.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CONNECTIVITY_EXTRA_HTTP_PROBES=<значение>

# CONNECTIVITY_EXTRA_HTTP_PROBES=

# NETWORK_PROBE_TIMEOUT_SEC — network probe timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NETWORK_PROBE_TIMEOUT_SEC=10

NETWORK_PROBE_TIMEOUT_SEC=12

# GEMMA_LIVE_NETWORK — gemma live network.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_LIVE_NETWORK=true

GEMMA_LIVE_NETWORK=1
