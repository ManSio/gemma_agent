# =============================================================================
# Site Recipe (core/site_recipe_*.py): парсинг сайтов по рецептам
# =============================================================================
# Директория рецептов
# SITE_RECIPE_DIR — site recipe dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: SITE_RECIPE_DIR=data/runtime/example.json

# SITE_RECIPE_DIR — site recipe dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: SITE_RECIPE_DIR=data/runtime/example.json

SITE_RECIPE_DIR=./data/site_recipes

# SITE_RECIPE_CACHE_DIR — site recipe cache dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: SITE_RECIPE_CACHE_DIR=data/runtime/example.json

# SITE_RECIPE_CACHE_DIR=

# SITE_RECIPE_CACHE_SKIP — site recipe cache skip.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_CACHE_SKIP=true

SITE_RECIPE_CACHE_SKIP=false

# SITE_RECIPE_MAX_CODE_CHARS — site recipe max code chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_MAX_CODE_CHARS=10

SITE_RECIPE_MAX_CODE_CHARS=8000

# SITE_RECIPE_LEARN_ADMINS — site recipe learn admins.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SITE_RECIPE_LEARN_ADMINS=<значение>

# SITE_RECIPE_LEARN_ADMINS=

# SITE_RECIPE_MKDOCS_HOSTS — site recipe mkdocs hosts.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SITE_RECIPE_MKDOCS_HOSTS=<значение>

# SITE_RECIPE_MKDOCS_HOSTS=

# SITE_RECIPE_UPLOAD_TTL_SEC — site recipe upload ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_UPLOAD_TTL_SEC=10

SITE_RECIPE_UPLOAD_TTL_SEC=600

# SITE_RECIPE_UPLOAD_DEFER_TTL_SEC — site recipe upload defer ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_UPLOAD_DEFER_TTL_SEC=10

SITE_RECIPE_UPLOAD_DEFER_TTL_SEC=1800

# SITE_RECIPE_UPLOAD_MAX_FILES — site recipe upload max files.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_UPLOAD_MAX_FILES=10

SITE_RECIPE_UPLOAD_MAX_FILES=20

# SITE_RECIPE_UPLOAD_MAX_BYTES — site recipe upload max bytes.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_UPLOAD_MAX_BYTES=10

SITE_RECIPE_UPLOAD_MAX_BYTES=524288
