# =============================================================================
# Brain и Telegram UX
# =============================================================================

# BRAIN_DEDUP_MEMORY — brain dedup memory.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_DEDUP_MEMORY=true

# BRAIN_DEDUP_MEMORY — brain dedup memory.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_DEDUP_MEMORY=true

BRAIN_DEDUP_MEMORY=true

# BRAIN_USER_INPUT_HEAVY_GUARD — brain user input heavy guard.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_USER_INPUT_HEAVY_GUARD=true

BRAIN_USER_INPUT_HEAVY_GUARD=true

# BRAIN_USER_INPUT_HEAVY_CHAR_THRESHOLD — brain user input heavy char threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_INPUT_HEAVY_CHAR_THRESHOLD=10

BRAIN_USER_INPUT_HEAVY_CHAR_THRESHOLD=12000

# BRAIN_USER_INPUT_HEAVY_SCAN_MIN_CHARS — brain user input heavy scan min chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_INPUT_HEAVY_SCAN_MIN_CHARS=10

BRAIN_USER_INPUT_HEAVY_SCAN_MIN_CHARS=500

# BRAIN_USER_INPUT_HEAVY_MIN_UNIQUE_WORDS — brain user input heavy min unique words.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_USER_INPUT_HEAVY_MIN_UNIQUE_WORDS=10

BRAIN_USER_INPUT_HEAVY_MIN_UNIQUE_WORDS=18

# BRAIN_USER_INPUT_HEAVY_REPEAT_RATIO — brain user input heavy repeat ratio.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_USER_INPUT_HEAVY_REPEAT_RATIO=<значение>

BRAIN_USER_INPUT_HEAVY_REPEAT_RATIO=0.06

# --- Дополнительные inline-кнопки под ответом в обычном диалоге (первый шаг плана — chat-orchestrator с пустым buttons).
# Имена модулей через запятую, как в modules/<name>/module.json (поле "name"). Берутся manifest.buttons этих модулей и склеиваются.
# Пример: math,echo,vision_ocr

# TELEGRAM_EXTRA_REPLY_BUTTON_MODULES=

# MATH_AMBIGUOUS_SKIP_LONG_PROSE_CHARS — math ambiguous skip long prose chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MATH_AMBIGUOUS_SKIP_LONG_PROSE_CHARS=10

MATH_AMBIGUOUS_SKIP_LONG_PROSE_CHARS=320

# TELEGRAM_REPLY_TO_USER_MESSAGE — telegram reply to user message.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TELEGRAM_REPLY_TO_USER_MESSAGE=true

TELEGRAM_REPLY_TO_USER_MESSAGE=true

# TELEGRAM_PIPELINE_SERIALIZE_BY_CHAT — telegram pipeline serialize by chat.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TELEGRAM_PIPELINE_SERIALIZE_BY_CHAT=true

TELEGRAM_PIPELINE_SERIALIZE_BY_CHAT=true

# TELEGRAM_PIPELINE_PRIVATE_PARALLEL — параллельные ходы в личке.
#   1 — последовательно (рекомендуется): нет ответа «на прошлый вопрос».
#   2+ — параллель; риск перепутанного контекста (см. INCIDENT_2026-05-20).

TELEGRAM_PIPELINE_PRIVATE_PARALLEL=1

# POST_DEPLOY_SMOKE_ENABLED — post deploy smoke enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: POST_DEPLOY_SMOKE_ENABLED=true

POST_DEPLOY_SMOKE_ENABLED=true

# POST_DEPLOY_PROBE — post deploy probe.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: POST_DEPLOY_PROBE=true

POST_DEPLOY_PROBE=true

# POST_DEPLOY_PROBE_USER_ID — post deploy probe user id.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: POST_DEPLOY_PROBE_USER_ID=<значение>

POST_DEPLOY_PROBE_USER_ID=123456789
