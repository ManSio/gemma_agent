# =============================================================================
# Контракт продукта (pivot / search / reply gates) — docs/PRODUCT_BEHAVIOR_CONTRACT_RU.md
# =============================================================================
# PRODUCT_BEHAVIOR_ENABLED — product behavior enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: PRODUCT_BEHAVIOR_ENABLED=true

# PRODUCT_BEHAVIOR_ENABLED — product behavior enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: PRODUCT_BEHAVIOR_ENABLED=true

PRODUCT_BEHAVIOR_ENABLED=true

# PRODUCT_BEHAVIOR_PIVOT_GATE — product behavior pivot gate.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: PRODUCT_BEHAVIOR_PIVOT_GATE=true

PRODUCT_BEHAVIOR_PIVOT_GATE=true

# PRODUCT_BEHAVIOR_SEARCH_CONTRACT — product behavior search contract.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: PRODUCT_BEHAVIOR_SEARCH_CONTRACT=true

PRODUCT_BEHAVIOR_SEARCH_CONTRACT=true

# PRODUCT_BEHAVIOR_REPLY_GATE — product behavior reply gate.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: PRODUCT_BEHAVIOR_REPLY_GATE=true

PRODUCT_BEHAVIOR_REPLY_GATE=true

# PRODUCT_BEHAVIOR_ECHO_SIM_THRESHOLD — product behavior echo sim threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: PRODUCT_BEHAVIOR_ECHO_SIM_THRESHOLD=10

PRODUCT_BEHAVIOR_ECHO_SIM_THRESHOLD=0.82
