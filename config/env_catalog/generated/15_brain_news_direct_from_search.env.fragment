# =============================================================================
# BRAIN_NEWS_DIRECT_FROM_SEARCH — формат ответа на «новости».
#   false — LLM: 3–4 предложения на пункт (что внутри новости).
#   true — только заголовки из RSS без LLM (быстро, но сухо).

# BRAIN_NEWS_DIRECT_FROM_SEARCH — формат ответа на «новости».
#   false — LLM: 3–4 предложения на пункт (что внутри новости).
#   true — только заголовки из RSS без LLM (быстро, но сухо).

BRAIN_NEWS_DIRECT_FROM_SEARCH=false

# NEWS_ENRICH_SEARCH_SNIPPETS — news enrich search snippets.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: NEWS_ENRICH_SEARCH_SNIPPETS=true

NEWS_ENRICH_SEARCH_SNIPPETS=true

# NEWS_DIRECT_MAX_ITEMS — news direct max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_DIRECT_MAX_ITEMS=10

NEWS_DIRECT_MAX_ITEMS=7

# NEWS_RSS_MAX_ITEMS — news rss max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_RSS_MAX_ITEMS=10

NEWS_RSS_MAX_ITEMS=12

# NEWS_BRIEF_SOURCE_MAX_ITEMS — news brief source max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_BRIEF_SOURCE_MAX_ITEMS=10

NEWS_BRIEF_SOURCE_MAX_ITEMS=7

# NEWS_SNIPPET_MAX_CHARS — news snippet max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_SNIPPET_MAX_CHARS=10

NEWS_SNIPPET_MAX_CHARS=520

# NEWS_BRIEF_HINT_MAX_CHARS — news brief hint max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_BRIEF_HINT_MAX_CHARS=10

NEWS_BRIEF_HINT_MAX_CHARS=5500

# NEWS_REPLY_MAX_ITEMS — news reply max items.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NEWS_REPLY_MAX_ITEMS=10

NEWS_REPLY_MAX_ITEMS=7

# NEWS_WORLD_RSS_LANG — news world rss lang.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: NEWS_WORLD_RSS_LANG=<значение>

NEWS_WORLD_RSS_LANG=en

# NEWS_WORLD_RSS_QUERY — news world rss query.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: NEWS_WORLD_RSS_QUERY=<значение>

# NEWS_WORLD_RSS_QUERY=

# NEWS_GOOGLE_RSS_LOCALE — news google rss locale.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: NEWS_GOOGLE_RSS_LOCALE=<значение>

NEWS_GOOGLE_RSS_LOCALE=hl=en&gl=US&ceid=US:en

# NEWS_BLOCKED_DOMAINS — news blocked domains.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: NEWS_BLOCKED_DOMAINS=<значение>

NEWS_BLOCKED_DOMAINS=example-fake.com
