# =============================================================================
# Code Evolution (Фаза 9) — Self-Code Evolution
# =============================================================================
# Master switch
# CODE_EVOL_ENABLED — code evol enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CODE_EVOL_ENABLED=true

# CODE_EVOL_ENABLED — code evol enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CODE_EVOL_ENABLED=true

CODE_EVOL_ENABLED=true

# CODE_EVOL_ALLOWED_DIRS — code evol allowed dirs.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_ALLOWED_DIRS=<значение>

CODE_EVOL_ALLOWED_DIRS=core

# CODE_EVOL_PATCHES_MAX — code evol patches max.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_PATCHES_MAX=<значение>

CODE_EVOL_PATCHES_MAX=50

# CODE_EVOL_GIT_USER — code evol git user.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_GIT_USER=<значение>

CODE_EVOL_GIT_USER=gemma-bot

# CODE_EVOL_GIT_EMAIL — code evol git email.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_GIT_EMAIL=<значение>

CODE_EVOL_GIT_EMAIL=bot@localhost

# CODE_EVOL_DEPLOY_SSH — code evol deploy ssh.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_DEPLOY_SSH=<значение>

# CODE_EVOL_DEPLOY_SSH=

# CODE_EVOL_DEPLOY_CMD — code evol deploy cmd.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CODE_EVOL_DEPLOY_CMD=<значение>

CODE_EVOL_DEPLOY_CMD=bash /opt/gemma_agent/scripts/gemma_panel.sh update

# CODE_EVOL_OPTIMIZER_INTERVAL — code evol optimizer interval.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CODE_EVOL_OPTIMIZER_INTERVAL=10

CODE_EVOL_OPTIMIZER_INTERVAL=720
