# =============================================================================
# LLM Triage — анализ срабатываний healers через LLM
# =============================================================================
# Включён ли LLM Triage (true/false)
# LLM_TRIAGE_ENABLED — llm triage enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: LLM_TRIAGE_ENABLED=true

# LLM_TRIAGE_ENABLED — llm triage enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: LLM_TRIAGE_ENABLED=true

LLM_TRIAGE_ENABLED=true

# LLM_TRIAGE_MAX_CONTEXT_CHARS — llm triage max context chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LLM_TRIAGE_MAX_CONTEXT_CHARS=10

LLM_TRIAGE_MAX_CONTEXT_CHARS=8000

# LLM_TRIAGE_MAX_RECOMMENDATIONS — llm triage max recommendations.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LLM_TRIAGE_MAX_RECOMMENDATIONS=10

LLM_TRIAGE_MAX_RECOMMENDATIONS=50

# LLM_TRIAGE_AUTOFLUSH_COUNT — llm triage autoflush count.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LLM_TRIAGE_AUTOFLUSH_COUNT=10

LLM_TRIAGE_AUTOFLUSH_COUNT=3

# USER_DOC_PENDING_ENABLED — user doc pending enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: USER_DOC_PENDING_ENABLED=true

USER_DOC_PENDING_ENABLED=true

# PENDING_DOC_MAX_BYTES — pending doc max bytes.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: PENDING_DOC_MAX_BYTES=10

PENDING_DOC_MAX_BYTES=2500000

# USER_LIBRARY_DIR — user library dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USER_LIBRARY_DIR=data/runtime/example.json

USER_LIBRARY_DIR=./data/user_library

# SHARED_KNOWLEDGE_DIR — shared knowledge dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: SHARED_KNOWLEDGE_DIR=data/runtime/example.json

SHARED_KNOWLEDGE_DIR=./data/shared_knowledge

# SHARED_KNOWLEDGE_UPLOAD — shared knowledge upload.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SHARED_KNOWLEDGE_UPLOAD=<значение>

SHARED_KNOWLEDGE_UPLOAD=admin

# TELEGRAM_REPLY_CONTEXT_DEPTH — telegram reply context depth.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: TELEGRAM_REPLY_CONTEXT_DEPTH=<значение>

TELEGRAM_REPLY_CONTEXT_DEPTH=3

# TELEGRAM_REPLY_CONTEXT_MAX_CHARS — telegram reply context max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_REPLY_CONTEXT_MAX_CHARS=10

TELEGRAM_REPLY_CONTEXT_MAX_CHARS=4500

# RESILIENCE_SAFE_ERROR_TOTAL — resilience safe error total.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESILIENCE_SAFE_ERROR_TOTAL=<значение>

RESILIENCE_SAFE_ERROR_TOTAL=60

# RESILIENCE_CRITICAL_ERROR_TOTAL — resilience critical error total.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESILIENCE_CRITICAL_ERROR_TOTAL=<значение>

RESILIENCE_CRITICAL_ERROR_TOTAL=120

# RESILIENCE_CRITICAL_FAILED_MODULES — resilience critical failed modules.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESILIENCE_CRITICAL_FAILED_MODULES=<значение>

RESILIENCE_CRITICAL_FAILED_MODULES=3

# RESILIENCE_RECOVERY_OK_CYCLES — resilience recovery ok cycles.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESILIENCE_RECOVERY_OK_CYCLES=<значение>

RESILIENCE_RECOVERY_OK_CYCLES=2

# RESILIENCE_ERROR_SAMPLE — resilience error sample.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESILIENCE_ERROR_SAMPLE=<значение>

RESILIENCE_ERROR_SAMPLE=500

# RESILIENCE_ERROR_COUNT_SEVERITIES — resilience error count severities.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESILIENCE_ERROR_COUNT_SEVERITIES=10

RESILIENCE_ERROR_COUNT_SEVERITIES=error

# SAFE_MODE_MODULE_ALLOWLIST — safe mode module allowlist.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SAFE_MODE_MODULE_ALLOWLIST=<значение>

SAFE_MODE_MODULE_ALLOWLIST=chat_orchestrator,math,echo
