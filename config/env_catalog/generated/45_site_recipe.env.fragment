# =============================================================================
# Site recipe (парсинг сайтов под инструменты мозга)
# =============================================================================

# SITE_RECIPE_ENABLED — site recipe enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_ENABLED=true

# SITE_RECIPE_ENABLED — site recipe enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_ENABLED=true

SITE_RECIPE_ENABLED=true

# SITE_RECIPE_AUTO_LEARN_ON_MISS — site recipe auto learn on miss.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_AUTO_LEARN_ON_MISS=true

SITE_RECIPE_AUTO_LEARN_ON_MISS=false

# SITE_RECIPE_AUTO_LEARN_WITH_LLM — site recipe auto learn with llm.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_AUTO_LEARN_WITH_LLM=true

SITE_RECIPE_AUTO_LEARN_WITH_LLM=false

# SITE_RECIPE_LEARN_ENABLED — site recipe learn enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_LEARN_ENABLED=true

SITE_RECIPE_LEARN_ENABLED=false

# SITE_RECIPE_DIR — site recipe dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: SITE_RECIPE_DIR=data/runtime/example.json

SITE_RECIPE_DIR=./data/site_recipes

# SITE_RECIPE_USE_LLM — site recipe use llm.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_USE_LLM=true

SITE_RECIPE_USE_LLM=true

# SITE_RECIPE_LLM_HTML_CHARS — site recipe llm html chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_LLM_HTML_CHARS=10

SITE_RECIPE_LLM_HTML_CHARS=100000

# SITE_RECIPE_CACHE_ENABLED — site recipe cache enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_CACHE_ENABLED=true

SITE_RECIPE_CACHE_ENABLED=true

# SITE_RECIPE_CACHE_TTL_SEC — site recipe cache ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_CACHE_TTL_SEC=10

SITE_RECIPE_CACHE_TTL_SEC=604800

# SITE_RECIPE_EXTRACT_CODE — site recipe extract code.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SITE_RECIPE_EXTRACT_CODE=true

SITE_RECIPE_EXTRACT_CODE=true

# SITE_RECIPE_MAX_CODE_TOTAL_CHARS — site recipe max code total chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SITE_RECIPE_MAX_CODE_TOTAL_CHARS=10

SITE_RECIPE_MAX_CODE_TOTAL_CHARS=50000
