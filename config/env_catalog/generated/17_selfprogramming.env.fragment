# =============================================================================
# Мозг: учебник по плагинам в промпте (при доступных SelfProgramming.*)
# =============================================================================

# Вкл. по умолчанию: в system подмешивается docs/PLUGIN_AUTHOR_HANDBOOK_RU.md (кэш на процесс).
# BRAIN_PLUGIN_AUTHOR_DOCS — brain plugin author docs.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_PLUGIN_AUTHOR_DOCS=true

# BRAIN_PLUGIN_AUTHOR_DOCS — brain plugin author docs.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_PLUGIN_AUTHOR_DOCS=true

BRAIN_PLUGIN_AUTHOR_DOCS=true

# BRAIN_PLUGIN_AUTHOR_DOCS_MAX_CHARS — brain plugin author docs max chars.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_PLUGIN_AUTHOR_DOCS_MAX_CHARS=true

BRAIN_PLUGIN_AUTHOR_DOCS_MAX_CHARS=0

# BRAIN_POST_MODULE_GEN_BUTTONS — brain post module gen buttons.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_POST_MODULE_GEN_BUTTONS=true

BRAIN_POST_MODULE_GEN_BUTTONS=true

# BRAIN_WEATHER_WTTR_EAGER_FETCH — brain weather wttr eager fetch.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_WEATHER_WTTR_EAGER_FETCH=true

BRAIN_WEATHER_WTTR_EAGER_FETCH=true

# BRAIN_WEATHER_UNIVERSAL_SEARCH_FALLBACK — brain weather universal search fallback.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_WEATHER_UNIVERSAL_SEARCH_FALLBACK=true

BRAIN_WEATHER_UNIVERSAL_SEARCH_FALLBACK=true

# GEO_MAPS_ENABLED — geo maps enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEO_MAPS_ENABLED=true

GEO_MAPS_ENABLED=true

# GEO_HTTP_USER_AGENT — geo http user agent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEO_HTTP_USER_AGENT=<значение>

GEO_HTTP_USER_AGENT=gemma_bot/1.0 (обязательно осмысленный User-Agent для Nominatim)

# NOMINATIM_MIN_INTERVAL_SEC — nominatim min interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: NOMINATIM_MIN_INTERVAL_SEC=10

NOMINATIM_MIN_INTERVAL_SEC=1.05

# OSRM_ROUTING_BASE — osrm routing base.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: OSRM_ROUTING_BASE=<значение>

OSRM_ROUTING_BASE=https://router.project-osrm.org

# GEO_STATIC_MAP_URL_TEMPLATE — geo static map url template.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEO_STATIC_MAP_URL_TEMPLATE=<значение>

GEO_STATIC_MAP_URL_TEMPLATE=https://staticmap.openstreetmap.de/staticmap.php?center={lat},{lon}&zoom={z}&size={w}x{h}&maptype=mapnik

# GEO_STATIC_MAP_WIDTH — geo static map width.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEO_STATIC_MAP_WIDTH=<значение>

GEO_STATIC_MAP_WIDTH=640

# GEO_STATIC_MAP_HEIGHT — geo static map height.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEO_STATIC_MAP_HEIGHT=<значение>

GEO_STATIC_MAP_HEIGHT=400

# GEO_NEARBY_VIEWPORT_DEG — geo nearby viewport deg.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEO_NEARBY_VIEWPORT_DEG=<значение>

GEO_NEARBY_VIEWPORT_DEG=0.08

# RUNTIME_DIAG_TOOL_MAX_JSON_CHARS — runtime diag tool max json chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RUNTIME_DIAG_TOOL_MAX_JSON_CHARS=10

RUNTIME_DIAG_TOOL_MAX_JSON_CHARS=180000
