# =============================================================================
# LLM Step-Cache (core/llm_cache.py): SQLite + in-memory для LLM-ответов
# =============================================================================
# Время жизни записи в кэше (сек; по умолч. 21600 = 6 ч)
# LLM_CACHE_TTL_SEC — llm cache ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LLM_CACHE_TTL_SEC=10

# LLM_CACHE_TTL_SEC — llm cache ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LLM_CACHE_TTL_SEC=10

LLM_CACHE_TTL_SEC=21600

# LLM_PROXY_CACHE_ENABLED — llm proxy cache enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: LLM_PROXY_CACHE_ENABLED=true

LLM_PROXY_CACHE_ENABLED=true

# LLM_CACHE_DB_PATH — llm cache db path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: LLM_CACHE_DB_PATH=data/runtime/example.json

# LLM_CACHE_DB_PATH=
