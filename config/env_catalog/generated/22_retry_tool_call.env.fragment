# =============================================================================
# Инструменты: подсказка в промпт, дедуп вызовов, retry при неверном TOOL_CALL
# =============================================================================
# Эвристика «какой tool уместен» (URL, поиск, законы, вики) — строка tool_routing_hint в контексте LLM.
# BRAIN_TOOL_ROUTING_HINT — brain tool routing hint.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_TOOL_ROUTING_HINT=true

# BRAIN_TOOL_ROUTING_HINT — brain tool routing hint.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_TOOL_ROUTING_HINT=true

BRAIN_TOOL_ROUTING_HINT=true

# GOAL_DOMAIN_POLICY_ENABLED — goal domain policy enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_DOMAIN_POLICY_ENABLED=true

GOAL_DOMAIN_POLICY_ENABLED=true

# GOAL_DOMAIN_MULTISTEP_HINT — goal domain multistep hint.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GOAL_DOMAIN_MULTISTEP_HINT=true

GOAL_DOMAIN_MULTISTEP_HINT=false

# TOOL_ROUTING_MULTISTEP_UNIVERSAL — tool routing multistep universal.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TOOL_ROUTING_MULTISTEP_UNIVERSAL=true

TOOL_ROUTING_MULTISTEP_UNIVERSAL=false

# Сначала перечислять в промпте инструменты из подсказки (остальные — ниже).
# A/B agent instruction: full монолит constants.py vs укороченный chat-core + доменные вставки; выкл = всегда полный пакет.

BRAIN_AGENT_PACK_ADAPTIVE=true

# BRAIN_CHAT_CONTEXT_SLIM — brain chat context slim.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_CHAT_CONTEXT_SLIM=true

BRAIN_CHAT_CONTEXT_SLIM=true

# BRAIN_CHAT_CONTEXT_SLIM_EXTERNAL — brain chat context slim external.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_CHAT_CONTEXT_SLIM_EXTERNAL=true

BRAIN_CHAT_CONTEXT_SLIM_EXTERNAL=true

# BRAIN_CHAT_CONTEXT_SLIM_TOOLS_INDEX — brain chat context slim tools index.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_CHAT_CONTEXT_SLIM_TOOLS_INDEX=true

BRAIN_CHAT_CONTEXT_SLIM_TOOLS_INDEX=true

# BRAIN_CHAT_CONTEXT_SLIM_IN_GROUPS — brain chat context slim in groups.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_CHAT_CONTEXT_SLIM_IN_GROUPS=true

BRAIN_CHAT_CONTEXT_SLIM_IN_GROUPS=false

# BRAIN_TOOLS_PRIORITIZE_HINT — brain tools prioritize hint.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_TOOLS_PRIORITIZE_HINT=true

BRAIN_TOOLS_PRIORITIZE_HINT=true

# BRAIN_TOOLS_EXTRA_PREFIXES — brain tools extra prefixes.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_TOOLS_EXTRA_PREFIXES=<значение>

BRAIN_TOOLS_EXTRA_PREFIXES=MySiteParser.,OtherModule.

# BRAIN_TOOL_CALL_RETRY — brain tool call retry.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_TOOL_CALL_RETRY=<значение>

BRAIN_TOOL_CALL_RETRY=2

# BRAIN_FIRST_MAX_TOKENS — brain first max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_FIRST_MAX_TOKENS=10

BRAIN_FIRST_MAX_TOKENS=1536

# BRAIN_FIRST_MAX_TOKENS_LAW — brain first max tokens law.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_FIRST_MAX_TOKENS_LAW=10

BRAIN_FIRST_MAX_TOKENS_LAW=1600

# BRAIN_SECOND_MAX_TOKENS — brain second max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_SECOND_MAX_TOKENS=10

BRAIN_SECOND_MAX_TOKENS=1200

# --- Reasoning loop (только если первый проход без TOOL_CALL): внутренний ревью + финальный синтез, одна реплика пользователя ---
# Включён по умолчанию. Отключить: false.

BRAIN_REASONING_LOOP_ENABLED=true

# BRAIN_REASONING_LOOP_MODE — brain reasoning loop mode.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_REASONING_LOOP_MODE=<значение>

BRAIN_REASONING_LOOP_MODE=tier

# BRAIN_REASONING_LOOP_MIN_USER_CHARS — brain reasoning loop min user chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_REASONING_LOOP_MIN_USER_CHARS=10

BRAIN_REASONING_LOOP_MIN_USER_CHARS=96

# BRAIN_REASONING_LOOP_CRITIQUE_MAX_TOKENS — brain reasoning loop critique max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_REASONING_LOOP_CRITIQUE_MAX_TOKENS=10

BRAIN_REASONING_LOOP_CRITIQUE_MAX_TOKENS=520

# BRAIN_REASONING_LOOP_FINAL_MAX_TOKENS — brain reasoning loop final max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_REASONING_LOOP_FINAL_MAX_TOKENS=10

BRAIN_REASONING_LOOP_FINAL_MAX_TOKENS=1400

# Принудительно для хода: context brain_force_reasoning_loop=true (оркестратор/тесты)
# Детектор коррекций: при фразах «нет», «не то», «ошибся» и т.п. — форсирует reasoning loop,
# вставляет приоритетный блок ⚠️ ПОЛЬЗОВАТЕЛЬ ИСПРАВЛЯЕТ в external_hint.
# Настраивается через _CORRECTION_PATTERNS в reasoning_loop_controller.py.
# Число строк журнала в /admin_bug по умолчанию (1–100).

ADMIN_BUG_LOG_LINES=80

# BUG_REPORT_USER_SUBMIT_ENABLED — bug report user submit enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BUG_REPORT_USER_SUBMIT_ENABLED=true

BUG_REPORT_USER_SUBMIT_ENABLED=false

# BUG_REPORT_FORWARD_USER_IDS — bug report forward user ids.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BUG_REPORT_FORWARD_USER_IDS=<значение>

# BUG_REPORT_FORWARD_USER_IDS=

# BUG_REPORT_USER_COOLDOWN_SEC — bug report user cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BUG_REPORT_USER_COOLDOWN_SEC=10

BUG_REPORT_USER_COOLDOWN_SEC=120

# BUG_REPORT_USER_MAX_LOG_LINES — bug report user max log lines.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BUG_REPORT_USER_MAX_LOG_LINES=10

BUG_REPORT_USER_MAX_LOG_LINES=50

# BUG_REPORT_USER_ALLOW_NET — bug report user allow net.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BUG_REPORT_USER_ALLOW_NET=true

BUG_REPORT_USER_ALLOW_NET=false

# BUG_PENDING_TTL_SEC — bug pending ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BUG_PENDING_TTL_SEC=10

BUG_PENDING_TTL_SEC=600

# ADMIN_DIAGNOSTIC_COPY_TO_TOOLS — admin diagnostic copy to tools.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ADMIN_DIAGNOSTIC_COPY_TO_TOOLS=true

ADMIN_DIAGNOSTIC_COPY_TO_TOOLS=1

# TOOLS_BUNDLE_JSON_DEFAULT_MODE — tools bundle json default mode.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: TOOLS_BUNDLE_JSON_DEFAULT_MODE=<значение>

TOOLS_BUNDLE_JSON_DEFAULT_MODE=summary

# TOOLS_BUNDLE_JSON_SUMMARY_MAX_CHARS — tools bundle json summary max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TOOLS_BUNDLE_JSON_SUMMARY_MAX_CHARS=10

TOOLS_BUNDLE_JSON_SUMMARY_MAX_CHARS=16000

# TOOLS_BUNDLE_JSON_SECTION_MAX_CHARS — tools bundle json section max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TOOLS_BUNDLE_JSON_SECTION_MAX_CHARS=10

TOOLS_BUNDLE_JSON_SECTION_MAX_CHARS=28000

# TOOLS_BUNDLE_SUMMARY_SECTION_BUDGET — tools bundle summary section budget.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TOOLS_BUNDLE_SUMMARY_SECTION_BUDGET=10

TOOLS_BUNDLE_SUMMARY_SECTION_BUDGET=1200

# BRAIN_SECOND_TOOL_RESULT_MAX_CHARS — brain second tool result max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_SECOND_TOOL_RESULT_MAX_CHARS=10

BRAIN_SECOND_TOOL_RESULT_MAX_CHARS=45000

# BRAIN_SECOND_TOOL_RESULT_HEAD_CHARS — brain second tool result head chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_SECOND_TOOL_RESULT_HEAD_CHARS=10

BRAIN_SECOND_TOOL_RESULT_HEAD_CHARS=18000

# BRAIN_SECOND_TOOL_RESULT_TAIL_CHARS — brain second tool result tail chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_SECOND_TOOL_RESULT_TAIL_CHARS=10

BRAIN_SECOND_TOOL_RESULT_TAIL_CHARS=12000

# BRAIN_TOOL_DEDUP_ENABLED — brain tool dedup enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_TOOL_DEDUP_ENABLED=true

BRAIN_TOOL_DEDUP_ENABLED=true

# BRAIN_TOOL_DEDUP_TTL_SEC — brain tool dedup ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_TOOL_DEDUP_TTL_SEC=10

BRAIN_TOOL_DEDUP_TTL_SEC=90

# TOOLS_FILTER_KWARGS — tools filter kwargs.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TOOLS_FILTER_KWARGS=true

TOOLS_FILTER_KWARGS=true
