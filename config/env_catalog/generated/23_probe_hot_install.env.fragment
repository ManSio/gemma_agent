# =============================================================================
# Автономика: дайджест сессии, «усталость», риск маршрута, probe после hot-install
# =============================================================================

# --- Дайджест сессии (краткая сводка ходов в JSONL, аналог «консолидации») ---
# Когда пишется: накопились ходы одного user_id и выполнено ЛИБО ≥ SESSION_DIGEST_EVERY_N_TURNS,
#   ЛИБО суммарный размер буфера ≥ SESSION_DIGEST_BUFFER_CHARS.
# В строке: счётчики ok/fallback/clarify/error/failure и до 8 коротких образцов (user_excerpt).
# false — не вести журнал.
# SESSION_DIGEST_ENABLED — session digest enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SESSION_DIGEST_ENABLED=true

# SESSION_DIGEST_ENABLED — session digest enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SESSION_DIGEST_ENABLED=true

SESSION_DIGEST_ENABLED=true

# SESSION_DIGEST_EVERY_N_TURNS — session digest every n turns.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SESSION_DIGEST_EVERY_N_TURNS=<значение>

SESSION_DIGEST_EVERY_N_TURNS=12

# SESSION_DIGEST_BUFFER_CHARS — session digest buffer chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SESSION_DIGEST_BUFFER_CHARS=10

SESSION_DIGEST_BUFFER_CHARS=6000

# SESSION_DIGEST_MIN_USER_CHARS — session digest min user chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SESSION_DIGEST_MIN_USER_CHARS=10

SESSION_DIGEST_MIN_USER_CHARS=2

# GEMMA_SESSION_DIGEST_PATH — gemma session digest path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_SESSION_DIGEST_PATH=data/runtime/example.json

GEMMA_SESSION_DIGEST_PATH=data/runtime/session_digest.jsonl

# --- «Усталость» по латентности (ужать промпт и ответ) ---
# Когда включается: p95 за последние измерения в OBS для ключа telegram_pipeline ≥ FATIGUE_P95_TELEGRAM_MS
#   ИЛИ p95 для openrouter_completion_ms ≥ FATIGUE_P95_OPENROUTER_MS.
# Эффект: verbosity → concise, принудительно slim-сборка промпта мозга (меньше контекста).
# false — не реагировать на задержки.

AUTONOMIC_FATIGUE_ENABLED=true

# FATIGUE_P95_TELEGRAM_MS — fatigue p95 telegram ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: FATIGUE_P95_TELEGRAM_MS=10

FATIGUE_P95_TELEGRAM_MS=14000

# FATIGUE_P95_OPENROUTER_MS — fatigue p95 openrouter ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: FATIGUE_P95_OPENROUTER_MS=10

FATIGUE_P95_OPENROUTER_MS=55000

# --- Cost-aware autopilot (дневной бюджет токенов без ручного свитча) ---
# Режимы: normal / saving / hard_saving по доле от дневного бюджета.
# Эффекты:
#   • saving: concise + меньше стратегических подсказок на коротких general-запросах;
#   • hard_saving: сильнее ужатие, отключение части hints и инструментов для короткого чата.

COST_AUTOPILOT_ENABLED=true

# COST_DAILY_TOKEN_BUDGET — cost daily token budget.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: COST_DAILY_TOKEN_BUDGET=<значение>

COST_DAILY_TOKEN_BUDGET=300000

# COST_SAVING_THRESHOLD — cost saving threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: COST_SAVING_THRESHOLD=10

COST_SAVING_THRESHOLD=0.75

# COST_HARD_SAVING_THRESHOLD — cost hard saving threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: COST_HARD_SAVING_THRESHOLD=10

COST_HARD_SAVING_THRESHOLD=0.90

# COST_LLM_USAGE_MAX_ROWS — cost llm usage max rows.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: COST_LLM_USAGE_MAX_ROWS=10

COST_LLM_USAGE_MAX_ROWS=20000

# --- Efficiency guard: авто-реакция при деградации роутинга/плагинов ---
# true — при падении качества автоматически ужимает стиль/глубину и включает строгий guard маршрутизации.

EFFICIENCY_GUARD_ENABLED=true

# EFF_GUARD_ROUTE_SUCCESS_WARN_PCT — eff guard route success warn pct.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EFF_GUARD_ROUTE_SUCCESS_WARN_PCT=<значение>

EFF_GUARD_ROUTE_SUCCESS_WARN_PCT=85

# EFF_GUARD_ROUTE_SUCCESS_CRIT_PCT — eff guard route success crit pct.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EFF_GUARD_ROUTE_SUCCESS_CRIT_PCT=<значение>

EFF_GUARD_ROUTE_SUCCESS_CRIT_PCT=70

# EFF_GUARD_PLUGIN_SUCCESS_WARN_PCT — eff guard plugin success warn pct.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EFF_GUARD_PLUGIN_SUCCESS_WARN_PCT=<значение>

EFF_GUARD_PLUGIN_SUCCESS_WARN_PCT=92

# EFF_GUARD_PLUGIN_SUCCESS_CRIT_PCT — eff guard plugin success crit pct.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EFF_GUARD_PLUGIN_SUCCESS_CRIT_PCT=<значение>

EFF_GUARD_PLUGIN_SUCCESS_CRIT_PCT=80

# EFF_GUARD_TOKEN_EFF_WARN_PCT — eff guard token eff warn pct.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EFF_GUARD_TOKEN_EFF_WARN_PCT=<значение>

EFF_GUARD_TOKEN_EFF_WARN_PCT=12

# EFF_GUARD_MIN_SAMPLES — eff guard min samples.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: EFF_GUARD_MIN_SAMPLES=10

EFF_GUARD_MIN_SAMPLES=20

# HOUSEKEEPING_ENABLED — housekeeping enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HOUSEKEEPING_ENABLED=true

HOUSEKEEPING_ENABLED=true

# HOUSEKEEPING_PROFILE — housekeeping profile.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HOUSEKEEPING_PROFILE=<значение>

HOUSEKEEPING_PROFILE=auto

# HOUSEKEEPING_MAX_DELETE_PER_CYCLE — housekeeping max delete per cycle.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HOUSEKEEPING_MAX_DELETE_PER_CYCLE=10

HOUSEKEEPING_MAX_DELETE_PER_CYCLE=200

# HOUSEKEEPING_DELETE_PY_CACHE — housekeeping delete py cache.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HOUSEKEEPING_DELETE_PY_CACHE=true

HOUSEKEEPING_DELETE_PY_CACHE=true

# HOUSEKEEPING_DELETE_PYTEST_CACHE — housekeeping delete pytest cache.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HOUSEKEEPING_DELETE_PYTEST_CACHE=true

HOUSEKEEPING_DELETE_PYTEST_CACHE=true

# HOUSEKEEPING_DELETE_PYC_FILES — housekeeping delete pyc files.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HOUSEKEEPING_DELETE_PYC_FILES=true

HOUSEKEEPING_DELETE_PYC_FILES=true

# HOUSEKEEPING_DELETE_TEST_TMP — housekeeping delete test tmp.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HOUSEKEEPING_DELETE_TEST_TMP=true

HOUSEKEEPING_DELETE_TEST_TMP=true

# HOUSEKEEPING_TEST_TMP_MAX_AGE_HOURS — housekeeping test tmp max age hours.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HOUSEKEEPING_TEST_TMP_MAX_AGE_HOURS=10

HOUSEKEEPING_TEST_TMP_MAX_AGE_HOURS=12

# HOUSEKEEPING_STORAGE_OPTIMIZE_ENABLED — housekeeping storage optimize enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: HOUSEKEEPING_STORAGE_OPTIMIZE_ENABLED=true

HOUSEKEEPING_STORAGE_OPTIMIZE_ENABLED=true

# HOUSEKEEPING_JSONL_MAX_BYTES — housekeeping jsonl max bytes.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: HOUSEKEEPING_JSONL_MAX_BYTES=10

HOUSEKEEPING_JSONL_MAX_BYTES=2097152

# HOUSEKEEPING_JSONL_KEEP_LINES — housekeeping jsonl keep lines.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HOUSEKEEPING_JSONL_KEEP_LINES=<значение>

HOUSEKEEPING_JSONL_KEEP_LINES=6000

# CONTEXT_COMPRESSION_ENABLED — context compression enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CONTEXT_COMPRESSION_ENABLED=true

CONTEXT_COMPRESSION_ENABLED=true

# CONTEXT_TOOL_OUTPUT_TRIM_ENABLED — context tool output trim enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CONTEXT_TOOL_OUTPUT_TRIM_ENABLED=true

CONTEXT_TOOL_OUTPUT_TRIM_ENABLED=true

# CONTEXT_TOOL_OUTPUT_KEEP_RECENT — context tool output keep recent.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CONTEXT_TOOL_OUTPUT_KEEP_RECENT=<значение>

CONTEXT_TOOL_OUTPUT_KEEP_RECENT=2

# CONTEXT_TOOL_OUTPUT_MIN_CHARS — context tool output min chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CONTEXT_TOOL_OUTPUT_MIN_CHARS=10

CONTEXT_TOOL_OUTPUT_MIN_CHARS=1200

# CONTEXT_TOOL_OUTPUT_PLACEHOLDER — context tool output placeholder.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CONTEXT_TOOL_OUTPUT_PLACEHOLDER=<значение>

CONTEXT_TOOL_OUTPUT_PLACEHOLDER=[старый результат инструмента сжат; при необходимости повторите запрос]

# TURN_OBSERVER_ENABLED — turn observer enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: TURN_OBSERVER_ENABLED=true

TURN_OBSERVER_ENABLED=true

# GEMMA_TURNS_LOG_PATH — gemma turns log path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_TURNS_LOG_PATH=data/runtime/example.json

GEMMA_TURNS_LOG_PATH=data/runtime/turns.jsonl

# CONTEXT_RECENT_KEEP_MESSAGES — context recent keep messages.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CONTEXT_RECENT_KEEP_MESSAGES=<значение>

CONTEXT_RECENT_KEEP_MESSAGES=10

# CONTEXT_ASSISTANT_CLIP_CHARS — context assistant clip chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CONTEXT_ASSISTANT_CLIP_CHARS=10

CONTEXT_ASSISTANT_CLIP_CHARS=700

# CONTEXT_USER_CLIP_CHARS — context user clip chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CONTEXT_USER_CLIP_CHARS=10

CONTEXT_USER_CLIP_CHARS=420

# CONTEXT_DEDUP_WINDOW — context dedup window.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: CONTEXT_DEDUP_WINDOW=<значение>

CONTEXT_DEDUP_WINDOW=4

# CONTEXT_SUMMARY_MAX_CHARS — context summary max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CONTEXT_SUMMARY_MAX_CHARS=10

CONTEXT_SUMMARY_MAX_CHARS=1200

# CONTEXT_SUMMARY_STABLE_HEAD_TAIL — context summary stable head tail.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CONTEXT_SUMMARY_STABLE_HEAD_TAIL=true

CONTEXT_SUMMARY_STABLE_HEAD_TAIL=true

# Мозг (core/brain/pipeline): в external_hint всегда добавляется блок времени и календаря (сегодня/вчера/завтра
#   в поясе пользователя или в UTC), не только при явном «который час» — для фраз «вчера», «сегодня утром» и сопоставления с telegram_ts в recent_dialogue.
# Запросы вида «что писал вчера утром», «неделю назад» (с маркерами диалога) подмешивают реплики из message_archive + recent_dialogue за вычисленное окно (core/relative_dialogue_time.py).
# Sticky session по intent-bucket (chat/logic/debug/admin) для лучшего prompt-cache reuse.

BRAIN_KV_SESSION_PER_INTENT_BUCKET=true

# BRAIN_KV_INTENT_HYSTERESIS_TURNS — brain kv intent hysteresis turns.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_KV_INTENT_HYSTERESIS_TURNS=<значение>

BRAIN_KV_INTENT_HYSTERESIS_TURNS=2

# BRAIN_KV_INTENT_SWITCH_COOLDOWN_SEC — brain kv intent switch cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_KV_INTENT_SWITCH_COOLDOWN_SEC=10

BRAIN_KV_INTENT_SWITCH_COOLDOWN_SEC=120

# BRAIN_KV_INTENT_SWITCH_CONFIDENCE_SOFT — brain kv intent switch confidence soft.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_KV_INTENT_SWITCH_CONFIDENCE_SOFT=<значение>

BRAIN_KV_INTENT_SWITCH_CONFIDENCE_SOFT=0.6

# BRAIN_KV_INTENT_SWITCH_CONFIDENCE_HARD — brain kv intent switch confidence hard.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_KV_INTENT_SWITCH_CONFIDENCE_HARD=<значение>

BRAIN_KV_INTENT_SWITCH_CONFIDENCE_HARD=0.9

# BRAIN_KV_PROFILE_STICKY — brain kv profile sticky.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_KV_PROFILE_STICKY=true

BRAIN_KV_PROFILE_STICKY=true

# SELF_MODEL_ENABLED — self model enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_MODEL_ENABLED=true

SELF_MODEL_ENABLED=true

# SELF_MODEL_TTL_SEC — self model ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_MODEL_TTL_SEC=10

SELF_MODEL_TTL_SEC=2592000

# SELF_MODEL_TREND_WINDOW — self model trend window.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_MODEL_TREND_WINDOW=deepseek/deepseek-v4-flash

SELF_MODEL_TREND_WINDOW=12

# Лимиты «доверия к контексту» — подмешиваются в system prompt call_brain (короткий блок).
# true = осторожный режим (по умолчанию в JSON); false = увереннее опираться на контекст/память.

SELF_MODEL_NO_FORCE_EXTERNAL_STATE=true

# SELF_MODEL_CONTEXT_IS_PROBABILISTIC — self model context is probabilistic.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_MODEL_CONTEXT_IS_PROBABILISTIC=true

SELF_MODEL_CONTEXT_IS_PROBABILISTIC=true

# Отключить весь addon limits в промпт: SELF_MODEL_PROMPT_ADDON_ENABLED=false
#
# Динамический стиль ответа (только строка в system prompt; не трогает CDC/маршруты). По умолчанию выкл.

SELF_MODEL_AUTONOMY_STYLE_ENABLED=false

# SELF_MODEL_AUTONOMY_LOOKBACK — self model autonomy lookback.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_MODEL_AUTONOMY_LOOKBACK=deepseek/deepseek-v4-flash

SELF_MODEL_AUTONOMY_LOOKBACK=5

# SELF_MODEL_AUTONOMY_SCORE_ASSERTIVE — self model autonomy score assertive.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_MODEL_AUTONOMY_SCORE_ASSERTIVE=deepseek/deepseek-v4-flash

SELF_MODEL_AUTONOMY_SCORE_ASSERTIVE=0.8

# SELF_MODEL_AUTONOMY_SCORE_CAUTIOUS — self model autonomy score cautious.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_MODEL_AUTONOMY_SCORE_CAUTIOUS=deepseek/deepseek-v4-flash

SELF_MODEL_AUTONOMY_SCORE_CAUTIOUS=0.5

# SELF_MODEL_AUTONOMY_CLARIFY_CAUTIOUS — self model autonomy clarify cautious.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_MODEL_AUTONOMY_CLARIFY_CAUTIOUS=deepseek/deepseek-v4-flash

SELF_MODEL_AUTONOMY_CLARIFY_CAUTIOUS=2

# SELF_MODEL_AUTONOMY_MIN_TURNS_ASSERTIVE — self model autonomy min turns assertive.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_MODEL_AUTONOMY_MIN_TURNS_ASSERTIVE=10

SELF_MODEL_AUTONOMY_MIN_TURNS_ASSERTIVE=3

# SELF_MODEL_AUTONOMY_EXTENDED_ENABLED — self model autonomy extended enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_MODEL_AUTONOMY_EXTENDED_ENABLED=true

SELF_MODEL_AUTONOMY_EXTENDED_ENABLED=false

#
# Связка с recall: только при STYLE+EXTENDED в context.self_model.dynamic появляются clarify_rate / context_stability.
# Чтобы по ним подмешивать «тонкий» пакет архива/digest в мозг — отдельно включите MEMORY_RECALL_SELF_MODEL_BOOST_ENABLED
# (см. блок MemoryRecallFacade ниже; без этого флага extended сам recall не усиливает).
# Пороги для доп. строк (0..1): trust memory/external, context_stability, dialog_health

SELF_MODEL_AUTONOMY_EXT_TRUST_LOW=0.45

# SELF_MODEL_AUTONOMY_EXT_CONTEXT_LOW — self model autonomy ext context low.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_MODEL_AUTONOMY_EXT_CONTEXT_LOW=deepseek/deepseek-v4-flash

SELF_MODEL_AUTONOMY_EXT_CONTEXT_LOW=0.42

# SELF_MODEL_AUTONOMY_EXT_HEALTH_LOW — self model autonomy ext health low.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: SELF_MODEL_AUTONOMY_EXT_HEALTH_LOW=deepseek/deepseek-v4-flash

SELF_MODEL_AUTONOMY_EXT_HEALTH_LOW=0.48

# SELF_MODEL_AUTONOMY_GOAL_CONTEXT_ENABLED — self model autonomy goal context enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: SELF_MODEL_AUTONOMY_GOAL_CONTEXT_ENABLED=true

SELF_MODEL_AUTONOMY_GOAL_CONTEXT_ENABLED=false

# SELF_MODEL_AUTONOMY_GOAL_DEFAULT_MAX_TOOL_CALLS — self model autonomy goal default max tool calls.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_MODEL_AUTONOMY_GOAL_DEFAULT_MAX_TOOL_CALLS=10

SELF_MODEL_AUTONOMY_GOAL_DEFAULT_MAX_TOOL_CALLS=8

# --- Self-deployment: авто деплой сгенерированных модулей (генерация → тест → git → редеплой) ---
# Включает: pytest → git add/commit/push → SSH remote pull + restart

SELF_DEPLOY_ENABLED=false

# SELF_DEPLOY_BRANCH — self deploy branch.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_BRANCH=<значение>

SELF_DEPLOY_BRANCH=main

# SELF_DEPLOY_GIT_USER_NAME — self deploy git user name.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_GIT_USER_NAME=<значение>

SELF_DEPLOY_GIT_USER_NAME=GemmaAgent

# SELF_DEPLOY_GIT_USER_EMAIL — self deploy git user email.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_GIT_USER_EMAIL=<значение>

SELF_DEPLOY_GIT_USER_EMAIL=bot@example.com

# SELF_DEPLOY_REMOTE_SSH_HOST — self deploy remote ssh host.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_REMOTE_SSH_HOST=<значение>

# SELF_DEPLOY_REMOTE_SSH_HOST=

# SELF_DEPLOY_REMOTE_SSH_USER — self deploy remote ssh user.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_REMOTE_SSH_USER=<значение>

# SELF_DEPLOY_REMOTE_SSH_USER=

# SELF_DEPLOY_REMOTE_COMMAND — self deploy remote command.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: SELF_DEPLOY_REMOTE_COMMAND=<значение>

SELF_DEPLOY_REMOTE_COMMAND=cd gemma_bot && git pull && docker compose restart app

# SELF_DEPLOY_PUSH_DELAY_SEC — self deploy push delay sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: SELF_DEPLOY_PUSH_DELAY_SEC=10

SELF_DEPLOY_PUSH_DELAY_SEC=30

# --- Память риска маршрута (повторные сбои по тому же запросу) ---
# Когда пишется: исход хода fallback / clarify / error / failure → строка в route_risk.jsonl (fp + intent + модуль).
# Когда подмешивается hint: за последние ROUTE_RISK_LOOKBACK_LINES записей набралось ≥ ROUTE_RISK_MIN_STUMBLES
#   совпадений с ТЕКУЩИМ текстом (тот же fingerprint) и тем же intent — в промпт идёт стратегия, не старый ответ.

ROUTE_RISK_MEMORY_ENABLED=false — не писать stumble в route_risk.jsonl.

# ROUTE_RISK_MEMORY_ENABLED — route risk memory enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ROUTE_RISK_MEMORY_ENABLED=true

ROUTE_RISK_MEMORY_ENABLED=true

# ROUTE_RISK_RECORD_CLARIFY — route risk record clarify.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ROUTE_RISK_RECORD_CLARIFY=true

ROUTE_RISK_RECORD_CLARIFY=false

# ROUTE_RISK_HINT_ENABLED — route risk hint enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ROUTE_RISK_HINT_ENABLED=true

ROUTE_RISK_HINT_ENABLED=true

# TURN_OBSERVER_ENABLED — turn observer enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
