# =============================================================================
# Ephemeral Autolearn (core/ephemeral_autolearn.py): авто-продвижение наблюдений
# =============================================================================
# ID пользователей, которым доверяем (через запятую)
# EPHEMERAL_AUTOLEARN_TRUST_USER_IDS — ephemeral autolearn trust user ids.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EPHEMERAL_AUTOLEARN_TRUST_USER_IDS=<значение>

# EPHEMERAL_AUTOLEARN_TRUST_USER_IDS — ephemeral autolearn trust user ids.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EPHEMERAL_AUTOLEARN_TRUST_USER_IDS=<значение>

# EPHEMERAL_AUTOLEARN_TRUST_USER_IDS=

# EPHEMERAL_AUTOLEARN_STRIKES_TRUSTED — ephemeral autolearn strikes trusted.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EPHEMERAL_AUTOLEARN_STRIKES_TRUSTED=<значение>

EPHEMERAL_AUTOLEARN_STRIKES_TRUSTED=2

# EPHEMERAL_AUTOLEARN_STRIKES_UNTRUSTED — ephemeral autolearn strikes untrusted.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: EPHEMERAL_AUTOLEARN_STRIKES_UNTRUSTED=<значение>

EPHEMERAL_AUTOLEARN_STRIKES_UNTRUSTED=999

# EPHEMERAL_AUTOLEARN_MAX_PROMOTIONS_PER_DAY — ephemeral autolearn max promotions per day.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: EPHEMERAL_AUTOLEARN_MAX_PROMOTIONS_PER_DAY=10

EPHEMERAL_AUTOLEARN_MAX_PROMOTIONS_PER_DAY=30
