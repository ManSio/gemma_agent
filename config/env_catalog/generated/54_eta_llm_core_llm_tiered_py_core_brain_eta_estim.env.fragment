# =============================================================================
# Таймауты и ETA для LLM (core/llm_tiered.py, core/brain/eta_estimate.py)
# =============================================================================
# Порог длины промпта (символов) для пересчёта таймаута LLM
# BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD — brain llm timeout prompt chars threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD=10

# BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD — brain llm timeout prompt chars threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD=10

BRAIN_LLM_TIMEOUT_PROMPT_CHARS_THRESHOLD=7000

# BRAIN_LLM_TIMEOUT_MAX_TOKENS_THRESHOLD — brain llm timeout max tokens threshold.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_TIMEOUT_MAX_TOKENS_THRESHOLD=10

BRAIN_LLM_TIMEOUT_MAX_TOKENS_THRESHOLD=1800

# BRAIN_LLM_FREE_TIMEOUT_SHORT_SEC — brain llm free timeout short sec.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: BRAIN_LLM_FREE_TIMEOUT_SHORT_SEC=true

BRAIN_LLM_FREE_TIMEOUT_SHORT_SEC=0

# BRAIN_LLM_ETA_OVERHEAD_SEC — brain llm eta overhead sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_LLM_ETA_OVERHEAD_SEC=10

BRAIN_LLM_ETA_OVERHEAD_SEC=2.0
