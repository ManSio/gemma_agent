# =============================================================================
# Файлы, изображения, документы, код
# =============================================================================

# FILE_INTAKE_ENABLED — file intake enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: FILE_INTAKE_ENABLED=true

# FILE_INTAKE_ENABLED — file intake enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: FILE_INTAKE_ENABLED=true

FILE_INTAKE_ENABLED=true

# FILE_MAX_IMAGE_MB — file max image mb.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: FILE_MAX_IMAGE_MB=10

FILE_MAX_IMAGE_MB=10

# FILE_MAX_DOC_MB — file max doc mb.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: FILE_MAX_DOC_MB=10

FILE_MAX_DOC_MB=15

# FILE_MAX_AUDIO_MB — file max audio mb.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: FILE_MAX_AUDIO_MB=10

FILE_MAX_AUDIO_MB=15

# FILE_TEMP_DIR — file temp dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: FILE_TEMP_DIR=data/runtime/example.json

FILE_TEMP_DIR=

# IMAGE_TOOLS_ENABLED — image tools enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: IMAGE_TOOLS_ENABLED=true

IMAGE_TOOLS_ENABLED=true

# IMAGE_MAX_RESOLUTION — image max resolution.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: IMAGE_MAX_RESOLUTION=10

IMAGE_MAX_RESOLUTION=2048

# IMAGE_EDIT_BACKEND_URL — image edit backend url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: IMAGE_EDIT_BACKEND_URL=http://127.0.0.1:8001

IMAGE_EDIT_BACKEND_URL=http://127.0.0.1:8091/edit

# IMAGE_EDIT_BACKEND_TIMEOUT_SEC — image edit backend timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: IMAGE_EDIT_BACKEND_TIMEOUT_SEC=10

IMAGE_EDIT_BACKEND_TIMEOUT_SEC=45

# IMAGE_EDIT_BACKEND_TOKEN — image edit backend token.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: IMAGE_EDIT_BACKEND_TOKEN=<значение>

# IMAGE_EDIT_BACKEND_TOKEN=

# IMAGE_GEN_ENABLED — image gen enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: IMAGE_GEN_ENABLED=true

IMAGE_GEN_ENABLED=true

# IMAGE_GEN_API_URL — image gen api url.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: IMAGE_GEN_API_URL=http://127.0.0.1:8001

IMAGE_GEN_API_URL=https://openrouter.ai/api/v1/chat/completions

# IMAGE_GEN_MODEL — image gen model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: IMAGE_GEN_MODEL=deepseek/deepseek-v4-flash

IMAGE_GEN_MODEL=google/gemini-3.1-flash-image-preview

# IMAGE_GEN_MODEL_FALLBACK — image gen model fallback.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: IMAGE_GEN_MODEL_FALLBACK=google/gemini-2.5-flash-image

IMAGE_GEN_MODEL_FALLBACK=google/gemini-2.5-flash-image

# IMAGE_GEN_MODALITIES — image gen modalities.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: IMAGE_GEN_MODALITIES=<значение>

IMAGE_GEN_MODALITIES=image,text

# IMAGE_GEN_RETRY_ON_400 — image gen retry on 400.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: IMAGE_GEN_RETRY_ON_400=true

IMAGE_GEN_RETRY_ON_400=true

# IMAGE_GEN_ASPECT_RATIO — image gen aspect ratio.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: IMAGE_GEN_ASPECT_RATIO=<значение>

IMAGE_GEN_ASPECT_RATIO=1:1

# IMAGE_GEN_SIZE — image gen size.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: IMAGE_GEN_SIZE=<значение>

IMAGE_GEN_SIZE=1024x1024

# IMAGE_GEN_QUALITY — image gen quality.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: IMAGE_GEN_QUALITY=<значение>

IMAGE_GEN_QUALITY=medium

# IMAGE_GEN_STYLE — image gen style.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: IMAGE_GEN_STYLE=<значение>

IMAGE_GEN_STYLE=vivid

# IMAGE_GEN_TIMEOUT_SEC — image gen timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: IMAGE_GEN_TIMEOUT_SEC=10

IMAGE_GEN_TIMEOUT_SEC=90

# IMAGE_GEN_OUTPUT_DIR — image gen output dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: IMAGE_GEN_OUTPUT_DIR=data/runtime/example.json

IMAGE_GEN_OUTPUT_DIR=./data/generated_images

# IMAGE_GEN_DAILY_LIMIT_PER_USER — image gen daily limit per user.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: IMAGE_GEN_DAILY_LIMIT_PER_USER=10

IMAGE_GEN_DAILY_LIMIT_PER_USER=15

# IMAGE_GEN_QUOTA_PATH — image gen quota path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: IMAGE_GEN_QUOTA_PATH=data/runtime/example.json

IMAGE_GEN_QUOTA_PATH=./data/runtime/image_gen_quota.json

# IMAGE_GEN_NL_ROUTE — image gen nl route.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: IMAGE_GEN_NL_ROUTE=true

IMAGE_GEN_NL_ROUTE=true

# IMAGE_GEN_NL_MAX_CHARS — image gen nl max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: IMAGE_GEN_NL_MAX_CHARS=10

IMAGE_GEN_NL_MAX_CHARS=3000

# IMAGE_GEN_IMAGE_CONFIG — image gen image config.

IMAGE_GEN_IMAGE_CONFIG=true

# IMAGE_GEN_REFERENCE_ENABLED — image gen reference enabled.

IMAGE_GEN_REFERENCE_ENABLED=true

# IMAGE_GEN_REFERENCE_MAX_BYTES — image gen reference max bytes.

IMAGE_GEN_REFERENCE_MAX_BYTES=4194304

# IMAGE_GEN_REFERENCE_MAX_COUNT — image gen reference max count.

IMAGE_GEN_REFERENCE_MAX_COUNT=2

# BUG_CAPTURE_RECENT_MESSAGES — bug capture recent messages.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BUG_CAPTURE_RECENT_MESSAGES=<значение>

BUG_CAPTURE_RECENT_MESSAGES=5

# IMAGE_PENDING_TTL_SEC — image pending ttl sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: IMAGE_PENDING_TTL_SEC=10

IMAGE_PENDING_TTL_SEC=300

# TELEGRAM_RECENT_MSG_BUFFER — telegram recent msg buffer.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: TELEGRAM_RECENT_MSG_BUFFER=10

TELEGRAM_RECENT_MSG_BUFFER=40

# Доп. текст в промпт мозга (самокоррекция, директивы). Пример: скопировать
# config/system_directive_addon_v3.example.txt → data/runtime/system_directive_addon.txt

SYSTEM_DIRECTIVE_ADDON_PATH=data/runtime/system_directive_addon.txt

# DOC_INTAKE_ENABLED — doc intake enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DOC_INTAKE_ENABLED=true

DOC_INTAKE_ENABLED=true

# PDF_INTAKE_BACKEND — pdf intake backend.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: PDF_INTAKE_BACKEND=<значение>

PDF_INTAKE_BACKEND=auto

# PDF_INTAKE_MAX_PAGES — pdf intake max pages.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: PDF_INTAKE_MAX_PAGES=10

PDF_INTAKE_MAX_PAGES=200

# DOC_INTAKE_PLAIN_MAX_BYTES — doc intake plain max bytes.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: DOC_INTAKE_PLAIN_MAX_BYTES=10

DOC_INTAKE_PLAIN_MAX_BYTES=400000

# ZIP_MAX_ENTRIES — zip max entries.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: ZIP_MAX_ENTRIES=10

ZIP_MAX_ENTRIES=200

# ZIP_MAX_UNPACKED_MB — zip max unpacked mb.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: ZIP_MAX_UNPACKED_MB=10

ZIP_MAX_UNPACKED_MB=100

# CODE_INTAKE_ENABLED — code intake enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: CODE_INTAKE_ENABLED=true

CODE_INTAKE_ENABLED=true

# CODE_INTAKE_MAX_FILE_KB — code intake max file kb.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: CODE_INTAKE_MAX_FILE_KB=10

CODE_INTAKE_MAX_FILE_KB=512

# BRAIN_DOCUMENT_PROMPT_MAX_CHARS — brain document prompt max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_DOCUMENT_PROMPT_MAX_CHARS=10

BRAIN_DOCUMENT_PROMPT_MAX_CHARS=14000

# BRAIN_PLUGIN_MANIFEST_PROMPTS_MAX_CHARS — brain plugin manifest prompts max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: BRAIN_PLUGIN_MANIFEST_PROMPTS_MAX_CHARS=10

BRAIN_PLUGIN_MANIFEST_PROMPTS_MAX_CHARS=6000

# BRAIN_PROMPT_CLIP_MODE — brain prompt clip mode.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: BRAIN_PROMPT_CLIP_MODE=<значение>

BRAIN_PROMPT_CLIP_MODE=soft
