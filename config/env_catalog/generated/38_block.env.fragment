# =============================================================================
# Паспорт развития
# =============================================================================

# DEVELOPMENT_PASSPORT_PATH — development passport path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: DEVELOPMENT_PASSPORT_PATH=data/runtime/example.json

# DEVELOPMENT_PASSPORT_PATH — development passport path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: DEVELOPMENT_PASSPORT_PATH=data/runtime/example.json

DEVELOPMENT_PASSPORT_PATH=./data/development_passport.json

# PASSPORT_BACKUP_DIR — passport backup dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: PASSPORT_BACKUP_DIR=data/runtime/example.json

PASSPORT_BACKUP_DIR=./data/passport_backups

# RESTART_WATCH_COMMAND — restart watch command.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RESTART_WATCH_COMMAND=<значение>

RESTART_WATCH_COMMAND=docker compose restart bot

# RESTART_WATCH_INTERVAL_SEC — restart watch interval sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: RESTART_WATCH_INTERVAL_SEC=10

RESTART_WATCH_INTERVAL_SEC=5
