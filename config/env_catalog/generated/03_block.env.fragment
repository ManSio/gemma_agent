# =============================================================================
# Логи и телеметрия
# =============================================================================

# --- Уровень логирования Python (DEBUG, INFO, …)
# LOG_LEVEL — log level.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LOG_LEVEL=<значение>

# LOG_LEVEL — log level.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LOG_LEVEL=<значение>

LOG_LEVEL=INFO

# LOG_FORMAT — log format.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LOG_FORMAT=<значение>

LOG_FORMAT=json

# GEMMA_REPORT_TIMEZONE — gemma report timezone.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_REPORT_TIMEZONE=<значение>

GEMMA_REPORT_TIMEZONE=Europe/Minsk

# GEMMA_INSTANCE_ATTRIBUTION_ENABLED — gemma instance attribution enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_INSTANCE_ATTRIBUTION_ENABLED=true

GEMMA_INSTANCE_ATTRIBUTION_ENABLED=false

# GEMMA_INSTANCE_AUTHOR — gemma instance author.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_INSTANCE_AUTHOR=<значение>

GEMMA_INSTANCE_AUTHOR=GemmaProject

# GEMMA_INSTANCE_CREDIT_LINE — gemma instance credit line.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_INSTANCE_CREDIT_LINE=<значение>

GEMMA_INSTANCE_CREDIT_LINE=Этот бот настроил …

# GEMMA_CORE_LOG_FULL — gemma core log full.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_CORE_LOG_FULL=true

GEMMA_CORE_LOG_FULL=true

# GEMMA_LLM_AUDIT_LOG — gemma llm audit log.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_LLM_AUDIT_LOG=true

GEMMA_LLM_AUDIT_LOG=true

# GEMMA_LOG_ROTATE_HOURS — gemma log rotate hours.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GEMMA_LOG_ROTATE_HOURS=10

GEMMA_LOG_ROTATE_HOURS=6

# GEMMA_LOG_FILE_MAX_MB — gemma log file max mb.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GEMMA_LOG_FILE_MAX_MB=10

GEMMA_LOG_FILE_MAX_MB=32

# GEMMA_LOG_FILE_BACKUPS — gemma log file backups.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_LOG_FILE_BACKUPS=<значение>

GEMMA_LOG_FILE_BACKUPS=20

# GEMMA_LOG_COMPACT — gemma log compact.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_LOG_COMPACT=true

GEMMA_LOG_COMPACT=true

# GEMMA_CRITICAL_LOG_ENABLED — gemma critical log enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_CRITICAL_LOG_ENABLED=true

GEMMA_CRITICAL_LOG_ENABLED=true

# GEMMA_CRITICAL_LOG_FILE — gemma critical log file.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_CRITICAL_LOG_FILE=<значение>

GEMMA_CRITICAL_LOG_FILE=./data/logs/gemma_critical.log

# GEMMA_CRITICAL_CONTEXT_BUFFER_LINES — gemma critical context buffer lines.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_CRITICAL_CONTEXT_BUFFER_LINES=<значение>

GEMMA_CRITICAL_CONTEXT_BUFFER_LINES=140

# GEMMA_CRITICAL_CONTEXT_TAIL_LINES — gemma critical context tail lines.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: GEMMA_CRITICAL_CONTEXT_TAIL_LINES=<значение>

GEMMA_CRITICAL_CONTEXT_TAIL_LINES=30

# LATENCY_TRACE_LOG — latency trace log.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LATENCY_TRACE_LOG=<значение>

LATENCY_TRACE_LOG=all

# LATENCY_TRACE_SLOW_MS — latency trace slow ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LATENCY_TRACE_SLOW_MS=10

LATENCY_TRACE_SLOW_MS=1800

# LIVE_PULSE_PLANNER_TAIL — live pulse planner tail.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LIVE_PULSE_PLANNER_TAIL=<значение>

LIVE_PULSE_PLANNER_TAIL=48

# LIVE_PULSE_TELEGRAM_P95_WARN_MS — live pulse telegram p95 warn ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LIVE_PULSE_TELEGRAM_P95_WARN_MS=10

LIVE_PULSE_TELEGRAM_P95_WARN_MS=60000

# LIVE_PULSE_TELEGRAM_P95_CRITICAL_MS — live pulse telegram p95 critical ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LIVE_PULSE_TELEGRAM_P95_CRITICAL_MS=10

LIVE_PULSE_TELEGRAM_P95_CRITICAL_MS=90000

# LIVE_PULSE_OPENROUTER_P95_CRITICAL_MS — live pulse openrouter p95 critical ms.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: LIVE_PULSE_OPENROUTER_P95_CRITICAL_MS=10

LIVE_PULSE_OPENROUTER_P95_CRITICAL_MS=35000
