# =============================================================================
# Маршрут math (/calc): только явные фразы или короткое выражение (см. intent_heuristics)
# =============================================================================

# MATH_IMPLICIT_RAW_MAX_CHARS — math implicit raw max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MATH_IMPLICIT_RAW_MAX_CHARS=10

# MATH_IMPLICIT_RAW_MAX_CHARS — math implicit raw max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MATH_IMPLICIT_RAW_MAX_CHARS=10

MATH_IMPLICIT_RAW_MAX_CHARS=220

# MATH_IMPLICIT_SCRUB_MAX_CHARS — math implicit scrub max chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MATH_IMPLICIT_SCRUB_MAX_CHARS=10

MATH_IMPLICIT_SCRUB_MAX_CHARS=132

# MATH_IMPLICIT_MAX_LETTERS — math implicit max letters.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MATH_IMPLICIT_MAX_LETTERS=10

MATH_IMPLICIT_MAX_LETTERS=28

# MATH_VERB_LONG_PROSE_CHARS — math verb long prose chars.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MATH_VERB_LONG_PROSE_CHARS=10

MATH_VERB_LONG_PROSE_CHARS=320

# MATH_AMBIGUOUS_CLARIFY — math ambiguous clarify.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: MATH_AMBIGUOUS_CLARIFY=true

MATH_AMBIGUOUS_CLARIFY=true
