# =============================================================================
# Пути и каталоги данных
# =============================================================================

# --- Корень манифестов плагинов modules/
# MODULES_PATH — modules path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: MODULES_PATH=data/runtime/example.json

# MODULES_PATH — modules path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: MODULES_PATH=data/runtime/example.json

MODULES_PATH=./modules

# CORE_LIBRARIES_PATH — core libraries path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: CORE_LIBRARIES_PATH=data/runtime/example.json

CORE_LIBRARIES_PATH=./core_libraries

# PROJECT_ROOT — project root.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: PROJECT_ROOT=<значение>

PROJECT_ROOT=

# USER_PERSONAS_PATH — user personas path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: USER_PERSONAS_PATH=data/runtime/example.json

USER_PERSONAS_PATH=data/user_personas.json

# GEMMA_UPDATE_AUTOSTASH_PANEL — gemma update autostash panel.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_UPDATE_AUTOSTASH_PANEL=true

GEMMA_UPDATE_AUTOSTASH_PANEL=true

# RUNTIME_ENSURE_DATA_LAYOUT — runtime ensure data layout.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RUNTIME_ENSURE_DATA_LAYOUT=true

RUNTIME_ENSURE_DATA_LAYOUT=true

# RUNTIME_DIR_MODE — runtime dir mode.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: RUNTIME_DIR_MODE=<значение>

RUNTIME_DIR_MODE=750

# --- Копировать примеры в data/runtime при старте, если файлов ещё нет:
#     system_directive_addon.txt ← config/system_directive_addon_v3.example.txt
#     operator_rules.json ← config/operator_rules.example.json

RUNTIME_CONFIG_SEED=true

# RUNTIME_DIRECTIVE_SEED_FORCE — runtime directive seed force.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RUNTIME_DIRECTIVE_SEED_FORCE=true

RUNTIME_DIRECTIVE_SEED_FORCE=true

# RUNTIME_OPERATOR_RULES_SEED_FORCE — runtime operator rules seed force.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: RUNTIME_OPERATOR_RULES_SEED_FORCE=true

RUNTIME_OPERATOR_RULES_SEED_FORCE=true

# PLUGIN_MANIFEST_PATHS — plugin manifest paths.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: PLUGIN_MANIFEST_PATHS=data/runtime/example.json

PLUGIN_MANIFEST_PATHS=

# RAG_DATABASE_PATH — rag database path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: RAG_DATABASE_PATH=data/runtime/example.json

RAG_DATABASE_PATH=./data/rag

# CACHE_PATH — cache path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: CACHE_PATH=data/runtime/example.json

CACHE_PATH=./data/cache

# MODELS_PATH — models path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: MODELS_PATH=data/runtime/example.json

MODELS_PATH=./models

# BEHAVIOR_DATA_DIR — behavior data dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: BEHAVIOR_DATA_DIR=data/runtime/example.json

BEHAVIOR_DATA_DIR=./data/users

# USER_AGENT_IMPRESSION_ENABLED — user agent impression enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: USER_AGENT_IMPRESSION_ENABLED=true

USER_AGENT_IMPRESSION_ENABLED=true

# ERROR_ANALYSIS_DIR — error analysis dir.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: ERROR_ANALYSIS_DIR=data/runtime/example.json

ERROR_ANALYSIS_DIR=./data

# GEMMA_LLM_USAGE_PERSIST — gemma llm usage persist.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GEMMA_LLM_USAGE_PERSIST=true

GEMMA_LLM_USAGE_PERSIST=true

# GEMMA_LLM_USAGE_PATH — gemma llm usage path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: GEMMA_LLM_USAGE_PATH=data/runtime/example.json

# GEMMA_LLM_USAGE_PATH=

# DATABASE_PATH — database path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: DATABASE_PATH=data/runtime/example.json

DATABASE_PATH=./data/database.sqlite
