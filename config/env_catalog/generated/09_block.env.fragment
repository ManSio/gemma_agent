# =============================================================================
# Приложение и антиабьюз
# =============================================================================

# APP_ENV — app env.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: APP_ENV=<значение>

# APP_ENV — app env.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: APP_ENV=<значение>

APP_ENV=production

# ANTI_FLOOD_ENABLED — anti flood enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: ANTI_FLOOD_ENABLED=true

ANTI_FLOOD_ENABLED=true

# MAX_MSG_PER_10S — max msg per 10s.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: MAX_MSG_PER_10S=10

MAX_MSG_PER_10S=7

# MAX_SAME_TEXT — max same text.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MAX_SAME_TEXT=<значение>

MAX_SAME_TEXT=3

# MAX_CMD_PER_10S — max cmd per 10s.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: MAX_CMD_PER_10S=<значение>

MAX_CMD_PER_10S=4

# GROUP_COOLDOWN_SEC — group cooldown sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: GROUP_COOLDOWN_SEC=10

GROUP_COOLDOWN_SEC=2.0

# GROUP_LOOSE_BOTNAME_TRIGGER — group loose botname trigger.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: GROUP_LOOSE_BOTNAME_TRIGGER=true

GROUP_LOOSE_BOTNAME_TRIGGER=false

# HARD_FLOOD_MULTIPLIER — hard flood multiplier.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: HARD_FLOOD_MULTIPLIER=<значение>

HARD_FLOOD_MULTIPLIER=2

# ANTI_FLOOD_RESPONSE — anti flood response.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: ANTI_FLOOD_RESPONSE=<значение>

ANTI_FLOOD_RESPONSE='Слишком много сообщений подряд. Подожди немного.'

# LINK_SAFETY_ENABLED — link safety enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: LINK_SAFETY_ENABLED=true

LINK_SAFETY_ENABLED=true

# LINK_SAFETY_MODE — link safety mode.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: LINK_SAFETY_MODE=<значение>

LINK_SAFETY_MODE=warn

# LINK_REPUTATION_API_ENDPOINT — link reputation api endpoint.
#   URL сервиса; пусто — функция отключена или встроенный fallback.
#   Пример: LINK_REPUTATION_API_ENDPOINT=http://127.0.0.1:8001

LINK_REPUTATION_API_ENDPOINT=

# LINK_REPUTATION_API_KEY — link reputation api key.
#   Секрет — не коммитить; хранить только в .env на сервере/ПК.
#   Пример: LINK_REPUTATION_API_KEY=<значение из панели провайдера>

LINK_REPUTATION_API_KEY=
