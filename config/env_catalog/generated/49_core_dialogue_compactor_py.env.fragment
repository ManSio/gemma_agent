# =============================================================================
# Диалоговый компактор (core/dialogue_compactor.py): сжатие длинных диалогов
# =============================================================================
# Использовать LLM для сжатия диалога (true/false)
# DIALOGUE_COMPACT_LLM — dialogue compact llm.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOGUE_COMPACT_LLM=true

# DIALOGUE_COMPACT_LLM — dialogue compact llm.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: DIALOGUE_COMPACT_LLM=true

DIALOGUE_COMPACT_LLM=false

# DIALOGUE_COMPACT_LLM_MODEL — dialogue compact llm model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: DIALOGUE_COMPACT_LLM_MODEL=deepseek/deepseek-v4-flash

# DIALOGUE_COMPACT_LLM_MODEL=

# DIALOGUE_COMPACT_MAX_TOKENS — dialogue compact max tokens.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: DIALOGUE_COMPACT_MAX_TOKENS=10

DIALOGUE_COMPACT_MAX_TOKENS=220

# DIALOGUE_COMPACT_TIMEOUT_SEC — dialogue compact timeout sec.
#   Число; порог/лимит из кода читает эту переменную (без «магии» в .py).
#   Пример: DIALOGUE_COMPACT_TIMEOUT_SEC=10

DIALOGUE_COMPACT_TIMEOUT_SEC=25
