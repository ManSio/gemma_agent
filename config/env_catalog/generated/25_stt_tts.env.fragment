# =============================================================================
# Голос STT/TTS
# =============================================================================

# VOICE_ENABLED — voice enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: VOICE_ENABLED=true

# VOICE_ENABLED — voice enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: VOICE_ENABLED=true

VOICE_ENABLED=true

# VOICE_STT_ENABLED — voice stt enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: VOICE_STT_ENABLED=true

VOICE_STT_ENABLED=true

# VOICE_STT_BACKEND — voice stt backend.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: VOICE_STT_BACKEND=<значение>

VOICE_STT_BACKEND=vosk

# VOICE_STT_MODEL_PATH — voice stt model path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: VOICE_STT_MODEL_PATH=data/runtime/example.json

VOICE_STT_MODEL_PATH=./models/vosk-model-small-ru

# VOICE_VOSK_FFMPEG — voice vosk ffmpeg.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: VOICE_VOSK_FFMPEG=true

VOICE_VOSK_FFMPEG=true

# VOICE_FFMPEG_BIN — voice ffmpeg bin.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: VOICE_FFMPEG_BIN=<значение>

VOICE_FFMPEG_BIN=ffmpeg

# VOICE_STT_FALLBACK_BACKEND — voice stt fallback backend.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: VOICE_STT_FALLBACK_BACKEND=<значение>

VOICE_STT_FALLBACK_BACKEND=openrouter

# VOICE_OPENROUTER_STT_MODEL — voice openrouter stt model.
#   Slug модели OpenRouter или локального сервиса.
#   Пример: VOICE_OPENROUTER_STT_MODEL=deepseek/deepseek-v4-flash

VOICE_OPENROUTER_STT_MODEL=google/gemini-2.0-flash-001

# VOICE_STT_LOCAL_ONLY — voice stt local only.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: VOICE_STT_LOCAL_ONLY=true

VOICE_STT_LOCAL_ONLY=true

# VOICE_TTS_ENABLED — voice tts enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: VOICE_TTS_ENABLED=true

VOICE_TTS_ENABLED=true

# VOICE_TTS_BACKEND — voice tts backend.
#   Строковое значение; пусто — дефолт в коде.
#   Пример: VOICE_TTS_BACKEND=<значение>

VOICE_TTS_BACKEND=piper

# VOICE_TTS_MODEL_PATH — voice tts model path.
#   Путь к файлу или каталогу на диске сервера.
#   Пример: VOICE_TTS_MODEL_PATH=data/runtime/example.json

VOICE_TTS_MODEL_PATH=./models/piper/ru_RU-irina-medium.onnx

# VOICE_REPLY_ENABLED — voice reply enabled.
#   true / 1 / on / yes — включено.
#   false / 0 / off / no — выключено.
#   Пример: VOICE_REPLY_ENABLED=true

VOICE_REPLY_ENABLED=false
