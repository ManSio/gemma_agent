# =============================================================================
# НОВОСТИ — дайджест в Telegram (RSS + веб-поиск + LLM)
# См. также: docs/DEV_DIARY_RU.md (блоки 2026-05-24), core/telegram_output_guard.py
# =============================================================================

# BRAIN_NEWS_DIRECT_FROM_SEARCH — откуда берётся текст ответа на «какие новости».
#   false (рекомендуется): RSS/поиск → сырьё в LLM → 3–4 предложения на пункт, видно «что внутри».
#     Пример ответа: «1. НАТО усиливает ПВО … — Союзники обсуждают … · Reuters»
#   true: без LLM, сразу готовый список (быстро/дёшево, но часто только заголовки).
#     Пример: «1. Заголовок · reuters.com» — сухо, без разбора.
BRAIN_NEWS_DIRECT_FROM_SEARCH=false

# NEWS_DIGEST_LLM_SUMMARY — дайджест: 3–4 предложения на пункт по заголовку RSS (без мусора из поиска).
#   true (рекомендуется): нормальная сводка в Telegram.
NEWS_DIGEST_LLM_SUMMARY=true

# NEWS_ENRICH_ON_DIGEST — подмешивать веб-поиск к RSS при сборе дайджеста (часто «Как → Викисловарь»).
#   false (рекомендуется): поиск только при выборе пункта «2» / «подробнее».
NEWS_ENRICH_ON_DIGEST=false

# NEWS_ENRICH_SEARCH_SNIPPETS — подмешать выдержки из поиска в brain pipeline (не в news_direct).
NEWS_ENRICH_SEARCH_SNIPPETS=false

# NEWS_DIRECT_REPLY_ENABLED — дайджест без полного brain (orchestrator news_direct + pipeline).
# NEWS_ITEM_PICK_ENABLED — пункт по номеру «2» после дайджеста (поиск + url_fetch полного текста).
# NEWS_ITEM_FULL_ARTICLE=true — полная статья, не LLM по заголовку.
# NEWS_ITEM_FULL_MAX_CHARS=12000
# NEWS_ITEM_MAX_IMAGES=3
# NEWS_ITEM_FETCH_TIMEOUT_SEC=12
# NEWS_ITEM_REQUIRE_TITLE_ANCHORS=true — отсечь чужую статью (Севастополь vs Одесса при общих «ракетный удар»).
# NEWS_ITEM_FETCH_MIN_SCORE=0.20 — мин. совпадение заголовка и текста при url_fetch после поиска.

# NEWS_BRIEF_FOOTER — строка внизу краткого дайджеста (direct-режим).
#   по умолчанию: подсказка «номер пункта / развёрнуто»
#   0 / false / off — без подвала
# NEWS_BRIEF_FOOTER=Напишите номер пункта или «развёрнуто» — расскажу подробнее.

# NEWS_DIRECT_MAX_ITEMS — сколько пунктов в списке (direct или после обрезки LLM).
#   5–7: длиннее текст на пункт; 12: больше заголовков, короче каждый.
NEWS_DIRECT_MAX_ITEMS=7

# NEWS_RSS_MAX_ITEMS — сколько статей тянуть из Google News RSS (до дедупа доменов).
NEWS_RSS_MAX_ITEMS=12

# NEWS_BRIEF_SOURCE_MAX_ITEMS — сколько пунктов отдать в external_hint для LLM.
NEWS_BRIEF_SOURCE_MAX_ITEMS=7

# NEWS_SNIPPET_MAX_CHARS — макс. длина выдержки из поиска на один пункт.
NEWS_SNIPPET_MAX_CHARS=520

# NEWS_BRIEF_HINT_MAX_CHARS — макс. объём сырого блока новостей в промпте (краткий режим).
NEWS_BRIEF_HINT_MAX_CHARS=5500

# NEWS_REPLY_MAX_ITEMS — обрезка нумерованного списка в ответе LLM (anti-hallucination).
NEWS_REPLY_MAX_ITEMS=7

# NEWS_WORLD_RSS_LANG — язык мировой ленты при запросе «в мире».
#   ru (по умолчанию для кириллицы): заголовки на русском.
#   en: NDTV/BBC и т.д. — NEWS_WORLD_RSS_LANG=en
# NEWS_WORLD_RSS_LANG=

# NEWS_WORLD_RSS_QUERY — свой поисковый запрос в Google News для мировой ленты.
#   Пусто: «международные новости» (ru) или «world news» (en).
# NEWS_WORLD_RSS_QUERY=

# NEWS_GOOGLE_RSS_LOCALE — полная подмена locale RSS (hl=…&gl=…&ceid=…).
#   Пример англ. ленты: hl=en&gl=US&ceid=US:en
# NEWS_GOOGLE_RSS_LOCALE=

# NEWS_BLOCKED_DOMAINS — доп. домены-мусор через запятую (сатира, фейки).
# NEWS_BLOCKED_DOMAINS=example-fake.com
