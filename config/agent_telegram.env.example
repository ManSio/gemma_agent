# Скопируйте в config/agent_telegram.env (файл в .gitignore через data/ — держите локально)
# Ключи: https://my.telegram.org/apps → API development tools

# api_id — число; api_hash — ровно 32 hex-символа (целиком с my.telegram.org)
AGENT_TELEGRAM_API_ID=12345678
AGENT_TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Username бота без @ (BOT_TEST → BOT_TEST_USERNAME)
AGENT_TARGET_BOT_USERNAME=BOT_TEST_USERNAME

# Опционально: телефон для первого входа (+375...)
AGENT_TELEGRAM_PHONE=

# Опционально: HTTP API на сервере (agent_probe_http.py)
AGENT_PROBE_API_URL=
API_TOKEN=
