# =============================================================================
# PROFILE: power_agent — fuller Plan → Execute → Verify loop (opt-in)
#
# Default public .env.example is chat-first (stable for 3–8 users).
# This profile enables multi-step goals, self-verify, and quality-loop audit.
#
# Apply to working .env:
#   python scripts/apply_power_agent_env.py
#   bash scripts/apply_power_agent_env.sh
#
# Docs: docs/AGENT_LOOP.md
# Verify:
#   pytest tests/test_goal_runner.py tests/test_turn_quality_loop.py -q
#   python scripts/gemma_status.py --online
#
# Mem0: for semantic LTM use a real Mem0 server (not JSON stub):
#   In scripts/gemma_panel.local.conf set GEMMA_MEM0_USE_STUB=false
#   Run: bash scripts/apply_mem0_local_server.sh  (or your Mem0 URL)
# =============================================================================

# --- Multi-step planner (Goal Runner) ---
GOAL_RUNNER_ENABLED=true
GOAL_RUNNER_EXECUTOR_MODE=true
GOAL_RUNNER_AUTO_START=true
GOAL_RUNNER_AUTO_START_SMART=true
GOAL_RUNNER_PLAN_VALIDATOR=true
GOAL_RUNNER_TELEGRAM_PROGRESS=true

# --- Critic / verify before send ---
SELF_VERIFY_ACTIVE=true
REFLECTION_HEAVY_ENABLED=true

# --- Post-hoc turn audit (background, non-blocking) ---
TURN_QUALITY_LOOP_ENABLED=true
TURN_QUALITY_LESSON_DRAFT=true
TURN_QUALITY_SCAN_ON_TICK=true

# --- Resilience (on by default; explicit for reviewers) ---
HEALERS_ENABLED=true
RESILIENCE_AUTONOMY_ENABLED=true

# --- Goals engine (long-horizon hints) ---
GOAL_ENGINE_ENABLED=true

# --- MCE stays off in public build (owner-only prod experiments) ---
MCE_ENABLED=false
MCE_AUTO_APPLY=false
MCE_EXPERIMENT_ENABLED=false

# --- Mem0: point to server with embeddings (adjust host/port) ---
# Stub URL works for dev; production power profile should use real Mem0:
MEM0_API_URL=http://127.0.0.1:8001
MEM0_API_PREFIX=v3
