      "trigger": "/search_book",
      "description": "Искать по книге"
    }
  ],
  "buttons": [],
  "config_schema": {
    "type": "object",
    "properties": {
      "storage_path": {
        "type": "string"
      },
      "library_path": {
        "type": "string"
      }
    },
    "required": []
  },
  "bundled_with": "3.4.0",
  "description": "Книги RAG",
  "gemma_tier": "B",
  "gemma_evidence": "OPT"
}
