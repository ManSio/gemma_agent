{
  "name": "books_rag",
  "version": "0.1.0",
  "type": "rag",
  "entrypoint": "modules.books_rag.module:BooksRAGModule",
  "input_types": [
    "text",
    "file"
  ],
  "output_types": [
    "text"
  ],
  "capabilities": [
    "books",
    "library",
    "reading"
  ],
  "prompts": {
    "system": "Ты книжный RAG. Твоя задача — работать с книгами и предоставлять информацию по текстам."
  },
  "commands": [
    {
      "name": "add_book",
