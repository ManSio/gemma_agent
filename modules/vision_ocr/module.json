  "input_types": [
    "image"
  ],
  "output_types": [
    "text"
  ],
  "capabilities": [
    "vision",
    "ocr"
  ],
  "prompts": {
    "system": "Ты модуль OCR. Твоя задача — извлекать текст с изображений."
  },
  "commands": [
    {
      "name": "ocr",
